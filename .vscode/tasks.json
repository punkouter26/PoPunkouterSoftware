{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "kill-dotnet",
			"type": "shell",
			"command": "Get-Process dotnet -ErrorAction SilentlyContinue | Stop-Process -Force; exit 0",
			"windows": {
				"command": "Get-Process dotnet -ErrorAction SilentlyContinue | Stop-Process -Force; exit 0"
			},
			"presentation": {
				"echo": false,
				"reveal": "silent",
				"focus": false,
				"panel": "shared",
				"close": true
			},
			"problemMatcher": []
		},
		{
			"label": "start-live-server",
			"type": "shell",
			"command": "node",
			"args": ["${workspaceFolder}/server.js"],
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared"
			},
			"isBackground": true,
			"problemMatcher": {
				"pattern": {
					"regexp": "^.*$",
					"file": 1,
					"location": 2,
					"message": 3
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "^.*Server running at.*$",
					"endsPattern": "^.*Server running at.*$"
				}
			}
		},
		{
			"label": "clean",
			"command": "dotnet",
			"windows": {
				"command": "${env:ProgramFiles}\\dotnet\\x64\\dotnet.exe"
			},
			"type": "process",
			"args": [
				"clean",
				"${workspaceFolder}/PoPunkouterSoftware",
				"/property:GenerateFullPaths=true",
				"/consoleloggerparameters:NoSummary"
			],
			"problemMatcher": "$msCompile"
		},
		{
			"label": "publish-release",
			"command": "dotnet",
			"windows": {
				"command": "${env:ProgramFiles}\\dotnet\\x64\\dotnet.exe"
			},
			"type": "process",
			"args": [
				"publish",
				"${workspaceFolder}/PoPunkouterSoftware",
				"--configuration",
				"Release",
				"/property:GenerateFullPaths=true",
				"/consoleloggerparameters:NoSummary"
			],
			"problemMatcher": "$msCompile",
			"dependsOn": "clean"
		},
		{
			"label": "build",
			"command": "dotnet",
			"windows": {
				"command": "${env:ProgramFiles}\\dotnet\\x64\\dotnet.exe"
			},
			"type": "process",
			"args": [
				"build",
				"${workspaceFolder}/PoPunkouterSoftware/PoPunkouterSoftware.csproj",
				"/property:GenerateFullPaths=true",
				"/consoleloggerparameters:NoSummary"
			],
			"problemMatcher": "$msCompile",
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"label": "start-azurite",
			"type": "shell",
			"command": "docker compose up azurite -d",
			"options": { "cwd": "${workspaceFolder}" },
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "silent",
				"focus": false,
				"panel": "shared",
				"close": true
			},
			"problemMatcher": []
		},
		{
			"label": "start-api-server",
			"type": "shell",
			"command": "dotnet watch run --project ${workspaceFolder}/PoPunkouterSoftware/PoPunkouterSoftware.csproj",
			"windows": {
				"command": "\"${env:ProgramFiles}\\dotnet\\x64\\dotnet.exe\" watch run --project ${workspaceFolder}/PoPunkouterSoftware/PoPunkouterSoftware.csproj"
			},
			"group": "build",
			"isBackground": true,
			"dependsOn": ["kill-dotnet", "start-azurite"],
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "dedicated",
				"label": "API Server (watch :8000)"
			},
			"problemMatcher": {
				"pattern": {
					"regexp": "^.*$",
					"file": 1,
					"location": 2,
					"message": 3
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "^.*Now listening on.*$",
					"endsPattern": "^.*Application started.*$"
				}
			}
		},
		{
			"label": "test-unit",
			"command": "dotnet",
			"windows": {
				"command": "${env:ProgramFiles}\\dotnet\\x64\\dotnet.exe"
			},
			"type": "process",
			"args": [
				"test",
				"${workspaceFolder}/tests/PoPunkouterSoftware.Tests.Unit",
				"/property:GenerateFullPaths=true",
				"/consoleloggerparameters:NoSummary"
			],
			"group": {
				"kind": "test",
				"isDefault": true
			},
			"problemMatcher": "$msCompile",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared"
			}
		},
		{
			"label": "test-unit-watch",
			"type": "shell",
			"command": "dotnet watch test --project ${workspaceFolder}/tests/PoPunkouterSoftware.Tests.Unit",
			"windows": {
				"command": "\"${env:ProgramFiles}\\dotnet\\x64\\dotnet.exe\" watch test --project ${workspaceFolder}/tests/PoPunkouterSoftware.Tests.Unit"
			},
			"group": "test",
			"isBackground": true,
			"problemMatcher": "$msCompile",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "dedicated",
				"label": "Tests (watch)"
			}
		}
	]
}
