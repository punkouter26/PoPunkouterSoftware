{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "▶ Run PoPunkouterSoftware (.NET)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "kill-dotnet",
            "program": "${workspaceFolder}/PoPunkouterSoftware/bin/Debug/net10.0/PoPunkouterSoftware.dll",
            "args": [],
            "cwd": "${workspaceFolder}/PoPunkouterSoftware",
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "Now listening on: (https?://\\S+)",
                "uriFormat": "%s"
            },
            "launchBrowser": {
                "enabled": false
            },
            "sourceFileMap": {
                "/Views/": "${workspaceFolder}/"
            }
        },
        {
            "name": "🌐 Start Local Server & Open Website",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/server.js",
            "console": "integratedTerminal",
            "serverReadyAction": {
                "pattern": "Server running at (http://localhost:[0-9]+)",
                "uriFormat": "%s",
                "action": "openExternally"
            }
        },
        {
            "name": "📂 Open Website (File Protocol)",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/open-browser.js",
            "console": "integratedTerminal"
        },
        {
            "name": "🔧 Live Preview (if extension installed)",
            "type": "pwa-chrome",
            "request": "launch",
            "url": "http://localhost:3000",
            "webRoot": "${workspaceFolder}/PoPunkouterSoftware/wwwroot",
            "preLaunchTask": "start-live-server"
        }
    ]
}