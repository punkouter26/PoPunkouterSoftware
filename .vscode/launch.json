{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "🌐 Start Local Server & Open Website",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/server.js",
            "console": "integratedTerminal",
            "serverReadyAction": {
                "pattern": "Server running at (http://localhost:[0-9]+)",
                "uriFormat": "%s",
                "action": "openExternally"
            }
        },
        {
            "name": "📂 Open Website (File Protocol)",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/open-browser.js",
            "console": "integratedTerminal"
        },
        {
            "name": "🔧 Live Preview (if extension installed)",
            "type": "pwa-chrome",
            "request": "launch",
            "url": "http://localhost:3000",
            "webRoot": "${workspaceFolder}/PoPunkouterSoftware/wwwroot",
            "preLaunchTask": "start-live-server"
        }
    ]
}