{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "🌐 Launch Website (Local Server)",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/server.js",
            "console": "integratedTerminal",
            "serverReadyAction": {
                "pattern": "Server running at (http://localhost:[0-9]+)",
                "uriFormat": "%s",
                "action": "openExternally"
            },
            "env": {
                "NODE_ENV": "development"
            }
        },
        {
            "name": "📂 Open Website (Direct File)",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/open-browser.js",
            "console": "integratedTerminal"
        }
    ]
}