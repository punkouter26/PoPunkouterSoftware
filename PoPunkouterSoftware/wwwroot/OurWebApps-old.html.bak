<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Web Apps - Punkouter Software</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <!-- Web Component Header -->
    <site-header></site-header>
    
    <main>
        <section id="apps-intro">
            <h1>Web Apps</h1>
            <p>Explore our collection of innovative web applications designed to solve real-world problems.</p>

            <!-- Sort Controls -->
            <div class="controls-bar">
                <div class="sort-control">
                    <label for="sort-select">Sort by:</label>
                    <select id="sort-select" class="sort-dropdown">
                        <option value="alphabetical">Alphabetical (A-Z)</option>
                        <option value="alphabetical-desc">Alphabetical (Z-A)</option>
                        <option value="status">Status (Active First)</option>
                        <option value="category">Category</option>
                    </select>
                </div>
                <div class="app-count">
                    <span id="app-count-text">Loading apps...</span>
                </div>
            </div>

            <!-- Apps Grid - Dynamically loaded from JSON -->
            <div class="apps-grid">
                <!-- App cards will be loaded here by JavaScript -->
            </div>
        </section>
    </main>
    
    <!-- Web Component Footer -->
    <site-footer></site-footer>
    
    <script type="module" src="/js/main.js"></script>
</body>

</html>
