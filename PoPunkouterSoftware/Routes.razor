<Router AppAssembly="@typeof(Program).Assembly"
        AdditionalAssemblies="@([typeof(PoPunkouterSoftware.Client.Components.Layout.MainLayout).Assembly])">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(PoPunkouterSoftware.Client.Components.Layout.MainLayout)" />
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <PageTitle>Not found</PageTitle>
        <LayoutView Layout="@typeof(PoPunkouterSoftware.Client.Components.Layout.MainLayout)">
            <p role="alert">Sorry, there's nothing at this address.</p>
        </LayoutView>
    </NotFound>
</Router>