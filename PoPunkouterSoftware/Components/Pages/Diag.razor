@page "/diag"
@rendermode InteractiveServer
@using System.Text.Json
@using Radzen
@using Radzen.Blazor
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav

<PageTitle>PoPunkouterSoftware — Diagnostics</PageTitle>

<RadzenText TextStyle="TextStyle.H3" TagName="TagName.H1" class="rz-color-primary rz-mb-2">
    System Diagnostics
</RadzenText>
<RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary rz-mb-4">
    Live status of all external connections. Sensitive values are masked.
</RadzenText>

@if (_loading)
{
    <RadzenProgressBar Value="100" Mode="ProgressBarMode.Indeterminate" class="rz-my-4" />
    <RadzenText>Checking connections&hellip;</RadzenText>
}
else if (_result is not null)
{
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="8px" class="rz-mb-4">
        <RadzenBadge BadgeStyle="@(_result.Status == "healthy" ? BadgeStyle.Success : BadgeStyle.Danger)"
                     Text="@_result.Status.ToUpperInvariant()" />
        <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary">
            Environment: <strong>@_result.Environment</strong> &nbsp;|&nbsp;
            Checked at: <strong>@_result.Timestamp.ToString("yyyy-MM-dd HH:mm:ss") UTC</strong>
        </RadzenText>
        <RadzenButton Text="Refresh" Icon="refresh" ButtonStyle="ButtonStyle.Light"
                      Size="ButtonSize.Small" Click="@LoadAsync" />
    </RadzenStack>

    <RadzenDataGrid Data="@_checks" TItem="CheckRow" AllowSorting="true" AllowPaging="false"
                    class="rz-mb-6">
        <Columns>
            <RadzenDataGridColumn TItem="CheckRow" Property="Name" Title="Service" Width="200px" />
            <RadzenDataGridColumn TItem="CheckRow" Title="Status" Width="130px">
                <Template Context="row">
                    <RadzenBadge BadgeStyle="@(row.Status == "reachable" || row.Status == "healthy" ? BadgeStyle.Success : BadgeStyle.Danger)"
                                 Text="@row.Status.ToUpperInvariant()" />
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="CheckRow" Property="Detail" Title="Detail" />
        </Columns>
    </RadzenDataGrid>

    <!-- Environment / Config section -->
    <RadzenText TextStyle="TextStyle.H5" class="rz-color-primary rz-mb-2">Configuration Values</RadzenText>
    @if (_result.Config is { } cfg)
    {
        <RadzenDataGrid Data="@(cfg.Select(kv => new ConfigRow(kv.Key, kv.Value)).ToList())" TItem="ConfigRow" AllowSorting="true" AllowPaging="false">
            <Columns>
                <RadzenDataGridColumn TItem="ConfigRow" Property="Key" Title="Key" Width="300px" />
                <RadzenDataGridColumn TItem="ConfigRow" Property="Value" Title="Value (masked)" />
            </Columns>
        </RadzenDataGrid>
    }
}
else if (_error is not null)
{
    <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true">@_error</RadzenAlert>
}

@code {
    private bool _loading = true;
    private HealthResult? _result;
    private string? _error;
    private List<CheckRow> _checks = [];

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        _result = null;
        _checks = [];
        StateHasChanged();

        try
        {
            var client = HttpClientFactory.CreateClient();
            var response = await client.GetAsync(Nav.ToAbsoluteUri("/api/health").ToString());
            response.EnsureSuccessStatusCode();
            _result = await response.Content.ReadFromJsonAsync<HealthResult>();

            if (_result?.Checks is not null)
            {
                _checks = _result.Checks
                    .Select(kv =>
                    {
                        var detail = kv.Value.TryGetProperty("error", out var err)
                            ? err.GetString() ?? string.Empty
                            : kv.Value.TryGetProperty("httpStatus", out var code)
                                ? $"HTTP {code}"
                                : string.Empty;
                        var status = kv.Value.TryGetProperty("status", out var s)
                            ? s.GetString() ?? "unknown"
                            : "unknown";
                        return new CheckRow(kv.Key, status, detail);
                    })
                    .ToList();
            }


        }
        catch (Exception ex)
        {
            _error = $"Failed to reach /api/health: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private record CheckRow(string Name, string Status, string Detail);
    private record ConfigRow(string Key, string Value);

    private record HealthResult(
        string Status,
        string Application,
        string Environment,
        DateTime Timestamp,
        Dictionary<string, JsonElement>? Checks,
        Dictionary<string, string>? Config);
}
