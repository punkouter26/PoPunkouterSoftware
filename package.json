{
  "name": "popunkoutersoftware",
  "version": "0.1.0",
  "description": "PoPunkouterSoftware Static Web App",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:unit": "vitest run tests/unit --reporter=dot",
    "test:integration": "vitest run tests/integration --reporter=dot",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --project=chromium --grep @smoke --workers=1",
    "test:e2e:regression": "playwright test --project=chromium --grep @regression --workers=1",
    "test:ci": "npm run test:unit && npm run test:integration && npm run test:e2e:smoke",
    "test:trend": "node scripts/test-trend.js",
    "test:quality-gate": "node scripts/test-quality-gate.js",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report",
    "discover-apps": "node scripts/discover-azure-apps.js",
    "update-apps": "node scripts/update-apps-from-report.js",
    "cleanup-apps": "node scripts/cleanup-apps.js",
    "sync-azure": "npm run discover-apps && npm run cleanup-apps",
    "audit-azure": "node scripts/azure-cost-audit.js",
    "azure-report": "node scripts/azure-full-report.js",
    "spend-detail": "node scripts/azure-spend-detail.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.0",
    "vitest": "^2.1.8"
  }
}
