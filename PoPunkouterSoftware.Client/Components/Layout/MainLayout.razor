@inherits LayoutComponentBase
@inject NavigationManager NavigationManager
@inject HttpClient Http

<RadzenComponents />

@if (_isMockMode)
{
    <div style="background:#b8860b;color:#fff;padding:.2rem .6rem;font-weight:600;font-size:.7rem;position:fixed;top:8px;right:8px;z-index:9999;border-radius:4px;letter-spacing:.04em;">
        ⚠ MOCK DATA
    </div>
}

<RadzenLayout Style="grid-template-areas: 'rz-body';">
    <RadzenBody Style="overflow-y: auto">
        <div class="app-shell-body">
            <DevErrorBoundary>
                @Body
            </DevErrorBoundary>
        </div>
    </RadzenBody>
</RadzenLayout>

@code {
    private bool _isMockMode;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Fetch environment mode from server — shows MOCK DATA banner when server
            // runs in "Testing" environment (integration / E2E test runs). Rule 10.
            var cfg = await Http.GetFromJsonAsync<ConfigResponse>("/api/config");
            _isMockMode = cfg?.IsMockMode ?? false;
        }
        catch
        {
            // Non-fatal — banner stays hidden if the call fails.
        }
    }

    // GoF: Value Object — immutable config response carrier.
    private sealed record ConfigResponse(string ApiBase, bool IsMockMode);
}
