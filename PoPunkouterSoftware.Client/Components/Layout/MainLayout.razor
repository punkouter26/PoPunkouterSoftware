@inherits LayoutComponentBase
@inject NavigationManager NavigationManager

<RadzenComponents />

<RadzenLayout Style="grid-template-areas: 'rz-header' 'rz-body';">
    <RadzenHeader class="app-shell">
        <div class="app-shell-bar">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="12px" Wrap="FlexWrap.Wrap">
                <div class="app-shell-brand">
                    <RadzenImage Path="images/logo.png" />
                    <div>
                        <div class="app-shell-brand-title">Punkouter Software</div>
                        <div class="app-shell-brand-copy">Solo-built Azure apps, live ops, and portfolio telemetry.</div>
                    </div>
                </div>

                <div class="app-shell-nav">
                    <NavLink href="/" Match="NavLinkMatch.All" class="app-shell-link">Home</NavLink>
                    <NavLink href="/azure" class="app-shell-link">Azure</NavLink>
                    <NavLink href="/status" class="app-shell-link">Status</NavLink>
                    <NavLink href="/diag" class="app-shell-link">Diag</NavLink>
                </div>
            </RadzenStack>
        </div>
    </RadzenHeader>

    <RadzenBody Style="overflow-y: auto">
        <div class="app-shell-body">
            <DevErrorBoundary>
                @Body
            </DevErrorBoundary>
        </div>
    </RadzenBody>
</RadzenLayout>

