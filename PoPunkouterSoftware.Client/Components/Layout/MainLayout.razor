@inherits LayoutComponentBase

<RadzenComponents />

<RadzenLayout Style="grid-template-areas: 'rz-header' 'rz-body';">
    <RadzenHeader>
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="10px" class="rz-p-2">
            <RadzenImage Path="images/logo.png" Style="height: 40px; margin-right: 15px;" />
            <RadzenText TextStyle="TextStyle.H6" Style="margin: 0;">Punkouter Software</RadzenText>
            <RadzenStack Orientation="Orientation.Horizontal" Gap="4px" Style="margin-left:auto">
                <RadzenLink Path="/" Text="Home" Style="font-size:.85rem;padding:.25rem .6rem" />
                <RadzenLink Path="/azure" Text="Azure" Style="font-size:.85rem;padding:.25rem .6rem" />
                <RadzenLink Path="/status" Text="Status" Style="font-size:.85rem;padding:.25rem .6rem" />
            </RadzenStack>
        </RadzenStack>
    </RadzenHeader>

    <RadzenBody Style="overflow-y: auto">
        <div class="rz-p-4">
            <DevErrorBoundary>
                @Body
            </DevErrorBoundary>
        </div>
    </RadzenBody>
</RadzenLayout>

