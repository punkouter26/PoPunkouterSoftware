@inherits LayoutComponentBase
@inject NavigationManager NavigationManager
@inject HttpClient Http
@inject PoAppSession AppSession
@inject IJSRuntime JS

<RadzenComponents />

<canvas id="app-bg-canvas"></canvas>

@if (_isMockMode)
{
    <div class="app-mock-data-warning">
        ⚠ MOCK DATA
    </div>
}

<RadzenLayout Style="grid-template-areas: 'rz-header' 'rz-body'; grid-template-rows: auto 1fr;">
    <RadzenHeader>
        <nav class="app-topbar">
            <a href="/" class="app-topbar-brand">PoPunkouterSoftware</a>
            <div class="app-topbar-nav">
                <a href="/" class="app-topbar-link @NavClass("/")">
                    <span class="material-symbols-outlined">home</span>Portfolio
                </a>
                <a href="/azure" class="app-topbar-link @NavClass("/azure")">
                    <span class="material-symbols-outlined">cloud</span>Azure
                </a>
            </div>
            <div class="app-topbar-session">
                @if (_session?.IsAuthenticated == true)
                {
                    <span class="app-topbar-session-pill">
                        @_session.DisplayName @(_session.IsGuest ? "LOGGED IN" : _session.Status)
                        <button class="app-session-btn-logout" @onclick="LogoutAsync" title="Log Out">
                            <span class="material-symbols-outlined">logout</span>
                        </button>
                    </span>
                }
                else if (_guestLoginEnabled)
                {
                    <RadzenButton Text="Guest Login" Icon="login" ButtonStyle="ButtonStyle.Secondary"
                                  Size="ButtonSize.Small" Click="LoginAsGuestAsync" />
                }
            </div>
        </nav>
    </RadzenHeader>
    <RadzenBody>
        <div class="app-shell-body">
            <DevErrorBoundary>
                @Body
            </DevErrorBoundary>
        </div>
    </RadzenBody>
</RadzenLayout>

@code {
    private bool _isMockMode;
    private bool _guestLoginEnabled;
    private PoUserSession? _session;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Fetch environment mode from server — shows MOCK DATA banner when server
            // runs in "Testing" environment (integration / E2E test runs). Rule 10.
            var cfg = await Http.GetFromJsonAsync<ConfigResponse>("/api/config");
            _isMockMode = cfg?.IsMockMode ?? false;
            _guestLoginEnabled = cfg?.GuestLoginEnabled ?? false;
        }
        catch
        {
            // Non-fatal — banner stays hidden if the call fails.
        }

        try
        {
            _session = await AppSession.GetAsync();
        }
        catch
        {
            // Non-fatal — session pill stays hidden if browser storage is unavailable.
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initBackgroundCanvas");
            await JS.InvokeVoidAsync("initNavbarScroll");
        }
    }

    private async Task LoginAsGuestAsync()
    {
        var session = new PoUserSession(
            LoginMode: "Guest",
            DisplayName: "Guest User",
            Email: "guest@punkouter.local",
            IsGuest: true,
            IsAuthenticated: true,
            Status: "Active"
        );
        await AppSession.SaveAsync(session);
        _session = session;
        StateHasChanged();
    }

    private async Task LogoutAsync()
    {
        await AppSession.ClearAsync();
        _session = null;
        StateHasChanged();
    }

    private string NavClass(string href)
    {
        var current = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        if (href == "/")
            return current == "" || current == "/" ? "active" : "";
        return current.StartsWith(href.TrimStart('/'), StringComparison.OrdinalIgnoreCase) ? "active" : "";
    }

    // GoF: Value Object — immutable config response carrier.
    private sealed record ConfigResponse(string ApiBase, bool IsMockMode, bool GuestLoginEnabled);
}
