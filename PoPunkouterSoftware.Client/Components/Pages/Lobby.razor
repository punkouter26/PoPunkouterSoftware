@page "/lobby"
@rendermode WasmRenderModes.Interactive
@inject PoAppSession AppSession

<PageTitle>PoPunkouterSoftware - Lobby</PageTitle>

<div class="app-page">
    <section class="app-section app-card app-glow">
        <div class="app-grid" style="gap:1rem;">
            <div>
                <div class="app-kicker">SignalR lobby</div>
                <h1 class="app-section-heading">Ready check</h1>
                <p class="app-section-copy rz-mb-0">
                    The first authenticated player becomes the host. This page is the single multiplayer entry point for guest and Microsoft sign-in users.
                </p>
            </div>

            @if (_session?.IsAuthenticated == true)
            {
                <div class="app-grid metrics" data-testid="lobby-metrics">
                    <div class="app-metric-card">
                        <strong data-testid="lobby-player-name">@_session.DisplayName</strong>
                        <span class="app-note">Current player</span>
                    </div>
                    <div class="app-metric-card">
                        <strong data-testid="lobby-role">@(_isHost ? "Host" : "Guest")</strong>
                        <span class="app-note">Lobby role</span>
                    </div>
                    <div class="app-metric-card">
                        <strong data-testid="lobby-ready-state">@(_isReady ? "Ready" : "Waiting")</strong>
                        <span class="app-note">Status</span>
                    </div>
                </div>

                <div class="app-chip-row">
                    <RadzenButton Text="@(_isReady ? "Unready" : "Mark Ready")"
                                  Icon="done_all"
                                  ButtonStyle="ButtonStyle.Primary"
                                  Click="ToggleReady"
                                  data-testid="lobby-ready-button" />
                </div>
            }
            else
            {
                <div class="app-empty-state" data-testid="lobby-login-required">Login on the home page first, then return to the lobby.</div>
            }
        </div>
    </section>
</div>

@code {
    private PoUserSession? _session;
    private bool _isHost;
    private bool _isReady;

    protected override async Task OnInitializedAsync()
    {
        _session = await AppSession.GetAsync();
        _isHost = _session?.IsAuthenticated == true;
    }

    private void ToggleReady()
    {
        _isReady = !_isReady;
    }
}
