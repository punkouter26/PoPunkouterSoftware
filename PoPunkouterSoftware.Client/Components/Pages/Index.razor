@page "/"
@rendermode WasmRenderModes.Interactive
@using System.Text.Json
@using System.Text.Json.Serialization
@inject HttpClient Http
@inject NavigationManager NavigationManager

<PageTitle>PoPunkouterSoftware — Home</PageTitle>

<div class="app-page">
    <section class="app-section app-hero app-glow">
        <div class="app-grid" style="align-content:start;gap:1rem;">
            <span class="app-eyebrow">Modern indie software studio</span>
            <h1 class="app-hero-title">Punkouter Software</h1>
            <p class="app-hero-copy">
                A one-person product studio shipping AI-driven apps on Azure with a stronger focus on live operations,
                usable diagnostics, and portfolio quality instead of demo-only surfaces.
            </p>

            <div class="app-actions">
                <RadzenButton Text="Open Azure Command Center" Icon="dashboard" ButtonStyle="ButtonStyle.Primary"
                              Click="@(() => NavigationManager.NavigateTo("/azure"))" />
                <RadzenButton Text="View Live Status" Icon="monitor_heart" ButtonStyle="ButtonStyle.Light" Variant="Variant.Outlined"
                              Click="@(() => NavigationManager.NavigateTo("/status"))" />
            </div>

            <div class="app-grid metrics">
                <div class="app-stat">
                    <span class="app-stat-label">Live portfolio</span>
                    <span class="app-stat-value">@filteredApps.Count</span>
                </div>
                <div class="app-stat">
                    <span class="app-stat-label">Recently shipped</span>
                    <span class="app-stat-value">@CountRecentRepos(30)</span>
                </div>
                <div class="app-stat">
                    <span class="app-stat-label">Avg response time</span>
                    <span class="app-stat-value">@AverageResponseLabel</span>
                </div>
            </div>

            <div class="app-chip-row">
                <RadzenBadge Text="C# / .NET 10" BadgeStyle="BadgeStyle.Info" Variant="Variant.Flat" IsPill="true" />
                <RadzenBadge Text="Blazor + Radzen" BadgeStyle="BadgeStyle.Primary" Variant="Variant.Flat" IsPill="true" />
                <RadzenBadge Text="Azure hosted" BadgeStyle="BadgeStyle.Success" Variant="Variant.Flat" IsPill="true" />
                <RadzenBadge Text="Live diagnostics" BadgeStyle="BadgeStyle.Warning" Variant="Variant.Flat" IsPill="true" />
            </div>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(_narrative))
    {
        <section class="app-section">
            <div class="app-card" style="padding:1.25rem 1.5rem;border-left:4px solid var(--app-accent-strong);">
                <div class="app-kicker" style="margin-bottom:.5rem;">AI Portfolio Snapshot</div>
                <blockquote style="margin:0;font-size:1.05rem;line-height:1.7;font-style:italic;color:var(--rz-text-color);">
                    @_narrative
                </blockquote>
                <p class="app-note" style="margin:.75rem 0 0">Generated by Azure OpenAI · refreshes every 24 h</p>
            </div>
        </section>
    }

    <section id="apps" class="app-section">
        <div class="app-toolbar rz-mb-3">
            <div>
                <div class="app-kicker">Portfolio</div>
                <h2 class="app-section-heading">Web Apps</h2>
                <p class="app-section-copy rz-mb-0">
                    AI-powered tools, productivity utilities, and experiments currently surfaced from the live Azure inventory.
                </p>
            </div>

            <div class="app-grid metrics" style="min-width:min(100%, 520px);">
                <div class="app-metric-card">
                    <strong>@filteredApps.Count</strong>
                    <span class="app-note">Apps currently shown</span>
                </div>
                <div class="app-metric-card">
                    <strong>@CountAppsByStatus("active")</strong>
                    <span class="app-note">Active portfolio items</span>
                </div>
                <div class="app-metric-card">
                    <strong>@CountTrackedRepos()</strong>
                    <span class="app-note">Repos with GitHub activity</span>
                </div>
            </div>
        </div>

        @if (apps == null)
        {
            <div class="app-card">
                <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" class="rz-my-2" />
                <p class="app-note rz-mb-0">Loading portfolio inventory and live telemetry…</p>
            </div>
        }
        else if (filteredApps.Count == 0)
        {
            <div class="app-empty-state">No live apps matched the current inventory and health filters.</div>
        }
        else
        {
            <div class="app-grid cards">
                @foreach (var app in filteredApps)
                {
                    var isActive = app.Status?.ToLower() == "active";
                    var live = GetLiveStatus(app.Url);

                    <RadzenCard class="app-card app-glow" Style="@($"display:flex;flex-direction:column;gap:1rem;border-left:4px solid {(isActive ? "var(--app-accent-strong)" : "var(--app-border-strong)")}")">
                        <div class="app-status-row">
                            <div>
                                <div class="app-kicker">App</div>
                                <h3 class="app-card-title">@app.Name</h3>
                            </div>
                            <RadzenBadge Text="@(app.Status ?? "unknown")" IsPill="true"
                                         BadgeStyle="@(isActive ? BadgeStyle.Success : BadgeStyle.Light)" />
                        </div>

                        @if (live is not null)
                        {
                            <div class="app-chip-row">
                                <RadzenBadge Text="@live.HttpStatus.ToUpper()" IsPill="true"
                                             BadgeStyle="@(live.HttpStatus == "active" ? BadgeStyle.Success : live.HttpStatus == "broken" ? BadgeStyle.Danger : BadgeStyle.Warning)" />
                                @if (!string.IsNullOrEmpty(live.PlatformState))
                                {
                                    <RadzenBadge Text="@live.PlatformState" BadgeStyle="BadgeStyle.Info" Variant="Variant.Flat" IsPill="true" />
                                }
                                @if ((live.Connectivity?.ResponseTime ?? 0) > 0)
                                {
                                    var rt = live.Connectivity!.ResponseTime;
                                    <RadzenBadge Text="@($"{rt} ms")" BadgeStyle="@(rt < 1000 ? BadgeStyle.Success : BadgeStyle.Warning)" Variant="Variant.Flat" IsPill="true" />
                                }
                            </div>
                        }

                        <p class="app-card-copy rz-mb-0">@app.Description</p>

                        @if (app.Technologies?.Any() == true)
                        {
                            <div class="app-chip-row">
                                @foreach (var tech in app.Technologies)
                                {
                                    <RadzenBadge Text="@tech" BadgeStyle="BadgeStyle.Light" Variant="Variant.Flat" IsPill="true" />
                                }
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(app.GithubRepo) && _ghActivity.TryGetValue(app.GithubRepo, out var gh))
                        {
                            <div class="app-card app-surface-soft" style="padding:.85rem;box-shadow:none;">
                                <div class="app-kicker">GitHub activity</div>
                                <div class="app-status-row">
                                    <a class="app-inline-link" href="@($"https://github.com/{app.GithubRepo}")" target="_blank" rel="noopener noreferrer">
                                        @app.GithubRepo
                                    </a>
                                    @if (gh.LastCommitDate.HasValue)
                                    {
                                        var daysAgo = (int)(DateTime.UtcNow - gh.LastCommitDate.Value).TotalDays;
                                        var label = daysAgo == 0 ? "today" : daysAgo == 1 ? "1d ago" : $"{daysAgo}d ago";
                                        <span class="app-note" title="Last commit @gh.LastCommitDate.Value.ToString("yyyy-MM-dd")">Last commit: @label</span>
                                    }
                                    else
                                    {
                                        <span class="app-note">No commits found</span>
                                    }
                                </div>

                                <div class="app-status-row rz-mt-1">
                                    @if (gh.WeeklyCommits?.Length > 0)
                                    {
                                        <svg class="app-mini-chart" width="56" height="16" viewBox="0 0 56 16" title="8-week commit activity">
                                            @{ var max = gh.WeeklyCommits.Max(); }
                                            @for (int wi = 0; wi < gh.WeeklyCommits.Length; wi++)
                                            {
                                                var h = max > 0 ? (int)(gh.WeeklyCommits[wi] * 14.0 / max) : 0;
                                                var x = wi * 7;
                                                var y = 14 - h;
                                                <rect x="@x" y="@y" width="5" height="@(h + 1)"
                                                      fill="@(gh.WeeklyCommits[wi] > 0 ? "var(--app-accent-strong)" : "rgba(255,255,255,0.16)")"
                                                      rx="1" />
                                            }
                                        </svg>
                                    }
                                    @if (gh.HealthScore > 0)
                                    {
                                        var scoreStyle = gh.HealthScore >= 70 ? BadgeStyle.Success : gh.HealthScore >= 40 ? BadgeStyle.Warning : BadgeStyle.Danger;
                                        <RadzenBadge Text="@($"Health {gh.HealthScore}/100")" IsPill="true"
                                                     BadgeStyle="@scoreStyle" Variant="Variant.Flat"
                                                     title="Score: commit recency + activity + README + description + license" />
                                    }
                                </div>
                            </div>
                        }

                        <div class="app-actions">
                            <RadzenButton Text="Open App" Icon="open_in_new" Size="ButtonSize.Small"
                                          ButtonStyle="ButtonStyle.Primary"
                                          Disabled="@(string.IsNullOrEmpty(app.Url))"
                                          Click="@(() => OpenApp(app.Url))" />
                            <RadzenButton Text="Azure View" Icon="dashboard" Size="ButtonSize.Small"
                                          ButtonStyle="ButtonStyle.Light" Variant="Variant.Outlined"
                                          Click="@(() => NavigationManager.NavigateTo("/azure"))" />
                        </div>
                    </RadzenCard>
                }
            </div>
        }
    </section>

    <section id="about" class="app-section">
        <div class="app-kicker">Founder</div>
        <h2 class="app-section-heading">About</h2>
        <div class="app-card">
            <div class="app-profile">
                <RadzenImage Path="images/MATT2.png" />
                <div class="app-grid" style="gap:.8rem;">
                    <div>
                        <h3 class="app-card-title rz-mb-1">Matt</h3>
                        <div class="app-section-copy">Founder, solo developer, and operator of the portfolio.</div>
                    </div>

                    <p class="app-card-copy rz-mb-0">
                        Full-stack developer building indie software apps on Azure with a bias toward clear UX,
                        pragmatic telemetry, and productized internal tooling rather than one-off demos.
                    </p>

                    <div class="app-chip-row">
                        @foreach (var skill in new[] { "C#", ".NET 10", "Blazor", "Azure", "AI / ML", "TypeScript", "Node.js" })
                        {
                            <RadzenBadge Text="@skill" BadgeStyle="BadgeStyle.Info" Variant="Variant.Flat" IsPill="true" />
                        }
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

@code {
    // ── Apps ─────────────────────────────────────────────────────────
    private IEnumerable<AppModel>? apps;
    private List<AppModel> filteredApps = new();
    // GoF: Dictionary used as a simple cache (Flyweight-adjacent) for live status lookups by URL.
    private Dictionary<string, WebService> _liveByUrl = new(StringComparer.OrdinalIgnoreCase);
    private Dictionary<string, GitHubActivity> _ghActivity = new(StringComparer.OrdinalIgnoreCase);
    private string? _narrative;

    protected override async Task OnInitializedAsync()
    {
        await ReloadAppsAsync();
        await Task.WhenAll(LoadLiveStatusAsync(), LoadGitHubActivityAsync(), LoadNarrativeAsync());
    }

    // Reads apps.json as a static file served from wwwroot — no server file system access needed in WASM.
    private async Task ReloadAppsAsync()
    {
        try
        {
            var opts = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var wrapper = await Http.GetFromJsonAsync<AppsWrapper>("data/apps.json", opts);
            apps = wrapper?.Apps ?? new List<AppModel>();
            ApplyDefaultSort();
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
            apps = new List<AppModel>();
            filteredApps.Clear();
        }
    }

    // Reads the cached azure-full-report.json static file and builds a live-status lookup.
    private async Task LoadLiveStatusAsync()
    {
        try
        {
            var opts = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var report = await Http.GetFromJsonAsync<AzureReport>("data/azure-full-report.json", opts);
            var services = report?.WebServices?.Services ?? new List<WebService>();
            _liveByUrl = services
                .Where(s => !string.IsNullOrEmpty(s.Url))
                .ToDictionary(s => s.Url!, StringComparer.OrdinalIgnoreCase);
            // Re-filter now that we have live connectivity data
            ApplyDefaultSort();
            await InvokeAsync(StateHasChanged);
        }
        catch { /* non-fatal — live status is optional */ }
    }

    // Fetches GitHub activity for apps that declare a githubRepo field.
    private async Task LoadGitHubActivityAsync()
    {
        var repos = filteredApps
            .Where(a => !string.IsNullOrEmpty(a.GithubRepo))
            .Select(a => a.GithubRepo!)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        foreach (var repo in repos)
        {
            try
            {
                var opts = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                var gh = await Http.GetFromJsonAsync<GitHubActivity>($"/api/github-activity?repo={Uri.EscapeDataString(repo)}", opts);
                if (gh is not null)
                    _ghActivity[repo] = gh;
            }
            catch { /* non-fatal */ }
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadNarrativeAsync()
    {
        try
        {
            var opts = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var resp = await Http.GetFromJsonAsync<NarrativeDto>("/api/narrative", opts);
            if (resp is not null && !string.IsNullOrWhiteSpace(resp.Narrative) && resp.Disabled != true)
                _narrative = resp.Narrative;
        }
        catch { /* non-fatal */ }

        await InvokeAsync(StateHasChanged);
    }

    private record NarrativeDto(
        [property: JsonPropertyName("narrative")] string? Narrative,
        [property: JsonPropertyName("disabled")] bool? Disabled);

    private WebService? GetLiveStatus(string? url)
    {
        if (string.IsNullOrEmpty(url) || _liveByUrl.Count == 0) return null;
        if (_liveByUrl.TryGetValue(url, out var hit)) return hit;
        // Fuzzy match by hostname when exact URL differs
        if (Uri.TryCreate(url, UriKind.Absolute, out var uri))
        {
            var host = uri.Host;
            return _liveByUrl.Values.FirstOrDefault(s =>
                Uri.TryCreate(s.Url, UriKind.Absolute, out var su) &&
                su.Host.Equals(host, StringComparison.OrdinalIgnoreCase));
        }
        return null;
    }

    private void ApplyDefaultSort()
    {
        var statusRank = (AppModel a) => a.Status?.ToLower() switch { "active" => 0, "inactive" => 1, _ => 2 };

        filteredApps = (apps ?? Enumerable.Empty<AppModel>())
            .Where(a =>
            {
                // Before live data arrives show everything; once loaded, keep only working apps
                if (_liveByUrl.Count == 0) return true;
                var live = GetLiveStatus(a.Url);
                if (live is null) return false;                               // not in Azure
                if (live.HttpStatus != "active") return false;                // broken / stopped
                if (live.Connectivity?.IsAzureErrorPage == true) return false; // Azure placeholder
                return true;
            })
            // Deduplicate by name — keep the entry with the best status (active wins)
            .GroupBy(a => a.Name, StringComparer.OrdinalIgnoreCase)
            .Select(g => g.OrderBy(statusRank).First())
            .OrderBy(a => statusRank(a))
            .ThenBy(a => a.Name)
            .ToList();
    }

    private void OpenApp(string url)
    {
        if (!string.IsNullOrWhiteSpace(url))
            NavigationManager.NavigateTo(url, forceLoad: true);
    }

    private int CountRecentRepos(int days) =>
        _ghActivity.Values.Count(gh => gh.LastCommitDate is DateTime lastCommit && (DateTime.UtcNow - lastCommit).TotalDays <= days);

    private int CountTrackedRepos() =>
        filteredApps.Count(a => !string.IsNullOrWhiteSpace(a.GithubRepo) && _ghActivity.ContainsKey(a.GithubRepo));

    private int CountAppsByStatus(string status) =>
        filteredApps.Count(a => string.Equals(a.Status, status, StringComparison.OrdinalIgnoreCase));

    private string AverageResponseLabel
    {
        get
        {
            var responseTimes = filteredApps
                .Select(a => GetLiveStatus(a.Url)?.Connectivity?.ResponseTime)
                .Where(rt => rt is > 0)
                .Select(rt => rt!.Value)
                .ToList();

            if (responseTimes.Count == 0)
                return "—";

            return $"{responseTimes.Average():F0} ms";
        }
    }

    // ── Local models ─────────────────────────────────────────────────
    private class AppsWrapper { public List<AppModel> Apps { get; set; } = new(); }

    public class AppModel
    {
        public string Name { get; set; } = "";
        public string Status { get; set; } = "";
        public string Description { get; set; } = "";
        public string Url { get; set; } = "";
        public List<string>? Technologies { get; set; }
        public string? GithubRepo { get; set; }
    }

    private record GitHubActivity(
        [property: JsonPropertyName("lastCommitDate")] DateTime? LastCommitDate,
        [property: JsonPropertyName("weeklyCommits")] int[]? WeeklyCommits,
        [property: JsonPropertyName("healthScore")] int HealthScore);
}
