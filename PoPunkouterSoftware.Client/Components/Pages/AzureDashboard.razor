                                    @if (r.Error is null)
                                    {
                                        <span>@r.DeploymentMethod</span>
                                    }
                                </Template>
                            </RadzenDataGridColumn>

                            <RadzenDataGridColumn TItem="InfraReview" Title="CI/CD Files" Width="100px" Sortable="false" Filterable="false">
                                <Template Context="r">
                                    @if (r.CiCdFiles.Count > 0)
                                    {
                                        <RadzenBadge Text="@r.CiCdFiles.Count.ToString()" BadgeStyle="BadgeStyle.Primary" IsPill="true" />
                                        <span class="app-meta-line">workflows</span>
                                    }
                                    else { <span class="app-dash">none</span> }
                                </Template>
                            </RadzenDataGridColumn>

                            <RadzenDataGridColumn TItem="InfraReview" Title="Triggers" Width="150px" Sortable="false" Filterable="false">
                                <Template Context="r">
                                    <div class="app-badge-cluster">
                                    @foreach (var t in r.CiCdFiles.SelectMany(c => c.Triggers).Distinct())
                                    {
                                        <RadzenBadge Text="@t" BadgeStyle="@TriggerBadge(t)" IsPill="true" class="app-badge-2xs" />
                                    }
                                    </div>
                                </Template>
                            </RadzenDataGridColumn>

                            <RadzenDataGridColumn TItem="InfraReview" Title="Infra Files" Width="130px" Sortable="false" Filterable="false">
                                <Template Context="r">
                                    <div class="app-badge-cluster">
                                    @foreach (var f in r.InfraFiles)
                                    {
                                        <RadzenBadge Text="@f.FileType.ToUpper()" BadgeStyle="@InfraFileBadge(f.FileType)" IsPill="true" class="app-badge-2xs" title="@f.FileName" />
                                    }
                                    @if (!r.InfraFiles.Any())
                                    { <span class="app-dash">none</span> }
                                    </div>
                                </Template>
                            </RadzenDataGridColumn>

                            <RadzenDataGridColumn TItem="InfraReview" Title="Bicep Resources" Sortable="false" Filterable="false">
                                <Template Context="r">
                                    @{
                                        var types = r.InfraFiles
                                            .Where(f => f.FileType == "bicep")
                                            .SelectMany(f => f.ResourceTypes)
                                            .Distinct()
                                            .ToList();
