@page "/admin"
@page "/azure"
@page "/timebased"
@rendermode WasmRenderModes.Interactive
@using System.Text.Json
@using System.Text.Json.Serialization
@using Microsoft.AspNetCore.SignalR.Client
@using PoPunkouterSoftware.Shared.Azure
@implements IAsyncDisposable
@inject HttpClient Http
@inject IJSRuntime JS
@inject NotificationService NotificationService
@inject NavigationManager NavManager

<PageTitle>Po Software — Admin Dashboard</PageTitle>

<div class="app-page">

@if (_loading)
{
    <div class="app-card">
        <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" class="rz-my-3" />
        <p class="app-note rz-mb-0">Loading Azure report…</p>
    </div>
}
else if (!string.IsNullOrWhiteSpace(_loadError))
{
    <RadzenAlert AlertStyle="AlertStyle.Warning" Variant="Variant.Outlined" ShowIcon="true" class="rz-my-4">
        <div><strong>Azure dashboard load failed.</strong></div>
        <div style="margin-top:.35rem">@_loadError</div>
        <div style="margin-top:.75rem">
            <RadzenButton Text="Retry" Icon="refresh" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small" Click="@(async () => await LoadReportAsync())" />
        </div>
    </RadzenAlert>
}
else
{
    var currentReport = report ?? new AzureReport();
    var active   = currentReport.WebServices?.ByStatus?.Active ?? 0;
    var broken   = currentReport.WebServices?.ByStatus?.Broken ?? 0;
    var total    = currentReport.WebServices?.Total ?? 0;
    var healthPct = total > 0 ? (int)(active * 100.0 / total) : 100;
    var ageMin   = currentReport.GeneratedAt is DateTime genDt
                   ? (int)(DateTime.UtcNow - genDt).TotalMinutes : -1;
    var ageLabel = ageMin < 0 ? "" : ageMin < 60 ? $"{ageMin}m old" : ageMin < 1440 ? $"{ageMin / 60}h {ageMin % 60}m old" : $"{ageMin / 1440}d {ageMin % 1440 / 60}h old";
    var _secInsecureCount = (currentReport.StorageInventory ?? new()).Count(s => s.PublicBlobAccess || !s.HttpsOnly || s.MinTls is "TLS1_0" or "TLS1_1");
    var _criticalDriftCount = (currentReport.ConfigDrift ?? new()).Count(d => d.Issues?.Any(i => i.Severity is "critical" or "high") == true);

    <!-- ── Header banner ── -->
    <section class="app-section">
        <div class="app-banner @(broken > 0 ? "critical" : "healthy")">
            <div class="app-toolbar">
                <div>
                    <div class="app-kicker">Azure · @(currentReport.Subscription?.Name ?? "—")</div>
                    <h2 class="app-card-title">@(broken > 0 ? $"{broken} service(s) need attention" : "All systems operational")</h2>
                    <p class="app-note rz-mb-0">
                        Generated: @(currentReport.GeneratedAt?.ToString("yyyy-MM-dd HH:mm") ?? "—") UTC
                    </p>
                </div>
                <div class="app-actions">
                    @if (ageMin >= 0)
                    {
                        var ageBadge = ageMin < 30 ? BadgeStyle.Success : ageMin < 120 ? BadgeStyle.Info : ageMin < 360 ? BadgeStyle.Warning : BadgeStyle.Danger;
                        <RadzenBadge Text="@ageLabel" BadgeStyle="@ageBadge" IsPill="true" />
                    }
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="6px">
                        <RadzenButton Text="@(_refreshing ? "Refreshing…" : "Refresh from Azure")" Icon="refresh"
                                      ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small"
                                      Disabled="@_refreshing" Click="RefreshAsync" />                        <RadzenButton Text="Download JSON" Icon="download" ButtonStyle="ButtonStyle.Light"
                                      Variant="Variant.Outlined" Size="ButtonSize.Small"
                                      Disabled="@(report == null)" Click="DownloadReportAsync"
                                      title="Download the full Azure report as JSON for sharing with AI tools or debugging" />                        @if (_refreshing)
                        {
                            <RadzenButton Text="Cancel" Icon="close" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small"
                                          Click="CancelRefreshAsync" />
                        }
                    </RadzenStack>
                </div>
            </div>
        </div>
    </section>

    @if (_refreshing)
    {
        <section class="app-section">
            <RadzenProgressBar Value="@_progressPercent" Max="100" ShowValue="true" class="rz-mb-1" Style="height:22px" />
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="6px" class="rz-mb-2">
                <RadzenIcon Icon="sync" Style="font-size:1rem;animation:spin 1.4s linear infinite" />
                <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary">@_progressStep</RadzenText>
            </RadzenStack>
        </section>
    }

    @* Fix 3: Age badge in header is sufficient. Stale banner removed. *@

    @* Fix 4: Security alert surfaced near top, outside tabs *@
    @if (_secInsecureCount > 0 || _criticalDriftCount > 0)
    {
        <section class="app-section">
            <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Outlined" ShowIcon="true" class="rz-my-2">
                @if (_secInsecureCount > 0)
                {
                    <span><strong>Security:</strong> @_secInsecureCount storage account(s) have misconfigurations (public blobs / TLS / HTTPS). </span>
                }
                @if (_criticalDriftCount > 0)
                {
                    <span><strong>Config:</strong> @_criticalDriftCount service(s) have high/critical severity drift. </span>
                }
                <span class="app-note">Details in the Overview tab below.</span>
            </RadzenAlert>
        </section>
    }

    <RadzenTabs>
        <Tabs>
            <RadzenTabsItem Text="Overview">

    <!-- ── KPI Strip ── -->
    <section class="app-section">
        <div class="app-dashboard-summary">
            <div class="app-metric-card"><strong>@active / @total</strong><span class="app-note">Operational</span></div>
            <div class="app-metric-card"><strong>@(currentReport.Cost?.TotalFormatted ?? "$0.00")</strong><span class="app-note">30-day cost</span></div>
            <div class="app-metric-card"><strong>@((currentReport.OrphanedResources?.Count ?? 0) + (currentReport.ZombieApps?.Count ?? 0))</strong><span class="app-note">Waste candidates</span></div>
            <div class="app-metric-card"><strong>@(currentReport.AllResourceSummary?.Total ?? 0)</strong><span class="app-note">Total resources</span></div>
        </div>
    </section>

    <!-- ── Viz 1 + 2 : Fleet Health & Cost Breakdown ── -->
    <section class="app-section">
        <RadzenRow Gap="1rem">
            <!-- Viz 1: Fleet Health Donut -->
            <RadzenColumn SizeXS="12" SizeMD="4">
                <div class="app-card" style="height:100%">
                    <div class="app-kicker">Fleet Health</div>
                    <h3 class="app-card-title rz-mb-1">Service Status Overview</h3>
                    <p class="app-note rz-mb-2">Active / Broken / Other across all @total web services.</p>
                    <div style="position:relative">
                        <RadzenChart Style="height:230px">
                            <RadzenDonutSeries TItem="ChartPoint" Data="@FleetHealthDonutData"
                                               CategoryProperty="Label" ValueProperty="Value" InnerRadius="75" />
                            <RadzenLegend Position="LegendPosition.Bottom" />
                        </RadzenChart>
                        <div style="position:absolute;top:38%;left:50%;transform:translateX(-50%);text-align:center;pointer-events:none">
                            <div style="font-size:2rem;font-weight:700;line-height:1;color:@(healthPct >= 80 ? "var(--rz-success)" : healthPct >= 50 ? "var(--rz-warning)" : "var(--rz-danger)")">@healthPct%</div>
                            <div style="font-size:.72rem;opacity:.65;margin-top:.15rem">healthy</div>
                        </div>
                    </div>
                </div>
            </RadzenColumn>

            <!-- Viz 2: Cost Breakdown Bar Chart -->
            <RadzenColumn SizeXS="12" SizeMD="8">
                <div class="app-card" style="height:100%">
                    <div class="app-kicker">Cost Breakdown</div>
                    <h3 class="app-card-title rz-mb-1">Top Cost Drivers — 30 Days</h3>
                    <p class="app-note rz-mb-2">
                        Spend by Azure service / resource group. Total: <strong>@(currentReport.Cost?.TotalFormatted ?? "—")</strong>
                        @if (!string.IsNullOrEmpty(currentReport.Cost?.Note)) { <span class="app-tone-warning"> · @currentReport.Cost.Note</span> }
                    </p>
                    @if (CostDriversBarData.Count == 0)
                    {
                        <div class="app-callout info">No cost data — run Refresh from Azure to fetch billing data.</div>
                    }
                    else
                    {
                        <RadzenChart Style="height:230px">
                            <RadzenBarSeries TItem="ChartPoint" Data="@CostDriversBarData"
                                             CategoryProperty="Label" ValueProperty="Value" Title="USD" />
                            <RadzenValueAxis FormatString="${0:F2}"><RadzenGridLines Visible="true" /></RadzenValueAxis>
                            <RadzenCategoryAxis />
                            <RadzenLegend Visible="false" />
                        </RadzenChart>
                    }
                </div>
            </RadzenColumn>
        </RadzenRow>
    </section>

    <!-- ── Viz 4 + 5 : Response Times & Error Rate ── -->
    <section class="app-section">
        <RadzenRow Gap="1rem">
            <!-- Viz 4: App Response Time Distribution -->
            <RadzenColumn SizeXS="12" SizeMD="6">
                <div class="app-card" style="height:100%">
                    <div class="app-kicker">Performance</div>
                    <h3 class="app-card-title rz-mb-1">App Response Times</h3>
                    <p class="app-note rz-mb-2">Probe response time (ms), slowest first. &lt;1 000ms good · &gt;3 000ms critical.</p>
                    @if (ResponseTimeBarData.Count == 0)
                    {
                        <div class="app-callout info">No response time data — services may not yet have been probed.</div>
                    }
                    else
                    {
                        <RadzenChart Style="height:260px">
                            <RadzenBarSeries TItem="ChartPoint" Data="@ResponseTimeBarData"
                                             CategoryProperty="Label" ValueProperty="Value" Title="ms" />
                            <RadzenValueAxis FormatString="{0}ms"><RadzenGridLines Visible="true" /></RadzenValueAxis>
                            <RadzenLegend Visible="false" />
                        </RadzenChart>
                    }
                </div>
            </RadzenColumn>

            <!-- Viz 5: 7-Day Error Rate -->
            <RadzenColumn SizeXS="12" SizeMD="6">
                <div class="app-card" style="height:100%">
                    <div class="app-kicker">Reliability</div>
                    <h3 class="app-card-title rz-mb-1">7-Day 5xx Error Counts</h3>
                    <p class="app-note rz-mb-2">HTTP 5xx server errors per app over the past 7 days. Zero is ideal.</p>
                    @if (ErrorRateBarData.Count == 0)
                    {
                        <div class="app-callout success">No 5xx errors recorded in the last 7 days across all services.</div>
                    }
                    else
                    {
                        <RadzenChart Style="height:260px">
                            <RadzenBarSeries TItem="ChartPoint" Data="@ErrorRateBarData"
                                             CategoryProperty="Label" ValueProperty="Value" Title="5xx errors" />
                            <RadzenValueAxis><RadzenGridLines Visible="true" /></RadzenValueAxis>
                            <RadzenLegend Visible="false" />
                        </RadzenChart>
                    }
                </div>
            </RadzenColumn>
        </RadzenRow>
    </section>

    <!-- ── Viz 6 + 7 : Resource Inventory & Waste ── -->
    <section class="app-section">
        <RadzenRow Gap="1rem">
            <!-- Viz 6: Resource Inventory Donut + Drill-down -->
            <RadzenColumn SizeXS="12" SizeMD="6">
                <div class="app-card" style="height:100%">
                    <div class="app-kicker">Inventory</div>
                    <h3 class="app-card-title rz-mb-1">Resource Inventory by Type</h3>
                    <p class="app-note rz-mb-2">
                        @(currentReport.AllResourceSummary?.Total ?? 0) resources across
                        @(currentReport.AllResourceSummary?.ByType.Count ?? 0) types. Click a row to inspect.
                    </p>
                    <RadzenRow>
                        <RadzenColumn SizeXS="12" SizeMD="6">
                            <RadzenChart Style="height:230px">
                                <RadzenDonutSeries TItem="ChartPoint" Data="@ResourceTypeChartData"
                                                   CategoryProperty="Label" ValueProperty="Value" InnerRadius="50" />
                                <RadzenLegend Visible="false" />
                            </RadzenChart>
                        </RadzenColumn>
                        <RadzenColumn SizeXS="12" SizeMD="6">
                            <div class="app-table-frame" style="max-height:230px;overflow-y:auto">
                                <RadzenDataGrid Data="@ResourceTypeTableData" TItem="ChartPoint"
                                                AllowSorting="true" AllowPaging="false"
                                                RowClick="@(args => SelectResourceType(args.Data?.Label ?? ""))">
                                    <Columns>
                                        <RadzenDataGridColumn TItem="ChartPoint" Property="Label" Title="Type">
                                            <Template Context="p">
                                                <span class="@(_selectedResourceType == p.Label ? "app-row-link" : "")">@p.Label</span>
                                            </Template>
                                        </RadzenDataGridColumn>
                                        <RadzenDataGridColumn TItem="ChartPoint" Property="Value" Title="#" Width="55px" TextAlign="TextAlign.Right">
                                            <Template Context="p"><strong>@((int)p.Value)</strong></Template>
                                        </RadzenDataGridColumn>
                                    </Columns>
                                </RadzenDataGrid>
                            </div>
                        </RadzenColumn>
                    </RadzenRow>
                    @if (_selectedResourceType is not null && _selectedResourceDetails is not null)
                    {
                        <div class="app-detail-panel soft rz-mt-2">
                            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="8px" class="rz-mb-2">
                                <RadzenText TextStyle="TextStyle.H6" class="rz-m-0">@_selectedResourceType</RadzenText>
                                <RadzenBadge Text="@_selectedResourceDetails.Count.ToString()" BadgeStyle="BadgeStyle.Info" IsPill="true" />
                                <RadzenButton Icon="close" Size="ButtonSize.ExtraSmall" Variant="Variant.Text"
                                              Click="@(() => { _selectedResourceType = null; _selectedResourceDetails = null; })" />
                            </RadzenStack>
                            <RadzenDataGrid Data="@_selectedResourceDetails" TItem="ResourceDetail"
                                            AllowSorting="true" PageSize="8" AllowPaging="true">
                                <Columns>
                                    <RadzenDataGridColumn TItem="ResourceDetail" Property="Name" Title="Name" />
                                    <RadzenDataGridColumn TItem="ResourceDetail" Property="Location" Title="Location" Width="120px" />
                                    <RadzenDataGridColumn TItem="ResourceDetail" Property="Sku" Title="SKU" Width="90px" />
                                </Columns>
                            </RadzenDataGrid>
                        </div>
                    }
                </div>
            </RadzenColumn>

            <!-- Viz 7: Zombie & Orphaned Savings -->
            <RadzenColumn SizeXS="12" SizeMD="6">
                <div class="app-card" style="height:100%">
                    <div class="app-kicker">Waste</div>
                    <h3 class="app-card-title rz-mb-1">Zombie Apps &amp; Orphaned Resources</h3>
                    <p class="app-note rz-mb-2">Zero-traffic broken apps and unattached resources with estimated monthly cost.</p>
                    @{
                        var zombies  = currentReport.ZombieApps        ?? new();
                        var orphaned = currentReport.OrphanedResources  ?? new();
                        double totalWaste = 0;
                        foreach (var _o in orphaned.Where(x => x.EstimatedMonthlyCost != null))
                        {
                            if (double.TryParse(_o.EstimatedMonthlyCost!.Replace("$", ""), out var _c))
                                totalWaste += _c;
                        }
                    }
                    @if (zombies.Count == 0 && orphaned.Count == 0)
                    {
                        <div class="app-callout success">No zombie apps or orphaned resources detected.</div>
                    }
                    else
                    {
                        <div class="app-dashboard-summary rz-mb-3" style="grid-template-columns:repeat(auto-fit,minmax(110px,1fr))">
                            <div class="app-metric-card"><strong>@zombies.Count</strong><span class="app-note">Zombie apps</span></div>
                            <div class="app-metric-card"><strong>@orphaned.Count</strong><span class="app-note">Orphaned</span></div>
                            @if (totalWaste > 0)
                            {
                                <div class="app-metric-card"><strong class="app-tone-warning">~$@totalWaste.ToString("F2")/mo</strong><span class="app-note">Est. waste</span></div>
                            }
                        </div>
                        @if (zombies.Count > 0)
                        {
                            <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-mb-1">Zombie Apps</RadzenText>
                            <div class="app-table-frame" style="max-height:180px;overflow-y:auto;margin-bottom:.75rem">
                                <RadzenDataGrid Data="@zombies" TItem="ZombieApp" AllowPaging="false" AllowSorting="true">
                                    <Columns>
                                        <RadzenDataGridColumn TItem="ZombieApp" Property="Name" Title="App" />
                                        <RadzenDataGridColumn TItem="ZombieApp" Property="HttpStatus" Title="Status" Width="90px">
                                            <Template Context="z">
                                                <RadzenBadge Text="@z.HttpStatus" IsPill="true" BadgeStyle="@HttpBadgeStyle(z.HttpStatus)" />
                                            </Template>
                                        </RadzenDataGridColumn>
                                        <RadzenDataGridColumn TItem="ZombieApp" Property="Recommendation" Title="Action" />
                                    </Columns>
                                </RadzenDataGrid>
                            </div>
                        }
                        @if (orphaned.Count > 0)
                        {
                            <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-mb-1">Orphaned Resources</RadzenText>
                            <div class="app-table-frame" style="max-height:180px;overflow-y:auto">
                                <RadzenDataGrid Data="@orphaned" TItem="OrphanedResource" AllowPaging="false" AllowSorting="true">
                                    <Columns>
                                        <RadzenDataGridColumn TItem="OrphanedResource" Property="Name" Title="Name" />
                                        <RadzenDataGridColumn TItem="OrphanedResource" Property="Type" Title="Type" Width="110px">
                                            <Template Context="o">
                                                <RadzenBadge Text="@o.Type" BadgeStyle="BadgeStyle.Info" IsPill="true" class="app-badge-xs" />
                                            </Template>
                                        </RadzenDataGridColumn>
                                        <RadzenDataGridColumn TItem="OrphanedResource" Property="EstimatedMonthlyCost" Title="Est. Cost" Width="100px">
                                            <Template Context="o">
                                                @if (!string.IsNullOrEmpty(o.EstimatedMonthlyCost))
                                                {
                                                    <span class="app-tone-warning">@o.EstimatedMonthlyCost</span>
                                                }
                                                else
                                                {
                                                    <span class="app-dash">—</span>
                                                }
                                            </Template>
                                        </RadzenDataGridColumn>
                                    </Columns>
                                </RadzenDataGrid>
                            </div>
                        }
                    }
                </div>
            </RadzenColumn>
        </RadzenRow>
    </section>

    <!-- ── Viz 8 + 9 : Config Drift & Storage Security ── -->
    <section class="app-section">
        <RadzenRow Gap="1rem">
            <!-- Viz 8: Config Drift Severity Matrix -->
            <RadzenColumn SizeXS="12" SizeMD="6">
                <div class="app-card" style="height:100%">
                    <div class="app-kicker">Compliance</div>
                    <h3 class="app-card-title rz-mb-1">Config Drift</h3>
                    <p class="app-note rz-mb-2">Services with misconfigurations, ranked by issue count and severity.</p>
                    @{
                        var driftItems   = currentReport.ConfigDrift ?? new();
                        var criticalDrift = driftItems.Count(d => d.Issues?.Any(i => i.Severity is "critical" or "high") == true);
                    }
                    @if (driftItems.Count == 0)
                    {
                        <div class="app-callout success">No configuration drift detected across all services.</div>
                    }
                    else
                    {
                        @if (criticalDrift > 0)
                        {
                            <div class="app-callout danger rz-mb-2"><strong>@criticalDrift service(s)</strong> have high/critical severity issues.</div>
                        }
                        <div class="app-table-frame" style="max-height:340px;overflow-y:auto">
                            <RadzenDataGrid Data="@driftItems.OrderByDescending(d => d.IssueCount).ToList()"
                                            TItem="ConfigDriftItem" AllowSorting="true" AllowPaging="false">
                                <Columns>
                                    <RadzenDataGridColumn TItem="ConfigDriftItem" Property="FriendlyName" Title="Service" Width="160px">
                                        <Template Context="d"><strong>@(d.FriendlyName ?? d.Name)</strong></Template>
                                    </RadzenDataGridColumn>
                                    <RadzenDataGridColumn TItem="ConfigDriftItem" Property="IssueCount" Title="Issues" Width="75px" TextAlign="TextAlign.Center">
                                        <Template Context="d">
                                            <RadzenBadge Text="@d.IssueCount.ToString()" IsPill="true"
                                                         BadgeStyle="@(d.IssueCount > 3 ? BadgeStyle.Danger : d.IssueCount > 1 ? BadgeStyle.Warning : BadgeStyle.Info)" />
                                        </Template>
                                    </RadzenDataGridColumn>
                                    <RadzenDataGridColumn TItem="ConfigDriftItem" Title="Severities" Sortable="false">
                                        <Template Context="d">
                                            <div class="app-badge-cluster">
                                                @foreach (var issue in d.Issues?.Take(3) ?? Enumerable.Empty<ConfigIssue>())
                                                {
                                                    <RadzenBadge Text="@issue.Severity" IsPill="true" class="app-badge-xs"
                                                                 BadgeStyle="@(issue.Severity is "critical" or "high" ? BadgeStyle.Danger : issue.Severity == "medium" ? BadgeStyle.Warning : BadgeStyle.Info)" />
                                                }
                                            </div>
                                        </Template>
                                    </RadzenDataGridColumn>
                                    <RadzenDataGridColumn TItem="ConfigDriftItem" Title="Top Issue" Sortable="false">
                                        <Template Context="d">
                                            <span class="app-meta-line">@(d.Issues?.FirstOrDefault()?.Issue ?? "—")</span>
                                        </Template>
                                    </RadzenDataGridColumn>
                                </Columns>
                            </RadzenDataGrid>
                        </div>
                    }
                </div>
            </RadzenColumn>

            <!-- Viz 9: Storage Security Scorecard -->
            <RadzenColumn SizeXS="12" SizeMD="6">
                <div class="app-card" style="height:100%">
                    <div class="app-kicker">Security</div>
                    <h3 class="app-card-title rz-mb-1">Storage Security Scorecard</h3>
                    <p class="app-note rz-mb-2">Pass/fail per account: public blob access, HTTPS-only, and minimum TLS version.</p>
                    @{
                        var storageItems  = currentReport.StorageInventory ?? new();
                        var insecureCount = storageItems.Count(s => s.PublicBlobAccess || !s.HttpsOnly || s.MinTls is "TLS1_0" or "TLS1_1");
                    }
                    @if (storageItems.Count == 0)
                    {
                        <div class="app-callout info">No storage accounts found in the report.</div>
                    }
                    else
                    {
                        @if (insecureCount > 0)
                        {
                            <div class="app-callout warning rz-mb-2"><strong>@insecureCount account(s)</strong> have security misconfigurations.</div>
                        }
                        else
                        {
                            <div class="app-callout success rz-mb-2">All @storageItems.Count storage accounts pass security checks.</div>
                        }
                        <div class="app-table-frame" style="max-height:310px;overflow-y:auto">
                            <RadzenDataGrid Data="@storageItems.OrderByDescending(s => s.IssueCount).ToList()"
                                            TItem="StorageItem" AllowSorting="true" AllowPaging="false">
                                <Columns>
                                    <RadzenDataGridColumn TItem="StorageItem" Property="Name" Title="Account" Width="150px" />
                                    <RadzenDataGridColumn TItem="StorageItem" Title="Public Blobs" Width="105px" TextAlign="TextAlign.Center">
                                        <Template Context="s">@(s.PublicBlobAccess ? "🔴" : "🟢")</Template>
                                    </RadzenDataGridColumn>
                                    <RadzenDataGridColumn TItem="StorageItem" Title="HTTPS" Width="70px" TextAlign="TextAlign.Center">
                                        <Template Context="s">@(s.HttpsOnly ? "🟢" : "🔴")</Template>
                                    </RadzenDataGridColumn>
                                    <RadzenDataGridColumn TItem="StorageItem" Property="MinTls" Title="Min TLS" Width="90px" TextAlign="TextAlign.Center">
                                        <Template Context="s">
                                            <RadzenBadge Text="@(s.MinTls ?? "?")" IsPill="true"
                                                         BadgeStyle="@(s.MinTls is "TLS1_0" or "TLS1_1" ? BadgeStyle.Danger : BadgeStyle.Success)" />
                                        </Template>
                                    </RadzenDataGridColumn>
                                    <RadzenDataGridColumn TItem="StorageItem" Property="Sku" Title="SKU" Width="100px" />
                                </Columns>
                            </RadzenDataGrid>
                        </div>
                    }
                </div>
            </RadzenColumn>
        </RadzenRow>
    </section>

    <!-- ── Viz 10 : Free Tier Savings Opportunities ── -->
    <section class="app-section">
        <div class="app-card">
            <div class="app-kicker">Savings</div>
            <h3 class="app-card-title rz-mb-1">Free Tier Savings Opportunities</h3>
            <p class="app-note rz-mb-2">
                Services on paid tiers that can migrate to Free tier.
                Already on free: <strong>@(currentReport.FreeTier?.OnFree.Count ?? 0)</strong> services.
            </p>
            @{
                var canGoFreeItems = currentReport.FreeTier?.CanGoFree ?? new();
            }
            @if (canGoFreeItems.Count == 0)
            {
                <div class="app-callout success">No additional services identified as candidates for the Free tier.</div>
            }
            else
            {
                <div class="app-callout warning rz-mb-3"><strong>@canGoFreeItems.Count service(s)</strong> can be scaled to Free tier to reduce costs.</div>
                <RadzenRow>
                    @foreach (var item in canGoFreeItems)
                    {
                        <RadzenColumn SizeXS="12" SizeMD="6" SizeLG="4" class="rz-mb-2">
                            <div class="app-card" style="border-left:3px solid var(--rz-warning);padding:.75rem 1rem">
                                <strong>@item.Label</strong>
                                <div class="app-note rz-my-1">
                                    <RadzenBadge Text="@item.CurrentSku" BadgeStyle="BadgeStyle.Warning" IsPill="true" />
                                    <span style="margin:0 .4rem">→</span>
                                    <RadzenBadge Text="@(item.FreeSku ?? "Free")" BadgeStyle="BadgeStyle.Success" IsPill="true" />
                                </div>
                                @if (!string.IsNullOrEmpty(item.Recommendation)) { <div class="app-meta-line">@item.Recommendation</div> }
                                @if (!string.IsNullOrEmpty(item.ResourceGroup))   { <div class="app-meta-line">RG: @item.ResourceGroup</div> }
