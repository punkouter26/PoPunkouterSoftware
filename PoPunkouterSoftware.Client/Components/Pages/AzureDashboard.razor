@page "/azure"
@rendermode WasmRenderModes.Interactive
@using System.Text.Json
@using System.Text.Json.Serialization
@inject HttpClient Http
@inject IJSRuntime JS
@inject NotificationService NotificationService

<PageTitle>PoPunkouterSoftware — Azure Dashboard</PageTitle>

<RadzenText TextStyle="TextStyle.H3" TagName="TagName.H1" class="rz-color-primary rz-mb-2">Azure Dashboard</RadzenText>

@if (_loading)
{
    <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" class="rz-my-4" />
    <RadzenText TextStyle="TextStyle.Body1">Loading Azure report...</RadzenText>
}
else if (!string.IsNullOrWhiteSpace(_loadError))
{
    <RadzenAlert AlertStyle="AlertStyle.Warning" Variant="Variant.Outlined" ShowIcon="true" class="rz-my-4">
        <div><strong>Azure dashboard load failed.</strong></div>
        <div style="margin-top:.35rem">@_loadError</div>
        <div style="margin-top:.75rem">
            <RadzenButton Text="Retry" Icon="refresh" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small" Click="@(async () => await LoadReportAsync())" />
        </div>
    </RadzenAlert>
}
else
{
    var currentReport = report ?? new AzureReport();

    <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary rz-mb-2">
        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center" Wrap="FlexWrap.Wrap" Gap="8px">
            <span>Subscription: <strong>@currentReport.Subscription?.Name</strong> &nbsp;|&nbsp; Generated: <strong>@(currentReport.GeneratedAt?.ToString("yyyy-MM-dd HH:mm") ?? "—")</strong>
            @if (currentReport.GeneratedAt is DateTime generatedAt && (DateTime.UtcNow - generatedAt).TotalHours > 24)
            {
                <RadzenBadge Text="@($"Data is {(int)(DateTime.UtcNow - generatedAt).TotalHours}h old — refresh recommended")"
                             BadgeStyle="BadgeStyle.Warning" IsPill="true" Style="margin-left:.5rem;font-size:.7rem" />
            }
            </span>
            <RadzenButton Text="@(_refreshing ? "Refreshing…" : "Refresh from Azure")" Icon="refresh"
                          ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small"
                          Disabled="@_refreshing" Click="RefreshAsync" />
        </RadzenStack>
    </RadzenText>
    @if (_refreshing)
    {
        <RadzenProgressBar Value="@_progressPercent" Max="100" ShowValue="true" class="rz-mb-1" Style="height:22px" />
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="6px" class="rz-mb-2">
            <RadzenIcon Icon="sync" Style="font-size:1rem;animation:spin 1.4s linear infinite" />
            <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary">@_progressStep</RadzenText>
        </RadzenStack>
        @if (_progressLog.Count > 0)
        {
            <div style="max-height:140px;overflow-y:auto;background:rgba(0,0,0,.35);border-radius:6px;padding:.5rem .75rem;font-family:monospace;font-size:.72rem;line-height:1.6;color:var(--rz-text-secondary-color);margin-bottom:1rem">
                @foreach (var line in _progressLog)
                {
                    <div>@line</div>
                }
            </div>
        }
    }

    <!-- ── Summary Strip ── -->
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:.75rem;margin-bottom:1.75rem">
        @SummaryCard(currentReport.WebServices?.Total.ToString() ?? "0", "Services", "var(--rz-info)")
        @SummaryCard(currentReport.WebServices?.ByStatus?.Active.ToString() ?? "0", "Active", "var(--rz-success)")
        @SummaryCardLink(currentReport.WebServices?.ByStatus?.Broken.ToString() ?? "0", "Broken ↗", currentReport.WebServices?.ByStatus?.Broken > 0 ? "var(--rz-danger)" : "var(--rz-secondary)", () => _selectedTabIndex = 0)
        @SummaryCard(currentReport.Cost?.TotalFormatted ?? "$0.00", "30-Day Cost", "var(--rz-warning)")
        @SummaryCardLink(safeToRemove.Count.ToString(), "Safe to Remove ↗", safeToRemove.Count > 0 ? "var(--rz-danger)" : "var(--rz-success)", () => _selectedTabIndex = 1)
    </div>

    <RadzenTabs @bind-SelectedIndex="_selectedTabIndex">
        <Tabs>

            <!-- ── Tab 1: Web Services ── -->
            <RadzenTabsItem Text="@($"🌐 Web Services ({currentReport.WebServices?.Total ?? 0})")">
                <div style="overflow-x:auto">
                <RadzenDataGrid Data="@SortedServices" TItem="WebService" AllowFiltering="true" AllowSorting="true"
                                AllowPaging="true" PageSize="15" ShowPagingSummary="true" AllowColumnResize="true" FilterMode="FilterMode.Simple">
                    <Columns>
                        <RadzenDataGridColumn TItem="WebService" Property="FriendlyName" Title="Name" Width="160px">
                            <Template Context="s">
                                <strong>@(string.IsNullOrEmpty(s.FriendlyName) ? s.Name : s.FriendlyName)</strong>
                                <br /><small style="color:var(--rz-text-secondary-color)">@s.ResourceGroup</small>
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="WebService" Property="ResourceType" Title="Type" Width="130px">
                            <Template Context="s">
                                <RadzenBadge Text="@TypeLabel(s.ResourceType)" BadgeStyle="BadgeStyle.Info" IsPill="true" Style="font-size:.7rem" />
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="WebService" Property="Url" Title="URL" Width="220px">
                            <Template Context="s">
                                @if (!string.IsNullOrEmpty(s.Url))
                                {
                                    <a href="@s.Url" target="_blank" rel="noopener noreferrer"
                                       style="color:var(--rz-link-color);word-break:break-all;font-size:.8rem">@s.Url</a>
                                }
                                else { <span style="color:var(--rz-text-secondary-color)">—</span> }
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="WebService" Property="HttpStatus" Title="HTTP" Width="110px">
                            <Template Context="s">
                                <RadzenBadge Text="@s.HttpStatus" IsPill="true"
                                             BadgeStyle="@HttpBadgeStyle(s.HttpStatus)" />
                                @if (s.Connectivity?.IsAzureErrorPage == true)
                                { <RadzenBadge Text="AZ-page" BadgeStyle="BadgeStyle.Danger" IsPill="true" Style="font-size:.65rem;margin-left:2px" /> }
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="WebService" Property="PlatformState" Title="Platform" Width="100px">
                            <Template Context="s">
                                <RadzenBadge Text="@(s.PlatformState ?? "—")" IsPill="true"
                                             BadgeStyle="@(s.PlatformState=="Running" ? BadgeStyle.Success : BadgeStyle.Warning)" />
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="WebService" Title="7d Req" Width="80px">
                            <Template Context="s">
                                @if (s.Metrics7Days?.Requests == 0)
                                { <span style="color:var(--rz-warning-color)">0 ⚠</span> }
                                else { @(s.Metrics7Days?.Requests.ToString() ?? "—") }
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="WebService" Title="7d 5xx" Width="75px">
                            <Template Context="s">
                                @if (s.Metrics7Days?.Http5xx > 0)
                                { <span style="color:var(--rz-danger-color);font-weight:700">@s.Metrics7Days.Http5xx</span> }
                                else { @(s.Metrics7Days != null ? "0" : "—") }
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="WebService" Title="RT ms" Width="80px">
                            <Template Context="s">
                                @if (s.Connectivity?.Success == true)
                                {
                                    var rtColor = s.Connectivity.ResponseTime < 1000
                                        ? "var(--rz-success-color)"
                                        : s.Connectivity.ResponseTime < 3000
                                            ? "var(--rz-warning-color)"
                                            : "var(--rz-danger-color)";
                                    <span style="color:@rtColor" title="@s.Connectivity.ResponseTime ms">@s.Connectivity.ResponseTime ms</span>
                                }
                                else if (s.Connectivity?.Error != null && (s.Connectivity.Error.Contains("canceled") || s.Connectivity.Error.Contains("Timeout") || s.Connectivity.Error.Contains("timed out")))
                                { <RadzenBadge Text="Timeout" BadgeStyle="BadgeStyle.Danger" IsPill="true" Style="font-size:.7rem" /> }
                                else if (s.Connectivity?.Error != null)
                                { <span style="color:var(--rz-danger-color);font-size:.75rem" title="@s.Connectivity.Error">Err ⚠</span> }
                                else { <span style="color:var(--rz-text-secondary-color)">—</span> }
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="WebService" Title="Free Tier" Width="120px">
                            <Template Context="s">
                                @if (s.FreeTierCheck?.IsOnFreeTier == true)
                                { <RadzenBadge Text="Free ✓" BadgeStyle="BadgeStyle.Success" IsPill="true" Style="font-size:.7rem" /> }
                                else if (s.FreeTierCheck?.CanGoFree == true)
                                { <RadzenBadge Text="Can go free" BadgeStyle="BadgeStyle.Warning" IsPill="true" Style="font-size:.7rem" /> }
                                else
                                { <RadzenBadge Text="Paid" BadgeStyle="BadgeStyle.Light" IsPill="true" Style="font-size:.7rem" /> }
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
                </div>
            </RadzenTabsItem>

            <!-- ── Tab 2: Safe to Remove ── -->
            <RadzenTabsItem Text="@($"🗑 Safe to Remove ({safeToRemove.Count})")">
                <div class="rz-mt-2">
                @if (!safeToRemove.Any())
                {
                    <div style="background:rgba(50,255,167,.08);border:1px solid rgba(50,255,167,.3);border-radius:6px;padding:.7rem 1rem;color:var(--rz-success-color)">
                        ✅ No resources flagged as safe to remove. Your subscription looks clean.
                    </div>
                }
                else
                {
                    <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary rz-mb-3">
                        Resources identified as unused or cost-waste. Verify before running any commands.
                    </RadzenText>
                    <RadzenDataGrid Data="@safeToRemove" TItem="SafeToRemoveItem" AllowSorting="true" AllowPaging="true" PageSize="15">
                        <Columns>
                            <RadzenDataGridColumn TItem="SafeToRemoveItem" Property="Name" Title="Resource" Width="200px" />
                            <RadzenDataGridColumn TItem="SafeToRemoveItem" Property="Confidence" Title="Confidence" Width="110px">
                                <Template Context="i">
                                    <RadzenBadge Text="@i.Confidence.ToUpper()" IsPill="true"
                                                 BadgeStyle="@(i.Confidence=="high" ? BadgeStyle.Danger : i.Confidence=="medium" ? BadgeStyle.Warning : BadgeStyle.Light)" />
                                </Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="SafeToRemoveItem" Property="Source" Title="Source" Width="160px">
                                <Template Context="i"><small style="color:var(--rz-text-secondary-color)">@i.Source</small></Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="SafeToRemoveItem" Property="Reason" Title="Reason" />
                            <RadzenDataGridColumn TItem="SafeToRemoveItem" Property="Saving" Title="Saving" Width="110px">
                                <Template Context="i">
                                    @if (!string.IsNullOrEmpty(i.Saving))
                                    { <span style="color:var(--rz-success-color)">💰 @i.Saving</span> }
                                </Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="SafeToRemoveItem" Property="Command" Title="CLI Command" Sortable="false">
                                <Template Context="i">
                                    @if (!string.IsNullOrEmpty(i.Command))
                                    {
                                        <RadzenButton Text="Copy" Icon="content_copy" Size="ButtonSize.ExtraSmall" Variant="Variant.Outlined"
                                                      Click="@(() => CopyToClipboard(i.Command))" />
                                        <br /><small style="font-family:monospace;font-size:.7rem;color:var(--rz-info-color)">@i.Command[..Math.Min(60,i.Command.Length)]@(i.Command.Length>60?"…":"")</small>
                                    }
                                    else { <span style="color:var(--rz-text-secondary-color);font-size:.75rem">Check Azure Portal</span> }
                                </Template>
                            </RadzenDataGridColumn>
                        </Columns>
                    </RadzenDataGrid>
                }
                </div>
            </RadzenTabsItem>

            <!-- ── Tab 3: Cost ── -->
            <RadzenTabsItem Text="@($"💳 Cost ({currentReport.Cost?.TotalFormatted ?? "$0"})")">
                <div class="rz-mt-2">
                @if (currentReport.Cost?.Note != null)
                {
                    <div style="background:rgba(255,214,0,.08);border:1px solid rgba(255,214,0,.3);border-radius:6px;padding:.7rem 1rem;color:#ffd700;margin-bottom:1rem">
                        📝 @currentReport.Cost.Note
                    </div>
                }
                @if (currentReport.BurnRate?.DailyCosts.Count > 0)
                {
                    <RadzenRow class="rz-mb-4">
                        <RadzenColumn SizeXS="12" SizeMD="7">
                            <RadzenText TextStyle="TextStyle.H6" class="rz-mb-1">
                                Monthly Burn Rate
                                <RadzenBadge Text="@($"Projected: {currentReport.BurnRate?.ProjectedFormatted ?? "—"}")" BadgeStyle="BadgeStyle.Warning" IsPill="true" Style="font-size:.75rem;margin-left:.5rem" />
                            </RadzenText>
                            <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary rz-mb-1">Based on daily spend this calendar month only — not rolling 30d</RadzenText>
                            <RadzenChart Style="height:280px">
                                <RadzenLineSeries TItem="DailyCostChartPoint" Data="@BurnRateChartData" CategoryProperty="Date" ValueProperty="Cost" Title="Daily ($)" Smooth="true">
                                    <RadzenMarkers MarkerType="MarkerType.Circle" Size="4" />
                                </RadzenLineSeries>
                                <RadzenCategoryAxis Step="@BurnRateLabelStep" />
                                <RadzenValueAxis FormatString="${0:F2}">
                                    <RadzenGridLines Visible="true" />
                                </RadzenValueAxis>
                                <RadzenLegend Visible="false" />
                            </RadzenChart>
                        </RadzenColumn>
                        <RadzenColumn SizeXS="12" SizeMD="5">
                            <RadzenText TextStyle="TextStyle.H6" class="rz-mb-1">Cost by Resource Group (30d)</RadzenText>
                            <RadzenChart Style="height:260px">
                                <RadzenBarSeries TItem="ChartPoint" Data="@CostByRgData" CategoryProperty="Label" ValueProperty="Value" Title="Cost ($)">
                                    <RadzenSeriesDataLabels Visible="false" />
                                </RadzenBarSeries>
                                <RadzenValueAxis FormatString="${0:F2}">
                                    <RadzenGridLines Visible="true" />
                                </RadzenValueAxis>
                                <RadzenLegend Visible="false" />
                            </RadzenChart>
                        </RadzenColumn>
                    </RadzenRow>
                }
                <RadzenDataGrid Data="@currentReport.Cost?.TopCostDrivers" TItem="CostDriver" AllowSorting="true" PageSize="30" AllowPaging="false">
                    <Columns>
                        <RadzenDataGridColumn TItem="CostDriver" Property="Name" Title="Service / Resource Group" />
                        <RadzenDataGridColumn TItem="CostDriver" Property="Cost" Title="Cost (USD)" Width="130px" TextAlign="TextAlign.Right">
                            <Template Context="d">
                                <span style="color:@(d.Cost > 0 ? "#ffd700" : "var(--rz-text-secondary-color)");font-weight:600">
                                    $@d.Cost.ToString("F2")
                                </span>
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
                <RadzenCard class="rz-mt-3" Style="text-align:right">
                    <RadzenText TextStyle="TextStyle.H6">Total: <span style="color:#ffd700">@(currentReport.Cost?.TotalFormatted ?? "—")</span></RadzenText>
                </RadzenCard>
                </div>
            </RadzenTabsItem>

            <!-- ── SSL Expiry Tab ── -->
            <RadzenTabsItem Text="@($"🔒 SSL ({currentReport.SslExpiry?.Count ?? 0})")">
                <div class="rz-mt-2">
                @{
                    var sslCritical  = currentReport.SslExpiry?.Count(x => x.DaysLeft is { } d && d < 14) ?? 0;
                    var sslWarning   = currentReport.SslExpiry?.Count(x => x.DaysLeft is { } d && d is >= 14 and < 60) ?? 0;
                    var sslErrored   = currentReport.SslExpiry?.Count(x => x.Error != null && x.DaysLeft == null) ?? 0;
                    var sslOk        = currentReport.SslExpiry?.Count(x => x.DaysLeft != null) ?? 0;
                }
                @if (sslErrored > 0 && sslOk == 0)
                {
                    <div style="background:rgba(255,214,0,.08);border:1px solid rgba(255,214,0,.3);border-radius:6px;padding:.7rem 1rem;color:#ffd700;margin-bottom:1rem">
                        ⚠️ SSL checks ran but all <strong>@sslErrored</strong> entries returned errors. Hit <strong>Refresh from Azure</strong> to re-check.
                    </div>
                }
                else if (sslCritical > 0)
                {
                    <div style="background:rgba(255,50,50,.1);border:1px solid rgba(255,50,50,.4);border-radius:6px;padding:.7rem 1rem;color:var(--rz-danger-color);margin-bottom:1rem">
                        ⚠️ <strong>@sslCritical certificate(s)</strong> expire in fewer than 14 days — renew immediately!
                    </div>
                }
                else if (sslWarning > 0)
                {
                    <div style="background:rgba(255,214,0,.08);border:1px solid rgba(255,214,0,.3);border-radius:6px;padding:.7rem 1rem;color:#ffd700;margin-bottom:1rem">
                        🟡 @sslWarning certificate(s) expire within 60 days — schedule renewal soon.
                    </div>
                }
                <RadzenDataGrid Data="@currentReport.SslExpiry" TItem="SslEntry" AllowSorting="true" AllowFiltering="true"
                                FilterMode="FilterMode.Simple" AllowPaging="true" PageSize="20">
                    <Columns>
                        <RadzenDataGridColumn TItem="SslEntry" Property="Name" Title="Service" Width="180px" />
                        <RadzenDataGridColumn TItem="SslEntry" Property="Url" Title="URL" Width="230px">
                            <Template Context="s">
                                @if (!string.IsNullOrEmpty(s.Url))
                                { <a href="@s.Url" target="_blank" rel="noopener noreferrer" style="font-size:.8rem;word-break:break-all;color:var(--rz-link-color)">@s.Url</a> }
                                else { <span style="color:var(--rz-text-secondary-color)">—</span> }
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="SslEntry" Property="DaysLeft" Title="Days Left" Width="110px">
                            <Template Context="s">
                                @if (s.DaysLeft is { } d)
                                {
                                    <RadzenBadge Text="@($"{d}d")" IsPill="true"
                                                 BadgeStyle="@(d < 14 ? BadgeStyle.Danger : d < 60 ? BadgeStyle.Warning : BadgeStyle.Success)" />
                                }
                                else if (!string.IsNullOrEmpty(s.Error))
                                { <RadzenBadge Text="Error" BadgeStyle="BadgeStyle.Warning" IsPill="true" Style="font-size:.7rem" /> }
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="SslEntry" Property="Error" Title="Error" Width="160px">
                            <Template Context="s">
                                @if (!string.IsNullOrEmpty(s.Error))
                                { <span style="color:var(--rz-warning-color);font-size:.78rem" title="@s.Error">@(s.Error.Length > 40 ? s.Error.Substring(0, 40) + "…" : s.Error)</span> }
                                else { <span style="color:var(--rz-text-secondary-color)">—</span> }
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="SslEntry" Property="Expiry" Title="Expires" Width="115px" />
                        <RadzenDataGridColumn TItem="SslEntry" Property="Subject" Title="Subject">
                            <Template Context="s">
                                @if (s.Subject?.Contains("*.azurewebsites.net") == true || s.Subject?.Contains("*.azurefd.net") == true || s.Subject?.Contains("*.trafficmanager.net") == true)
                                { <RadzenBadge Text="Azure Managed" BadgeStyle="BadgeStyle.Light" IsPill="true" Style="font-size:.65rem;opacity:.6" /> }
                                else { <span style="font-size:.78rem">@(s.Subject ?? "—")</span> }
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
                </div>
            </RadzenTabsItem>

            <!-- ── App Insights Tab ── -->
            <RadzenTabsItem Text="@($"📊 App Insights ({currentReport.AppInsightsMetrics?.Count ?? 0})")">
                <div class="rz-mt-2">
                @if (currentReport.AppInsightsMetrics?.Any() != true)
                {
                    <div style="background:rgba(100,180,255,.07);border:1px solid rgba(100,180,255,.25);border-radius:6px;padding:.75rem 1rem;color:var(--rz-text-secondary-color)">
                        ℹ️ No Application Insights components found, or metrics could not be retrieved.
                    </div>
                }
                else
                {
                    <RadzenDataGrid Data="@currentReport.AppInsightsMetrics" TItem="AppInsightsMetric"
                                    AllowSorting="true" AllowFiltering="true" FilterMode="FilterMode.Simple"
                                    AllowPaging="true" PageSize="20">
                        <Columns>
                            <RadzenDataGridColumn TItem="AppInsightsMetric" Property="Name" Title="Component" Width="210px" />
                            <RadzenDataGridColumn TItem="AppInsightsMetric" Property="ResourceGroup" Title="Resource Group" Width="160px" />
                            <RadzenDataGridColumn TItem="AppInsightsMetric" Property="Requests7Days" Title="7d Requests" Width="120px" TextAlign="TextAlign.Right">
                                <Template Context="m">
                                    @if (m.Requests7Days == 0) { <span style="color:var(--rz-warning-color)">0 ⚠</span> }
                                    else { <span>@(m.Requests7Days?.ToString() ?? "—")</span> }
                                </Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="AppInsightsMetric" Property="FailedRequests7Days" Title="7d Failed" Width="105px" TextAlign="TextAlign.Right">
                                <Template Context="m">
                                    @if (m.FailedRequests7Days > 0) { <span style="color:var(--rz-danger-color);font-weight:700">@m.FailedRequests7Days</span> }
                                    else { <span style="color:var(--rz-success-color)">@(m.FailedRequests7Days?.ToString() ?? "—")</span> }
                                </Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="AppInsightsMetric" Property="Exceptions7Days" Title="7d Exceptions" Width="125px" TextAlign="TextAlign.Right">
                                <Template Context="m">
                                    @if (m.Exceptions7Days > 0) { <span style="color:var(--rz-warning-color)">⚠ @m.Exceptions7Days</span> }
                                    else { <span>@(m.Exceptions7Days?.ToString() ?? "—")</span> }
                                </Template>
                            </RadzenDataGridColumn>
                        </Columns>
                    </RadzenDataGrid>
                }
                </div>
            </RadzenTabsItem>

            <!-- ── Resource Breakdown Tab ── -->
            <RadzenTabsItem Text="@($"📦 Resources ({currentReport.AllResourceSummary?.Total ?? 0})")">
                <div class="rz-mt-2">
                <RadzenRow>
                    <RadzenColumn SizeXS="12" SizeMD="6">
                        <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">Top 10 Resource Types <small style="font-size:.75rem;color:var(--rz-text-secondary-color)">(click a row to drill in)</small></RadzenText>
                        <RadzenChart Style="height:340px">
                            <RadzenDonutSeries TItem="ChartPoint" Data="@ResourceTypeChartData" CategoryProperty="Label" ValueProperty="Value" InnerRadius="70" />
                            <RadzenLegend Position="LegendPosition.Bottom" />
                        </RadzenChart>
                    </RadzenColumn>
                    <RadzenColumn SizeXS="12" SizeMD="6">
                        <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">All Resource Types</RadzenText>
                        <div style="max-height:360px;overflow-y:auto">
                        <RadzenDataGrid Data="@ResourceTypeTableData" TItem="ChartPoint" AllowSorting="true" PageSize="50" AllowPaging="false" RowClick="@(args => SelectResourceType(args.Data?.Label ?? ""))">
                            <Columns>
                                <RadzenDataGridColumn TItem="ChartPoint" Property="Label" Title="Type">
                                    <Template Context="p">
                                        <span style="cursor:pointer;color:@(_selectedResourceType == p.Label ? "var(--rz-primary-color)" : "inherit");font-weight:@(_selectedResourceType == p.Label ? "700" : "normal")">@p.Label</span>
                                    </Template>
                                </RadzenDataGridColumn>
                                <RadzenDataGridColumn TItem="ChartPoint" Property="Value" Title="Count" Width="90px" TextAlign="TextAlign.Right">
                                    <Template Context="p"><strong>@((int)p.Value)</strong></Template>
                                </RadzenDataGridColumn>
                            </Columns>
                        </RadzenDataGrid>
                        </div>
                    </RadzenColumn>
                </RadzenRow>
                @if (_selectedResourceType is not null && _selectedResourceDetails is not null)
                {
                    <div style="margin-top:1.5rem;border-top:1px solid var(--rz-border-disabled-color);padding-top:1rem">
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="12px" class="rz-mb-2">
                            <RadzenText TextStyle="TextStyle.H6" Style="margin:0">
                                🔍 <strong>@_selectedResourceType</strong>
                                <RadzenBadge Text="@_selectedResourceDetails.Count.ToString()" BadgeStyle="BadgeStyle.Info" IsPill="true" Style="margin-left:.5rem;font-size:.75rem" />
                            </RadzenText>
                            <RadzenButton Text="Clear" Icon="close" Size="ButtonSize.ExtraSmall" Variant="Variant.Outlined"
                                          Click="@(() => { _selectedResourceType = null; _selectedResourceDetails = null; })" />
                        </RadzenStack>
                        <RadzenDataGrid Data="@_selectedResourceDetails" TItem="ResourceDetail"
                                        AllowSorting="true" AllowFiltering="true" FilterMode="FilterMode.Simple" AllowPaging="true" PageSize="15">
                            <Columns>
                                <RadzenDataGridColumn TItem="ResourceDetail" Property="Name" Title="Name" Width="230px" />
                                <RadzenDataGridColumn TItem="ResourceDetail" Property="ResourceGroup" Title="Resource Group" Width="180px" />
                                <RadzenDataGridColumn TItem="ResourceDetail" Property="Location" Title="Location" Width="130px" />
                                <RadzenDataGridColumn TItem="ResourceDetail" Property="Sku" Title="SKU" Width="110px">
                                    <Template Context="r">
                                        @if (!string.IsNullOrEmpty(r.Sku))
                                        { <RadzenBadge Text="@r.Sku" BadgeStyle="BadgeStyle.Light" IsPill="true" Style="font-size:.7rem" /> }
                                        else { <span style="color:var(--rz-text-secondary-color)">—</span> }
                                    </Template>
                                </RadzenDataGridColumn>
                            </Columns>
                        </RadzenDataGrid>
                    </div>
                }
                </div>
            </RadzenTabsItem>

            <!-- ── Orphaned Resources Tab ── -->
            <RadzenTabsItem Text="@($"🧟 Orphaned ({currentReport.OrphanedResources?.Count ?? 0})")">
                <div class="rz-mt-2">
                @if (currentReport.OrphanedResources?.Any() != true)
                {
                    <div style="background:rgba(50,255,167,.08);border:1px solid rgba(50,255,167,.3);border-radius:6px;padding:.7rem 1rem;color:var(--rz-success-color)">
                        ✅ No orphaned resources — no unattached disks, idle public IPs, or empty App Service Plans.
                    </div>
                }
                else
                {
                    <RadzenDataGrid Data="@currentReport.OrphanedResources" TItem="OrphanedResource" AllowSorting="true" AllowPaging="true" PageSize="15">
                        <Columns>
                            <RadzenDataGridColumn TItem="OrphanedResource" Property="Name" Title="Resource" Width="200px" />
                            <RadzenDataGridColumn TItem="OrphanedResource" Property="ResourceGroup" Title="Resource Group" Width="160px" />
                            <RadzenDataGridColumn TItem="OrphanedResource" Property="Type" Title="Type" Width="150px">
                                <Template Context="o"><RadzenBadge Text="@o.Type" BadgeStyle="BadgeStyle.Info" IsPill="true" Style="font-size:.7rem" /></Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="OrphanedResource" Property="Reason" Title="Reason" />
                            <RadzenDataGridColumn TItem="OrphanedResource" Property="EstimatedMonthlyCost" Title="Est. Cost/mo" Width="130px">
                                <Template Context="o">
                                    @if (!string.IsNullOrEmpty(o.EstimatedMonthlyCost))
                                    { <span style="color:var(--rz-warning-color)">💰 @o.EstimatedMonthlyCost</span> }
                                </Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="OrphanedResource" Property="Command" Title="CLI Command" Sortable="false">
                                <Template Context="o">
                                    @if (!string.IsNullOrEmpty(o.Command))
                                    {
                                        <RadzenButton Text="Copy" Icon="content_copy" Size="ButtonSize.ExtraSmall" Variant="Variant.Outlined"
                                                      Click="@(() => CopyToClipboard(o.Command!))" />
                                        <br /><small style="font-family:monospace;font-size:.7rem;color:var(--rz-info-color)">@o.Command[..Math.Min(60, o.Command.Length)]@(o.Command.Length > 60 ? "…" : "")</small>
                                    }
                                </Template>
                            </RadzenDataGridColumn>
                        </Columns>
                    </RadzenDataGrid>
                }
                </div>
            </RadzenTabsItem>

            <!-- ── Storage Tab ── -->
            <RadzenTabsItem Text="@($"💾 Storage ({currentReport.StorageInventory?.Count ?? 0})")">
                <div class="rz-mt-2">
                <RadzenDataGrid Data="@currentReport.StorageInventory" TItem="StorageItem" AllowFiltering="true" AllowSorting="true" PageSize="15" AllowPaging="true" FilterMode="FilterMode.Simple">
                    <Columns>
                        <RadzenDataGridColumn TItem="StorageItem" Property="Name" Title="Account" Width="180px" />
                        <RadzenDataGridColumn TItem="StorageItem" Property="ResourceGroup" Title="Resource Group" Width="160px" />
                        <RadzenDataGridColumn TItem="StorageItem" Property="Sku" Title="SKU" Width="120px" />
                        <RadzenDataGridColumn TItem="StorageItem" Property="PublicBlobAccess" Title="Public Blobs" Width="120px">
                            <Template Context="s">
                                <RadzenBadge Text="@(s.PublicBlobAccess ? "Public ⚠" : "Private ✓")" IsPill="true"
                                             BadgeStyle="@(s.PublicBlobAccess ? BadgeStyle.Danger : BadgeStyle.Success)" />
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="StorageItem" Property="HttpsOnly" Title="HTTPS Only" Width="110px">
                            <Template Context="s">
                                <RadzenBadge Text="@(s.HttpsOnly ? "Yes" : "No ⚠")" IsPill="true"
                                             BadgeStyle="@(s.HttpsOnly ? BadgeStyle.Success : BadgeStyle.Danger)" />
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="StorageItem" Property="MinTls" Title="Min TLS" Width="90px" />
                        <RadzenDataGridColumn TItem="StorageItem" Property="IssueCount" Title="Issues" Width="80px">
                            <Template Context="s">
                                <RadzenBadge Text="@s.IssueCount.ToString()" IsPill="true"
                                             BadgeStyle="@(s.IssueCount > 0 ? BadgeStyle.Warning : BadgeStyle.Success)" />
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="StorageItem" Title="Issue Detail">
                            <Template Context="s">
                                @if (s.Issues?.Any() == true)
                                { @foreach (var issue in s.Issues) { <div style="font-size:.78rem;color:var(--rz-warning-color)">@issue.Issue</div> } }
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
                </div>
            </RadzenTabsItem>

        </Tabs>
    </RadzenTabs>
}

@code {
    // SOLID: Single Responsibility — this component only orchestrates the Azure dashboard UI.
    // Data loading is delegated to the server API (/api/diag/report).

    private AzureReport? report;
    private List<WebService> services = new();
    private List<SafeToRemoveItem> safeToRemove = new();
    private int _selectedTabIndex = 0;
    private bool _loading = true;
    private string? _loadError;
    private IEnumerable<WebService> SortedServices =>
        services.OrderBy(s => s.HttpStatus == "active" ? 0 : 1).ThenBy(s => s.FriendlyName ?? s.Name);

    private RenderFragment SummaryCard(string num, string label, string color) => __builder =>
    {
        <RadzenCard Style="@($"text-align:center;border-top:4px solid {color}")">
            <RadzenText TextStyle="TextStyle.H5" Style="@($"color:{color};margin:0")"><strong>@num</strong></RadzenText>
            <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary rz-text-uppercase">@label</RadzenText>
        </RadzenCard>
    };

    private RenderFragment SummaryCardLink(string num, string label, string color, Action onClick) => __builder =>
    {
        <RadzenCard Style="@($"text-align:center;border-top:4px solid {color};cursor:pointer")" @onclick="@(() => onClick())">
            <RadzenText TextStyle="TextStyle.H5" Style="@($"color:{color};margin:0")"><strong>@num</strong></RadzenText>
            <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary rz-text-uppercase">@label</RadzenText>
        </RadzenCard>
    };

    private bool _refreshing;
    private int    _progressPercent;
    private string _progressStep = "";
    private List<string> _progressLog = new();

    protected override async Task OnInitializedAsync() => await LoadReportAsync();

    // Calls /api/diag/report which handles Table Storage + file fallback on the server.
    // No file system access needed in WASM — all data comes via HTTP.
    private async Task LoadReportAsync()
    {
        _loading = true;
        _loadError = null;
        StateHasChanged();

        try
        {
            var opts = new JsonSerializerOptions(JsonSerializerDefaults.Web)
            {
                PropertyNameCaseInsensitive = true
            };

            report = await Http.GetFromJsonAsync<AzureReport>("/api/diag/report", opts);
            if (report is null)
                throw new InvalidOperationException("The Azure report endpoint returned no data.");

            services = report.WebServices?.Services ?? new List<WebService>();
            safeToRemove = BuildSafeToRemove(report);
        }
        catch (Exception ex)
        {
            report = null;
            services = new List<WebService>();
            safeToRemove = new List<SafeToRemoveItem>();
            _loadError = ex.Message;
            Console.Error.WriteLine($"Azure dashboard load error: {ex}");
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task RefreshAsync()
    {
        _refreshing      = true;
        _progressPercent = 0;
        _progressStep    = "Starting…";
        _progressLog     = new();
        report           = null;
        StateHasChanged();

        try
        {
            // POST is fire-and-forget on the server (returns 202 immediately).
            // We poll /api/diag/refresh-progress until IsRunning=false.
            var resp = await Http.PostAsync("/api/diag/refresh", null);
            if (resp.StatusCode == System.Net.HttpStatusCode.Conflict)
            {
                NotificationService.Notify(NotificationSeverity.Warning, "Already running", "A refresh is already in progress.");
                return;
            }

            // Poll until the background job finishes (no 230s timeout risk).
            while (true)
            {
                await Task.Delay(1500);
                await FetchProgressAsync();

                var snap = await Http.GetFromJsonAsync<ProgressSnapshot>("/api/diag/refresh-progress");
                if (snap is null || !snap.IsRunning)
                    break;
            }

            // One final progress read to show completed/failed state in the log.
            await FetchProgressAsync();

            // Reload the report data.
            await LoadReportAsync();
            NotificationService.Notify(NotificationSeverity.Success, "Done", "Azure report refreshed successfully.");
        }
        catch (Exception ex)
        {
            await FetchProgressAsync();
            NotificationService.Notify(NotificationSeverity.Error, "Error", ex.Message);
        }
        finally
        {
            _refreshing = false;
            StateHasChanged();
        }
    }

    private async Task PollProgressAsync(System.Threading.CancellationToken ct)
    {
        while (!ct.IsCancellationRequested)
        {
            await FetchProgressAsync();
            try { await Task.Delay(1200, ct); } catch (TaskCanceledException) { break; }
        }
    }

    private async Task FetchProgressAsync()
    {
        try
        {
            var snap = await Http.GetFromJsonAsync<ProgressSnapshot>("/api/diag/refresh-progress");
            if (snap is not null)
            {
                _progressPercent = snap.Percent;
                _progressStep    = snap.Step;
                _progressLog     = snap.Log?.ToList() ?? new();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch { /* ignore transient errors */ }
    }

    private record ProgressSnapshot(bool IsRunning, string Step, int Percent, string[]? Log);

    private static List<SafeToRemoveItem> BuildSafeToRemove(AzureReport? r)
    {
        if (r == null) return new();
        var items = new List<SafeToRemoveItem>();
        foreach (var svc in r.WebServices?.Services ?? new())
        {
            var zero = svc.Metrics7Days?.Requests == 0;
            var broken = svc.HttpStatus == "broken";
            var unreachable = svc.HttpStatus == "unreachable";
            var stopped = svc.PlatformState == "Stopped";
            var azErr = svc.Connectivity?.IsAzureErrorPage == true;
            if ((broken || unreachable || stopped || azErr) && zero)
            {
                var reasons = new List<string>();
                if (broken) reasons.Add("HTTP broken");
                if (unreachable) reasons.Add("Unreachable (timeout)");
                if (stopped) reasons.Add("Platform Stopped");
                if (azErr) reasons.Add("Serving Azure error page");
                if (zero) reasons.Add("0 requests in 7 days");
                items.Add(new SafeToRemoveItem
                {
                    Name = svc.Name,
                    Source = "Connectivity + Metrics",
                    Reason = string.Join(", ", reasons),
                    Confidence = broken ? "high" : "medium",
                    Command = svc.ResourceType == "Microsoft.Web/sites"
                        ? $"az webapp delete --name \"{svc.Name}\" --resource-group \"{svc.ResourceGroup}\""
                        : null,
                });
            }
        }
        items.Sort((a, b) =>
        {
            var o = new Dictionary<string, int> { ["high"] = 0, ["medium"] = 1, ["low"] = 2 };
            return o.GetValueOrDefault(a.Confidence) - o.GetValueOrDefault(b.Confidence);
        });
        return items;
    }

    private static string TypeLabel(string? t) => t switch
    {
        "Microsoft.Web/sites"         => "App Service",
        "Microsoft.App/containerApps" => "Container App",
        "Microsoft.Web/staticSites"   => "Static Web App",
        _                             => t?.Split('/').LastOrDefault() ?? "—",
    };

    private static BadgeStyle HttpBadgeStyle(string? s) => s switch
    {
        "active"  => BadgeStyle.Success,
        "broken"  => BadgeStyle.Danger,
        _         => BadgeStyle.Warning,
    };

    private async Task CopyToClipboard(string text)
    {
        try { await JS.InvokeVoidAsync("navigator.clipboard.writeText", text); }
        catch { }
        NotificationService.Notify(new NotificationMessage
        {
            Severity = NotificationSeverity.Success,
            Summary  = "Copied",
            Detail   = "Command copied to clipboard",
            Duration = 2500
        });
    }

    // ── Chart helpers ─────────────────────────────────────────────────────────

    private string? _selectedResourceType;
    private List<ResourceDetail>? _selectedResourceDetails;

    private void SelectResourceType(string typeLabel)
    {
        if (_selectedResourceType == typeLabel)
        {
            _selectedResourceType    = null;
            _selectedResourceDetails = null;
            return;
        }
        _selectedResourceType    = typeLabel;
        _selectedResourceDetails = report?.AllResourceSummary?.ResourcesByType.GetValueOrDefault(typeLabel);
    }

    private record ChartPoint(string Label, double Value);
    private record DailyCostChartPoint(string Date, double Cost);

    private List<ChartPoint> ResourceTypeChartData =>
        report?.AllResourceSummary?.ByType
            .OrderByDescending(kv => kv.Value).Take(10)
            .Select(kv => new ChartPoint(kv.Key, kv.Value)).ToList() ?? new();

    private List<ChartPoint> ResourceTypeTableData =>
        report?.AllResourceSummary?.ByType
            .OrderByDescending(kv => kv.Value)
            .Select(kv => new ChartPoint(kv.Key, kv.Value)).ToList() ?? new();

    private List<ChartPoint> CostByRgData
    {
        get
        {
            if (report?.Cost?.TopCostDrivers is null) return new();
            var byRg = new Dictionary<string, double>(StringComparer.OrdinalIgnoreCase);
            foreach (var d in report.Cost.TopCostDrivers)
            {
                var m  = System.Text.RegularExpressions.Regex.Match(d.Name, @"\(([^)]+)\)$");
                var rg = m.Success ? m.Groups[1].Value : "Other";
                byRg[rg] = byRg.GetValueOrDefault(rg) + d.Cost;
            }
            return byRg.OrderByDescending(kv => kv.Value).Take(12)
                .Select(kv => new ChartPoint(kv.Key, Math.Round(kv.Value, 2))).ToList();
        }
    }

    private List<DailyCostChartPoint> BurnRateChartData =>
        report?.BurnRate?.DailyCosts
            .Select(d => new DailyCostChartPoint(
                DateTime.TryParse(d.Date, out var dt) ? dt.ToString("MMM d") : d.Date,
                d.Cost)).ToList() ?? new();

    // Show a label every ~5 days so the x-axis stays readable
    private int BurnRateLabelStep =>
        BurnRateChartData.Count > 20 ? 5 :
        BurnRateChartData.Count > 10 ? 3 : 1;
}
