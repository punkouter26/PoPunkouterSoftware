@page "/azure"
@rendermode WasmRenderModes.Interactive
@using System.Text.Json
@using System.Text.Json.Serialization
@using Microsoft.AspNetCore.SignalR.Client
@using PoPunkouterSoftware.Shared.Azure
@implements IAsyncDisposable
@inject HttpClient Http
@inject IJSRuntime JS
@inject NotificationService NotificationService
@inject NavigationManager NavManager

<PageTitle>Po Software — Azure Monitor</PageTitle>

<div class="app-page">

@if (_loading)
{
    <div class="app-card">
        <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" class="rz-my-3" />
        <p class="app-note rz-mb-0">Loading Azure report…</p>
    </div>
}
else if (!string.IsNullOrWhiteSpace(_loadError))
{
    <RadzenAlert AlertStyle="AlertStyle.Warning" Variant="Variant.Outlined" ShowIcon="true" class="rz-my-4">
        <div><strong>Azure dashboard load failed.</strong></div>
        <div class="app-mt-35">@_loadError</div>
        <div class="app-mt-75">
            <RadzenButton Text="Retry" Icon="refresh" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small" Click="@(async () => await LoadReportAsync())" />
        </div>
    </RadzenAlert>
}
else
{
    var currentReport = report ?? new AzureReport();
    var active   = currentReport.WebServices?.ByStatus?.Active ?? 0;
    var broken   = currentReport.WebServices?.ByStatus?.Broken ?? 0;
    var total    = currentReport.WebServices?.Total ?? 0;
    var healthPct = total > 0 ? (int)(active * 100.0 / total) : 100;
    var ageMin   = currentReport.GeneratedAt is DateTime genDt
                   ? (int)(DateTime.UtcNow - genDt).TotalMinutes : -1;
    var ageLabel = ageMin < 0 ? "" : ageMin < 60 ? $"{ageMin}m old" : ageMin < 1440 ? $"{ageMin / 60}h {ageMin % 60}m old" : $"{ageMin / 1440}d {ageMin % 1440 / 60}h old";
    var _secInsecureCount = (currentReport.StorageInventory ?? new()).Count(s => s.PublicBlobAccess || !s.HttpsOnly || s.MinTls is "TLS1_0" or "TLS1_1");
    var _criticalDriftCount = (currentReport.ConfigDrift ?? new()).Count(d => d.Issues?.Any(i => i.Severity is "critical" or "high") == true);

    <!-- ── Header banner ── -->
    <section class="app-section">
        <h1 class="rz-mb-4" style="font-size: 2.25rem; font-weight: 800; background: linear-gradient(135deg, #fff 30%, var(--app-accent) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; letter-spacing: -0.03em; font-family: var(--app-headline-font);">Azure Cleanup &amp; Weekly Health Report</h1>
        <div class="app-banner @(broken > 0 ? "critical" : "healthy")">
            <div class="app-toolbar">
                <div>
                    <div class="app-kicker">Azure · @(currentReport.Subscription?.Name ?? "—")</div>
                    <h2 class="app-card-title">@(broken > 0 ? $"{broken} service(s) need attention" : "All systems operational")</h2>
                    <p class="app-note rz-mb-0">
                        Generated: @(currentReport.GeneratedAt?.ToString("yyyy-MM-dd HH:mm") ?? "—") UTC
                    </p>
                </div>
                <div class="app-actions">
                    @if (ageMin >= 0)
                    {
                        var ageBadge = ageMin < 30 ? BadgeStyle.Success : ageMin < 120 ? BadgeStyle.Info : ageMin < 360 ? BadgeStyle.Warning : BadgeStyle.Danger;
                        <RadzenBadge Text="@ageLabel" BadgeStyle="@ageBadge" IsPill="true" />
                    }
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="6px">
                        <RadzenButton Text="@(_refreshing ? "Refreshing…" : "Refresh from Azure")" Icon="refresh"
                                      ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small"
                                      Disabled="@_refreshing" Click="RefreshAsync" />
                        <details class="app-overflow-menu">
                            <summary class="app-overflow-trigger" title="More actions">More</summary>
                            <div class="app-overflow-panel">
                                <RadzenButton Text="Download JSON" Icon="download" ButtonStyle="ButtonStyle.Light"
                                              Variant="Variant.Outlined" Size="ButtonSize.Small"
                                              Disabled="@(report == null)" Click="DownloadReportAsync"
                                              title="Download the full Azure report as JSON for sharing with AI tools or debugging" />
                            </div>
                        </details>
                        @if (_refreshing)
                        {
                            <RadzenButton Text="Cancel" Icon="close" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small"
                                          Click="CancelRefreshAsync" />
                        }
                    </RadzenStack>
                </div>
            </div>
        </div>
    </section>

    @if (_refreshing)
    {
        <section class="app-section">
            <RadzenProgressBar Value="@_progressPercent" Max="100" ShowValue="true" class="rz-mb-1" Style="height:22px" />
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="6px" class="rz-mb-2">
                <RadzenIcon Icon="sync" class="app-progress-icon" />
                <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary">@_progressStep</RadzenText>
            </RadzenStack>
        </section>
    }

    @* Fix 3: Age badge in header is sufficient. Stale banner removed. *@

    @* Fix 4: Security alert surfaced near top, outside tabs *@
    @if (_secInsecureCount > 0 || _criticalDriftCount > 0)
    {
        <section class="app-section">
            <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Outlined" ShowIcon="true" class="rz-my-2">
                @if (_secInsecureCount > 0)
                {
                    <span><strong>Security:</strong> @_secInsecureCount storage account(s) have misconfigurations (public blobs / TLS / HTTPS). </span>
                }
                @if (_criticalDriftCount > 0)
                {
                    <span><strong>Config:</strong> @_criticalDriftCount service(s) have high/critical severity drift. </span>
                }
                <span class="app-note">Details are shown in the sections below.</span>
            </RadzenAlert>
        </section>
    }

    @* Flattened top-level content: Overview and Trends are now sequential sections. *@

    <!-- ── KPI Strip ── -->
    <section class="app-section">
        <div class="app-dashboard-summary">
            <div class="app-metric-card"><strong>@active / @total</strong><span class="app-note">Operational</span></div>
            <div class="app-metric-card"><strong>@(currentReport.Cost?.TotalFormatted ?? "$0.00")</strong><span class="app-note">30-day cost</span></div>
            <div class="app-metric-card"><strong>@((currentReport.OrphanedResources?.Count ?? 0) + (currentReport.ZombieApps?.Count ?? 0))</strong><span class="app-note">Waste candidates</span></div>
            <div class="app-metric-card"><strong>@(currentReport.AllResourceSummary?.Total ?? 0)</strong><span class="app-note">Total resources</span></div>
        </div>
    </section>

    <!-- ── Visualisations & Charts wrapped in Tabs ── -->
    <section class="app-section">
        <RadzenTabs SelectedIndex="0">
            <Tabs>
                @* ── Tab 1: Overview & Cost ── *@
                <RadzenTabsItem Text="Overview & Cost">
                    <RadzenRow Gap="1rem" class="rz-mt-3">
                        <!-- Viz 1: Fleet Health Donut -->
                        <RadzenColumn SizeXS="12" SizeMD="4">
                            <div class="app-card app-fill">
                                <div class="app-kicker">Fleet Health</div>
                                <h3 class="app-card-title rz-mb-1">Service Status Overview</h3>
                                <p class="app-note rz-mb-2">Active / Broken / Other across all @total web services.</p>
                                <div style="position:relative">
                                    <RadzenChart Style="height:230px">
                                        <RadzenDonutSeries TItem="ChartPoint" Data="@FleetHealthDonutData"
                                                           CategoryProperty="Label" ValueProperty="Value" InnerRadius="75" />
                                        <RadzenLegend Position="LegendPosition.Bottom" />
                                    </RadzenChart>
                                    <div style="position:absolute;top:38%;left:50%;transform:translateX(-50%);text-align:center;pointer-events:none">
                                        <div style="font-size:2rem;font-weight:700;line-height:1;color:@(healthPct >= 80 ? "var(--rz-success)" : healthPct >= 50 ? "var(--rz-warning)" : "var(--rz-danger)")">@healthPct%</div>
                                        <div style="font-size:.72rem;opacity:.65;margin-top:.15rem">healthy</div>
                                    </div>
                                </div>
                            </div>
                        </RadzenColumn>

                        <!-- Viz 2: Cost Breakdown Bar Chart -->
                        <RadzenColumn SizeXS="12" SizeMD="8">
                            <div class="app-card app-fill">
                                <div class="app-kicker">Cost Breakdown</div>
                                <h3 class="app-card-title rz-mb-1">Top Cost Drivers — 30 Days</h3>
                                <p class="app-note rz-mb-2">
                                    Spend by Azure service / resource group. Total: <strong>@(currentReport.Cost?.TotalFormatted ?? "—")</strong>
                                    @if (!string.IsNullOrEmpty(currentReport.Cost?.Note)) { <span class="app-tone-warning"> · @currentReport.Cost.Note</span> }
                                </p>
                                @if (CostDriversBarData.Count == 0)
                                {
                                    <div class="app-callout info">No cost data — run Refresh from Azure to fetch billing data.</div>
                                }
                                else
                                {
                                    <RadzenChart Style="height:230px">
                                        <RadzenBarSeries TItem="ChartPoint" Data="@CostDriversBarData"
                                                         CategoryProperty="Label" ValueProperty="Value" Title="USD" />
                                        <RadzenValueAxis FormatString="${0:F2}"><RadzenGridLines Visible="true" /></RadzenValueAxis>
                                        <RadzenCategoryAxis />
                                        <RadzenLegend Visible="false" />
                                    </RadzenChart>
                                }
                            </div>
                        </RadzenColumn>
                    </RadzenRow>

                    <RadzenRow Gap="1rem" class="rz-mt-3">
                        <!-- Viz 6: Resource Inventory Donut -->
                        <RadzenColumn SizeXS="12" SizeMD="6">
                            <div class="app-card app-fill">
                                <div class="app-kicker">Inventory</div>
                                <h3 class="app-card-title rz-mb-1">Resource Inventory by Type</h3>
                                <p class="app-note rz-mb-2">
                                    @(currentReport.AllResourceSummary?.Total ?? 0) resources across
                                    @(currentReport.AllResourceSummary?.ByType.Count ?? 0) types.
                                </p>
                                <RadzenRow>
                                    <RadzenColumn SizeXS="12" SizeMD="6">
                                        <RadzenChart Style="height:230px">
                                            <RadzenDonutSeries TItem="ChartPoint" Data="@ResourceTypeChartData"
                                                               CategoryProperty="Label" ValueProperty="Value" InnerRadius="50" />
                                            <RadzenLegend Visible="false" />
                                        </RadzenChart>
                                    </RadzenColumn>
                                    <RadzenColumn SizeXS="12" SizeMD="6">
                                        <div class="app-table-frame app-overflow-y-230">
                                            <RadzenDataGrid Data="@ResourceTypeTableData" TItem="ChartPoint"
                                                            AllowSorting="true" AllowPaging="false">
                                                <Columns>
                                                    <RadzenDataGridColumn TItem="ChartPoint" Property="Label" Title="Type" />
                                                    <RadzenDataGridColumn TItem="ChartPoint" Property="Value" Title="#" Width="55px" TextAlign="TextAlign.Right">
                                                        <Template Context="p"><strong>@((int)p.Value)</strong></Template>
                                                    </RadzenDataGridColumn>
                                                </Columns>
                                            </RadzenDataGrid>
                                        </div>
                                    </RadzenColumn>
                                </RadzenRow>
                            </div>
                        </RadzenColumn>

                        <!-- Viz 7: Waste summary -->
                        <RadzenColumn SizeXS="12" SizeMD="6">
                            <div class="app-card app-fill">
                                <div class="app-kicker">Waste Summary</div>
                                <h3 class="app-card-title rz-mb-1">Zombie Apps &amp; Orphaned Resources</h3>
                                <p class="app-note rz-mb-2">Zero-traffic broken apps and unattached resources with estimated monthly cost.</p>
                                @{
                                    var zombies  = currentReport.ZombieApps        ?? new();
                                    var orphaned = currentReport.OrphanedResources  ?? new();
                                    double totalWaste = 0;
                                    foreach (var _o in orphaned.Where(x => x.EstimatedMonthlyCost != null))
                                    {
                                        if (double.TryParse(_o.EstimatedMonthlyCost!.Replace("$", ""), out var _c))
                                            totalWaste += _c;
                                    }
                                }
                                @if (zombies.Count == 0 && orphaned.Count == 0)
                                {
                                    <div class="app-callout success">No zombie apps or orphaned resources detected.</div>
                                }
                                else
                                {
                                    <div class="app-dashboard-summary rz-mb-3 app-grid-metrics-110">
                                        <div class="app-metric-card"><strong>@zombies.Count</strong><span class="app-note">Zombie apps</span></div>
                                        <div class="app-metric-card"><strong>@orphaned.Count</strong><span class="app-note">Orphaned</span></div>
                                        @if (totalWaste > 0)
                                        {
                                            <div class="app-metric-card"><strong class="app-tone-warning">~$@totalWaste.ToString("F2")/mo</strong><span class="app-note">Est. waste</span></div>
                                        }
                                    </div>
                                    <div class="app-callout warning">
                                        <span>Waste cleanup candidates are detected. See details in the <strong>Waste &amp; Cleanup</strong> tab below.</span>
                                    </div>
                                }
                            </div>
                        </RadzenColumn>
                    </RadzenRow>
                </RadzenTabsItem>

                @* ── Tab 2: Performance & Traffic ── *@
                <RadzenTabsItem Text="Performance & Traffic">
                    <RadzenRow Gap="1rem" class="rz-mt-3">
                        <!-- Viz 4: App Response Time Distribution -->
                        <RadzenColumn SizeXS="12" SizeMD="6">
                            <div class="app-card app-fill">
                                <div class="app-kicker">Performance</div>
                                <h3 class="app-card-title rz-mb-1">App Response Times</h3>
                                <p class="app-note rz-mb-2">Probe response time (ms), slowest first. &lt;1 000ms good · &gt;3 000ms critical.</p>
                                @{
                                    var allTimedOut = ResponseTimeBarData.Count > 0 && ResponseTimeBarData.All(p => p.Value >= 14000);
                                }
                                @if (ResponseTimeBarData.Count == 0)
                                {
                                    <div class="app-callout info">No response time data — services may not yet have been probed.</div>
                                }
                                else if (allTimedOut)
                                {
                                    <div class="app-callout danger">All @ResponseTimeBarData.Count services are timing out at the 15-second probe limit. No meaningful response time differential to display — investigate service availability.</div>
                                }
                                else
                                {
                                    <RadzenChart Style="height:260px">
                                        <RadzenBarSeries TItem="ChartPoint" Data="@ResponseTimeBarData"
                                                         CategoryProperty="Label" ValueProperty="Value" Title="ms" />
                                        <RadzenValueAxis FormatString="{0}ms"><RadzenGridLines Visible="true" /></RadzenValueAxis>
                                        <RadzenLegend Visible="false" />
                                    </RadzenChart>
                                }
                            </div>
                        </RadzenColumn>

                        <!-- Viz 5: 7-Day Error Rate -->
                        <RadzenColumn SizeXS="12" SizeMD="6">
                            <div class="app-card app-fill">
                                <div class="app-kicker">Reliability</div>
                                <h3 class="app-card-title rz-mb-1">7-Day 5xx Error Counts</h3>
                                <p class="app-note rz-mb-2">HTTP 5xx server errors per app over the past 7 days. Zero is ideal.</p>
                                @if (ErrorRateBarData.Count == 0)
                                {
                                    <div class="app-callout success">No 5xx errors recorded in the last 7 days across all services.</div>
                                }
                                else
                                {
                                    <RadzenChart Style="height:260px">
                                        <RadzenBarSeries TItem="ChartPoint" Data="@ErrorRateBarData"
                                                         CategoryProperty="Label" ValueProperty="Value" Title="5xx errors" />
                                        <RadzenValueAxis><RadzenGridLines Visible="true" /></RadzenValueAxis>
                                        <RadzenLegend Visible="false" />
                                    </RadzenChart>
                                }
                            </div>
                        </RadzenColumn>
                    </RadzenRow>

                    @if (WebTrafficByService.Count > 0)
                    {
                        <div class="app-card rz-mt-3">
                            <div class="app-kicker">Traffic</div>
                            <h3 class="app-card-title rz-mb-1">Web Traffic (Requests — Last 7 Days)</h3>
                            <RadzenChart Style="height:300px">
                                <RadzenBarSeries TItem="TrafficPoint" Data="@WebTrafficByService"
                                                 CategoryProperty="Service" ValueProperty="Requests" Title="Requests">
                                    <RadzenSeriesDataLabels Visible="false" />
                                </RadzenBarSeries>
                                @if (WebTrafficByService.Any(p => p.Http5xx > 0))
                                {
                                    <RadzenBarSeries TItem="TrafficPoint" Data="@WebTrafficByService"
                                                     CategoryProperty="Service" ValueProperty="Http5xx" Title="5xx errors">
                                        <RadzenSeriesDataLabels Visible="false" />
                                    </RadzenBarSeries>
                                }
                                <RadzenCategoryAxis><RadzenAxisTitle Text="App" /></RadzenCategoryAxis>
                                <RadzenValueAxis><RadzenAxisTitle Text="Requests (7d)" /><RadzenGridLines Visible="true" /></RadzenValueAxis>
                                <RadzenLegend Visible="true" />
                            </RadzenChart>
                            <p class="app-note rz-mt-2 rz-mb-0">
                                Showing @WebTrafficByService.Count service(s). Total:
                                <strong>@WebTrafficByService.Sum(p => p.Requests).ToString("N0")</strong> requests
                                · @WebTrafficByService.Sum(p => p.Http5xx).ToString("N0") server errors.
                            </p>
                        </div>

                        <RadzenRow Gap="1rem" class="rz-mt-3">
                            <RadzenColumn SizeXS="12" SizeMD="6">
                                <div class="app-card app-fill">
                                    <div class="app-card-header"><span class="material-symbols-outlined">groups</span> Plan usage by App Service Plan</div>
                                    <p class="app-note rz-mb-2">Aggregated request volume and app counts by plan tier to highlight shared-resource pressure.</p>
                                    @if (PlanUsageByPlan.Count == 0)
                                    {
                                        <div class="app-callout info">No App Service Plan metadata is available in the current report.</div>
                                    }
                                    else
                                    {
                                        <RadzenChart Style="height:280px">
                                            <RadzenBarSeries TItem="PlanUsagePoint" Data="@PlanUsageByPlan" CategoryProperty="Plan" ValueProperty="Requests" Title="7d requests" />
                                            <RadzenBarSeries TItem="PlanUsagePoint" Data="@PlanUsageByPlan" CategoryProperty="Plan" ValueProperty="Apps" Title="Apps on plan" />
                                            <RadzenCategoryAxis><RadzenAxisTitle Text="Plan" /></RadzenCategoryAxis>
                                            <RadzenValueAxis><RadzenAxisTitle Text="Requests / Apps" /><RadzenGridLines Visible="true" /></RadzenValueAxis>
                                            <RadzenLegend Visible="true" />
                                        </RadzenChart>
                                    }
                                </div>
                            </RadzenColumn>

                            <RadzenColumn SizeXS="12" SizeMD="6">
                                <div class="app-card app-fill">
                                    <div class="app-card-header"><span class="material-symbols-outlined">trending_up</span> Top 10 apps by request volume</div>
                                    <p class="app-note rz-mb-2">A clearer view of which applications drive the busiest traffic on the shared plan.</p>
                                    @if (TopAppRequestChartData.Count == 0)
                                    {
                                        <div class="app-callout info">No request-volume data is available for individual apps.</div>
                                    }
                                    else
                                    {
                                        <RadzenChart Style="height:280px">
                                            <RadzenBarSeries TItem="ChartPoint" Data="@TopAppRequestChartData" CategoryProperty="Label" ValueProperty="Value" Title="Requests (7d)" />
                                            <RadzenCategoryAxis><RadzenAxisTitle Text="Application" /></RadzenCategoryAxis>
                                            <RadzenValueAxis><RadzenAxisTitle Text="Requests (7d)" /><RadzenGridLines Visible="true" /></RadzenValueAxis>
                                            <RadzenLegend Visible="false" />
                                        </RadzenChart>
                                    }
                                </div>
                            </RadzenColumn>
                        </RadzenRow>
                    }
                </RadzenTabsItem>

                @* ── Tab 3: History & Trends ── *@
                <RadzenTabsItem Text="History & Trends">
                    @if (HasHistory)
                    {
                        <div class="app-grid app-grid-auto-420 rz-mt-3">
                            <div class="app-card">
                                <div class="app-card-header"><span class="material-symbols-outlined">show_chart</span> Service Status Over Time</div>
                                <RadzenChart Style="height:260px">
                                    <RadzenLineSeries TItem="StatusHistPoint" Data="@ServiceStatusHistory" CategoryProperty="Label" ValueProperty="Active" Title="Active" Smooth="true"><RadzenSeriesDataLabels Visible="false" /></RadzenLineSeries>
                                    <RadzenLineSeries TItem="StatusHistPoint" Data="@ServiceStatusHistory" CategoryProperty="Label" ValueProperty="Broken" Title="Broken" Smooth="true"><RadzenSeriesDataLabels Visible="false" /></RadzenLineSeries>
                                    <RadzenCategoryAxis><RadzenAxisTitle Text="Date (last 30 days)" /></RadzenCategoryAxis>
                                    <RadzenValueAxis><RadzenAxisTitle Text="Services" /><RadzenGridLines Visible="true" /></RadzenValueAxis>
                                    <RadzenLegend Visible="true" />
                                </RadzenChart>
                            </div>
                            @if (CostHistory.Count > 0)
                            {
                                <div class="app-card">
                                    <div class="app-card-header"><span class="material-symbols-outlined">payments</span> 30-Day Cost Over Time</div>
                                    <RadzenChart Style="height:260px">
                                        <RadzenLineSeries TItem="TimePoint" Data="@CostHistory" CategoryProperty="Label" ValueProperty="Value" Title="Cost ($)" Smooth="true"><RadzenSeriesDataLabels Visible="false" /></RadzenLineSeries>
                                        <RadzenCategoryAxis><RadzenAxisTitle Text="Date (last 30 days)" /></RadzenCategoryAxis>
                                        <RadzenValueAxis FormatString="${0:F2}"><RadzenAxisTitle Text="USD (30d)" /><RadzenGridLines Visible="true" /></RadzenValueAxis>
                                    </RadzenChart>
                                </div>
                            }
                            @if (AvgResponseHistory.Count > 0)
                            {
                                <div class="app-card">
                                    <div class="app-card-header"><span class="material-symbols-outlined">speed</span> Avg Response Time Over Time</div>
                                    <RadzenChart Style="height:260px">
                                        <RadzenLineSeries TItem="TimePoint" Data="@AvgResponseHistory" CategoryProperty="Label" ValueProperty="Value" Title="Avg ms" Smooth="true"><RadzenSeriesDataLabels Visible="false" /></RadzenLineSeries>
                                        <RadzenCategoryAxis><RadzenAxisTitle Text="Date (last 30 days)" /></RadzenCategoryAxis>
                                        <RadzenValueAxis FormatString="{0}ms"><RadzenAxisTitle Text="Response (ms)" /><RadzenGridLines Visible="true" /></RadzenValueAxis>
                                    </RadzenChart>
                                </div>
                            }
                            @if (TrackedServiceNames.Count > 0)
                            {
                                <div class="app-card app-grid-span-all">
                                    <div class="app-card-header"><span class="material-symbols-outlined">timeline</span> Response Time per Service (active services)</div>
                                    <RadzenChart Style="height:300px">
                                        @foreach (var svcName in TrackedServiceNames)
                                        {
                                            var pts = GetServiceResponseHistory(svcName);
                                            <RadzenLineSeries TItem="ServiceTimePoint" Data="@pts" CategoryProperty="Label" ValueProperty="ResponseMs" Title="@svcName" Smooth="true"><RadzenSeriesDataLabels Visible="false" /></RadzenLineSeries>
                                        }
                                        <RadzenCategoryAxis><RadzenAxisTitle Text="Date (last 30 days)" /></RadzenCategoryAxis>
                                        <RadzenValueAxis FormatString="{0}ms"><RadzenAxisTitle Text="Response (ms)" /><RadzenGridLines Visible="true" /></RadzenValueAxis>
                                        <RadzenLegend Visible="true" />
                                    </RadzenChart>
                                </div>
                            }
                            @if (Errors5xxHistory.Count > 0)
                            {
                                <div class="app-card">
                                    <div class="app-card-header"><span class="material-symbols-outlined">error</span> Total 5xx Errors Over Time</div>
                                    <RadzenChart Style="height:260px">
                                        <RadzenLineSeries TItem="TimePoint" Data="@Errors5xxHistory" CategoryProperty="Label" ValueProperty="Value" Title="5xx errors" Smooth="true"><RadzenSeriesDataLabels Visible="false" /></RadzenLineSeries>
                                        <RadzenCategoryAxis><RadzenAxisTitle Text="Date (last 30 days)" /></RadzenCategoryAxis>
                                        <RadzenValueAxis><RadzenAxisTitle Text="Total 5xx errors" /><RadzenGridLines Visible="true" /></RadzenValueAxis>
                                    </RadzenChart>
                                </div>
                            }
                            @if (UptimePctHistory.Count > 0)
                            {
                                <div class="app-card">
                                    <div class="app-card-header"><span class="material-symbols-outlined">check_circle</span> Uptime % Over Time</div>
                                    <RadzenChart Style="height:260px">
                                        <RadzenLineSeries TItem="TimePoint" Data="@UptimePctHistory" CategoryProperty="Label" ValueProperty="Value" Title="Uptime %" Smooth="true"><RadzenSeriesDataLabels Visible="false" /></RadzenLineSeries>
                                        <RadzenCategoryAxis><RadzenAxisTitle Text="Date (last 30 days)" /></RadzenCategoryAxis>
                                        <RadzenValueAxis Min="0" Max="100" FormatString="{0}%"><RadzenAxisTitle Text="Uptime %" /><RadzenGridLines Visible="true" /></RadzenValueAxis>
                                    </RadzenChart>
                                </div>
                            }
                            @if (BrokenDeltaHistory.Count > 0)
                            {
                                <div class="app-card">
                                    <div class="app-card-header"><span class="material-symbols-outlined">trending_down</span> Broken Services Delta Over Time</div>
                                    <RadzenChart Style="height:260px">
                                        <RadzenBarSeries TItem="DeltaPoint" Data="@BrokenDeltaHistory" CategoryProperty="Label" ValueProperty="Delta" Title="Delta"><RadzenSeriesDataLabels Visible="false" /></RadzenBarSeries>
                                        <RadzenCategoryAxis><RadzenAxisTitle Text="Date (last 30 days)" /></RadzenCategoryAxis>
                                        <RadzenValueAxis><RadzenAxisTitle Text="Change in broken services" /><RadzenGridLines Visible="true" /></RadzenValueAxis>
                                    </RadzenChart>
                                </div>
                            }
                            @if (ResourceCountHistory.Count > 0)
                            {
                                <div class="app-card">
                                    <div class="app-card-header"><span class="material-symbols-outlined">inventory_2</span> Total Resource Count Over Time</div>
                                    <RadzenChart Style="height:260px">
                                        <RadzenLineSeries TItem="TimePoint" Data="@ResourceCountHistory" CategoryProperty="Label" ValueProperty="Value" Title="Resources" Smooth="true"><RadzenSeriesDataLabels Visible="false" /></RadzenLineSeries>
                                        <RadzenCategoryAxis><RadzenAxisTitle Text="Date (last 30 days)" /></RadzenCategoryAxis>
                                        <RadzenValueAxis><RadzenAxisTitle Text="Resource count" /><RadzenGridLines Visible="true" /></RadzenValueAxis>
                                    </RadzenChart>
                                </div>
                            }
                            @if (ScanDurationHistory.Count > 0)
                            {
                                <div class="app-card">
                                    <div class="app-card-header"><span class="material-symbols-outlined">timer</span> Scan Duration Over Time</div>
                                    <RadzenChart Style="height:260px">
                                        <RadzenLineSeries TItem="TimePoint" Data="@ScanDurationHistory" CategoryProperty="Label" ValueProperty="Value" Title="Duration" Smooth="true"><RadzenSeriesDataLabels Visible="false" /></RadzenLineSeries>
                                        <RadzenCategoryAxis><RadzenAxisTitle Text="Date (last 30 days)" /></RadzenCategoryAxis>
                                        <RadzenValueAxis FormatString="{0}ms"><RadzenAxisTitle Text="Total scan (ms)" /><RadzenGridLines Visible="true" /></RadzenValueAxis>
                                    </RadzenChart>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="app-card rz-mt-3">
                            <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true" AllowClose="false">
                                No scan history yet. Charts will appear after two or more scans are saved.
                                <RadzenButton Text="Refresh from Azure" Icon="refresh" ButtonStyle="ButtonStyle.Info"
                                              Size="ButtonSize.Small" Click="RefreshAsync" Style="margin-left:.75rem" />
                            </RadzenAlert>
                        </div>
                    }
                </RadzenTabsItem>
            </Tabs>
        </RadzenTabs>
    </section>

    <!-- ── Fleet Diagnosis ── -->
    @if (report?.DowntimeDiagnoses?.Count > 0)
    {
        var diags = report.DowntimeDiagnoses;
        var allSameCause = diags.Count > 1 && diags.Select(d => d.LikelyCause).Distinct().Count() == 1;
        var fleetPattern = allSameCause ? diags.First().LikelyCause : null;
        <section class="app-section">
            <div class="app-callout info">
                @if (allSameCause && !string.IsNullOrEmpty(fleetPattern))
                {
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="8px" class="rz-mb-1">
                        <span style="font-size:1.25rem">💡</span>
                        <strong>@diags.Count/@diags.Count broken apps show the same pattern:</strong>
                    </RadzenStack>
                    <div class="rz-mb-2">@fleetPattern</div>
                    <RadzenButton Text="View Fleet Logs" Icon="visibility" ButtonStyle="ButtonStyle.Info" Size="ButtonSize.Small"
                                  Click="@(() => { _selectedTabIndex = 0; })" />
                }
                else
                {
                    <span>@diags.Count services need attention. Details below.</span>
                }
            </div>
        </section>
    }

    <AzureDashboardDetailTabs Report="report"
                              TotalCount="TotalCount"
                              ShowAdvancedDiagnostics="ShowAdvancedDiagnostics"
                              @bind-SelectedTabIndex="_selectedTabIndex"
                              CleanupCandidates="CleanupCandidates"
                              AiServices="AiServices"
                              LogAnalyticsWorkspaces="LogAnalyticsWorkspaces"
                              AiCostDriversSum="AiCostDrivers.Sum(a => a.Cost)"
                              LogAnalyticsCostDriversSum="LogAnalyticsCostDrivers.Sum(l => l.Cost)" />

}

</div>

