                    </RadzenDataGrid>

                    @if (_infraSelected is not null)
                    {
                        <div class="app-detail-panel soft">
                            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center" class="rz-mb-3">
                                <RadzenText TextStyle="TextStyle.H6" class="rz-m-0">
                                    📂 <strong>@_infraSelected.RepoName</strong>
