                                                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="6px" class="rz-mb-1">
                                                    <RadzenBadge Text="@inf.FileType.ToUpper()" BadgeStyle="@InfraFileBadge(inf.FileType)" IsPill="true" class="app-badge-xs" />
                                                    <strong class="app-file-card-title">@inf.FileName</strong>
                                                </RadzenStack>
                                                <div class="app-meta-line rz-mb-1">@inf.FilePath</div>
                                                @if (inf.ResourceTypes.Any())
                                                {
                                                    <div>
                                                        <span class="app-subtle-label">Resources: </span>
                                                        @foreach (var rt in inf.ResourceTypes)
