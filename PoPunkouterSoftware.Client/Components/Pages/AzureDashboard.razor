@page "/azure"
@rendermode WasmRenderModes.Interactive
@using System.Text.Json
@using System.Text.Json.Serialization
@inject HttpClient Http
@inject IJSRuntime JS
@inject NotificationService NotificationService

<PageTitle>PoPunkouterSoftware — Azure Dashboard</PageTitle>

<div class="app-page">
    <section class="app-section app-ops-hero">
        <div class="app-kicker">Azure operations</div>
        <h1 class="app-section-heading">Azure Dashboard</h1>
        <p class="app-section-copy rz-mb-0">
            A command-center view across app health, cost, cleanup candidates, SSL, storage, and CI/CD posture.
        </p>
    </section>

@if (_loading)
{
    <div class="app-card">
        <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" class="rz-my-3" />
        <p class="app-note rz-mb-0">Loading Azure report and portfolio signals…</p>
    </div>
}
else if (!string.IsNullOrWhiteSpace(_loadError))
{
    <RadzenAlert AlertStyle="AlertStyle.Warning" Variant="Variant.Outlined" ShowIcon="true" class="rz-my-4">
        <div><strong>Azure dashboard load failed.</strong></div>
        <div style="margin-top:.35rem">@_loadError</div>
        <div style="margin-top:.75rem">
            <RadzenButton Text="Retry" Icon="refresh" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small" Click="@(async () => await LoadReportAsync())" />
        </div>
    </RadzenAlert>
}
else
{
    var currentReport = report ?? new AzureReport();
    var consolidatedServices = ConsolidatedServices;
    var priorityQueue = PriorityQueue;
    var topPriority = priorityQueue.Take(3).ToList();
    var attentionServices = SortedServices
        .Where(s => s.HttpStatus is "broken" or "unreachable"
            || s.Connectivity?.IsAzureErrorPage == true
            || (s.Metrics7Days?.Http5xx ?? 0) > 0)
        .Take(3)
        .ToList();
    var totalRequests7d = consolidatedServices.Sum(s => s.Requests7d);
    var activeApps = consolidatedServices.Count(s => s.HttpStatus == "active");
    var totalCost30d = currentReport.Cost?.TotalCost30Days ?? 0;
    var costPer1kRequests = totalRequests7d > 0 ? (totalCost30d / totalRequests7d) * 1000 : 0;
    var costPerActiveApp = activeApps > 0 ? totalCost30d / activeApps : 0;
    var avgReliability = consolidatedServices.Count > 0 ? consolidatedServices.Average(s => s.ReliabilityScore) : 100;

    <section class="app-section">
        <div class="app-banner @(attentionServices.Count > 0 ? "critical" : "healthy")">
            <div class="app-toolbar">
                <div>
                    <div class="app-kicker">Snapshot</div>
                    <h2 class="app-card-title">@((attentionServices.Count > 0) ? "Immediate action items detected" : "Portfolio looks stable")</h2>
                    <p class="app-note rz-mb-0">
                        Subscription: @(currentReport.Subscription?.Name ?? "—")
                        &nbsp;|&nbsp; Generated: @(currentReport.GeneratedAt?.ToString("yyyy-MM-dd HH:mm") ?? "—")
                    </p>
                </div>

                <div class="app-actions">
                    @if (currentReport.GeneratedAt is DateTime generatedAt && (DateTime.UtcNow - generatedAt).TotalHours > 24)
                    {
                        <RadzenBadge Text="@($"{(int)(DateTime.UtcNow - generatedAt).TotalHours}h old")"
                                     BadgeStyle="BadgeStyle.Warning" IsPill="true" />
                    }
                    <RadzenButton Text="@(_refreshing ? "Refreshing…" : "Refresh from Azure")" Icon="refresh"
                                  ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small"
                                  Disabled="@_refreshing" Click="RefreshAsync" />
                </div>
            </div>
        </div>
    </section>

    @if (_refreshing)
    {
        <section class="app-section">
        <RadzenProgressBar Value="@_progressPercent" Max="100" ShowValue="true" class="rz-mb-1" Style="height:22px" />
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="6px" class="rz-mb-2">
            <RadzenIcon Icon="sync" Style="font-size:1rem;animation:spin 1.4s linear infinite" />
            <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary">@_progressStep</RadzenText>
        </RadzenStack>
        @if (_progressLog.Count > 0)
        {
            <div class="app-progress-log">
                @foreach (var line in _progressLog)
                {
                    <div>@line</div>
                }
            </div>
        }
        </section>
    }

    <section class="app-section">
        <div class="app-dashboard-summary">
            <div class="app-metric-card"><strong>@consolidatedServices.Count</strong><span class="app-note">Consolidated apps</span></div>
            <div class="app-metric-card"><strong>@(currentReport.WebServices?.ByStatus?.Active ?? 0)</strong><span class="app-note">Active</span></div>
            <div class="app-metric-card"><strong>@(currentReport.WebServices?.ByStatus?.Broken ?? 0)</strong><span class="app-note">Broken</span></div>
            <div class="app-metric-card"><strong>@(currentReport.Cost?.TotalFormatted ?? "$0.00")</strong><span class="app-note">30-day cost</span></div>
            <div class="app-metric-card"><strong>@safeToRemove.Count</strong><span class="app-note">Safe to remove</span></div>
            <div class="app-metric-card"><strong>@($"${costPer1kRequests:F2}")</strong><span class="app-note">Cost / 1k req</span></div>
            <div class="app-metric-card"><strong>@($"${costPerActiveApp:F2}")</strong><span class="app-note">Cost / active app</span></div>
            <div class="app-metric-card"><strong>@($"{avgReliability:F0}%")</strong><span class="app-note">Avg reliability</span></div>
        </div>
    </section>

    <section class="app-section app-spotlight-grid">
        <div class="app-card">
            <div class="app-kicker">Priority first</div>
            <h2 class="app-card-title rz-mb-2">Operator queue</h2>
            <p class="app-note">The highest-impact actions are surfaced here first. Full detail remains in the tabs below.</p>
            <div class="app-priority-stack">
                @if (topPriority.Count == 0)
                {
                    <div class="app-empty-state">No immediate action items are currently ranked in the priority queue.</div>
                }
                else
                {
                    @foreach (var item in topPriority)
                    {
                        <div class="app-priority-item">
                            <div class="app-status-row rz-mb-1">
                                <div class="app-priority-item-title">@item.Item</div>
                                <RadzenBadge Text="@item.Actionability" IsPill="true" BadgeStyle="@ActionabilityBadge(item.Actionability)" />
                            </div>
                            <div class="app-note rz-mb-1">@item.Reason</div>
                            <div class="app-chip-row">
                                <RadzenBadge Text="@item.Source" BadgeStyle="BadgeStyle.Info" Variant="Variant.Flat" IsPill="true" />
                                <RadzenBadge Text="@($"Impact {item.ImpactScore}")" BadgeStyle="BadgeStyle.Warning" Variant="Variant.Flat" IsPill="true" />
                                <RadzenBadge Text="@item.Confidence" BadgeStyle="BadgeStyle.Light" Variant="Variant.Flat" IsPill="true" />
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <div class="app-card">
            <div class="app-kicker">Watchlist</div>
            <h2 class="app-card-title rz-mb-2">Services needing attention</h2>
            <p class="app-note">Broken apps, Azure placeholder pages, or services with recent 5xx activity.</p>
            <div class="app-priority-stack">
                @if (attentionServices.Count == 0)
                {
                    <div class="app-empty-state">No services are currently flagged for urgent review.</div>
                }
                else
                {
                    @foreach (var service in attentionServices)
                    {
                        <div class="app-priority-item">
                            <div class="app-status-row rz-mb-1">
                                <div class="app-priority-item-title">@(service.FriendlyName ?? service.Name)</div>
                                <RadzenBadge Text="@service.HttpStatus" BadgeStyle="@HttpBadgeStyle(service.HttpStatus)" IsPill="true" />
                            </div>
                            <div class="app-note">@(service.ResourceGroup ?? "No resource group")</div>
                            <div class="app-chip-row rz-mt-1">
                                @if (!string.IsNullOrWhiteSpace(service.PlatformState))
                                {
                                    <RadzenBadge Text="@service.PlatformState" BadgeStyle="BadgeStyle.Info" Variant="Variant.Flat" IsPill="true" />
                                }
                                @if ((service.Metrics7Days?.Http5xx ?? 0) > 0)
                                {
                                    <RadzenBadge Text="@($"5xx: {service.Metrics7Days!.Http5xx}")" BadgeStyle="BadgeStyle.Danger" Variant="Variant.Flat" IsPill="true" />
                                }
                                @if (service.Connectivity?.ResponseTime > 0)
                                {
                                    <RadzenBadge Text="@($"{service.Connectivity.ResponseTime} ms")" BadgeStyle="BadgeStyle.Warning" Variant="Variant.Flat" IsPill="true" />
                                }
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </section>

    <section class="app-section">
    <div class="app-card">
    <div class="app-toolbar rz-mb-3">
        <div>
            <div class="app-kicker">Deep analysis</div>
            <h2 class="app-card-title">Detailed portfolio views</h2>
            <p class="app-note rz-mb-0">Start with Consolidated, Priority Queue, and Web Services. Secondary analysis lives in the remaining tabs.</p>
        </div>
    </div>

    <RadzenTabs @bind-SelectedIndex="_selectedTabIndex">
        <Tabs>

            <!-- ── Tab 1: Consolidated View ── -->
            <RadzenTabsItem Text="@($"🧠 Consolidated ({consolidatedServices.Count})")">
                <div class="app-tab-pane rz-mt-2">
                    <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary rz-mb-2">
                        One row per app with merged signals, actionability tier, owner/environment hints, and anomaly flags.
                    </RadzenText>
                    <div class="app-table-frame">
                    <RadzenDataGrid Data="@consolidatedServices" TItem="ConsolidatedService" AllowFiltering="true" AllowSorting="true"
                                    AllowPaging="true" PageSize="15" ShowPagingSummary="true" FilterMode="FilterMode.Simple">
                        <Columns>
                            <RadzenDataGridColumn TItem="ConsolidatedService" Property="DisplayName" Title="App" Width="180px" />
                            <RadzenDataGridColumn TItem="ConsolidatedService" Property="Owner" Title="Owner" Width="110px" />
                            <RadzenDataGridColumn TItem="ConsolidatedService" Property="Environment" Title="Env" Width="90px">
                                <Template Context="c">
                                    <RadzenBadge Text="@c.Environment" IsPill="true" BadgeStyle="@(c.Environment == "prod" ? BadgeStyle.Danger : c.Environment == "dev" ? BadgeStyle.Warning : BadgeStyle.Info)" />
                                </Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="ConsolidatedService" Property="ResourceTypeSummary" Title="Platform" Width="170px" />
                            <RadzenDataGridColumn TItem="ConsolidatedService" Property="HealthScore" Title="Health" Width="85px">
                                <Template Context="c">
                                    <RadzenBadge Text="@c.HealthScore.ToString()" IsPill="true" BadgeStyle="@(c.HealthScore < 50 ? BadgeStyle.Danger : c.HealthScore < 75 ? BadgeStyle.Warning : BadgeStyle.Success)" />
                                </Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="ConsolidatedService" Property="ReliabilityScore" Title="Reliability" Width="95px">
                                <Template Context="c">
                                    <span class="@ReliabilityClass(c.ReliabilityScore)">@c.ReliabilityScore%</span>
                                </Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="ConsolidatedService" Property="Requests7d" Title="7d Req" Width="85px" />
                            <RadzenDataGridColumn TItem="ConsolidatedService" Property="Http5xx7d" Title="7d 5xx" Width="85px" />
                            <RadzenDataGridColumn TItem="ConsolidatedService" Property="Actionability" Title="Action" Width="110px">
                                <Template Context="c">
                                    <RadzenBadge Text="@c.Actionability" IsPill="true" BadgeStyle="@ActionabilityBadge(c.Actionability)" />
                                </Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="ConsolidatedService" Title="Anomaly" Width="120px" Sortable="false" Filterable="false">
                                <Template Context="c">
                                    @if (c.HasAnomaly)
                                    {
                                        <RadzenBadge Text="Deviation" BadgeStyle="BadgeStyle.Warning" IsPill="true" />
                                    }
                                    else
                                    {
                                        <span class="app-dash">—</span>
                                    }
                                </Template>
                            </RadzenDataGridColumn>
                        </Columns>
                    </RadzenDataGrid>
                    </div>

                    <RadzenRow class="rz-mt-3">
                        <RadzenColumn SizeXS="12" SizeMD="6">
                            <RadzenText TextStyle="TextStyle.H6" class="rz-mb-1">Portfolio by Environment</RadzenText>
                            <div class="app-table-frame">
                            <RadzenDataGrid Data="@PortfolioByEnvironment" TItem="PortfolioRollup" AllowPaging="false" AllowSorting="true">
                                <Columns>
                                    <RadzenDataGridColumn TItem="PortfolioRollup" Property="Dimension" Title="Environment" />
                                    <RadzenDataGridColumn TItem="PortfolioRollup" Property="Apps" Title="Apps" Width="80px" />
                                    <RadzenDataGridColumn TItem="PortfolioRollup" Property="Broken" Title="Broken" Width="80px" />
                                    <RadzenDataGridColumn TItem="PortfolioRollup" Property="AvgHealth" Title="Avg Health" Width="110px" />
                                </Columns>
                            </RadzenDataGrid>
                            </div>
                        </RadzenColumn>
                        <RadzenColumn SizeXS="12" SizeMD="6">
                            <RadzenText TextStyle="TextStyle.H6" class="rz-mb-1">Portfolio by Platform</RadzenText>
                            <div class="app-table-frame">
                            <RadzenDataGrid Data="@PortfolioByPlatform" TItem="PortfolioRollup" AllowPaging="false" AllowSorting="true">
                                <Columns>
                                    <RadzenDataGridColumn TItem="PortfolioRollup" Property="Dimension" Title="Platform" />
                                    <RadzenDataGridColumn TItem="PortfolioRollup" Property="Apps" Title="Apps" Width="80px" />
                                    <RadzenDataGridColumn TItem="PortfolioRollup" Property="Broken" Title="Broken" Width="80px" />
                                    <RadzenDataGridColumn TItem="PortfolioRollup" Property="AvgHealth" Title="Avg Health" Width="110px" />
                                </Columns>
                            </RadzenDataGrid>
                            </div>
                        </RadzenColumn>
                    </RadzenRow>
                </div>
            </RadzenTabsItem>

            <!-- ── Tab 2: Priority Queue ── -->
            <RadzenTabsItem Text="@($"🎯 Priority Queue ({priorityQueue.Count})")">
                <div class="app-tab-pane rz-mt-2">
                    <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary rz-mb-2">
                        Unified action queue across reliability, deletion candidates, SSL risk, and orphaned resources.
                    </RadzenText>
                    <div class="app-table-frame">
                    <RadzenDataGrid Data="@priorityQueue" TItem="PriorityQueueItem" AllowSorting="true" AllowFiltering="true"
                                    AllowPaging="true" PageSize="20" FilterMode="FilterMode.Simple">
                        <Columns>
                            <RadzenDataGridColumn TItem="PriorityQueueItem" Property="Actionability" Title="Tier" Width="105px">
                                <Template Context="p"><RadzenBadge Text="@p.Actionability" IsPill="true" BadgeStyle="@ActionabilityBadge(p.Actionability)" /></Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="PriorityQueueItem" Property="Item" Title="Item" Width="220px" />
                            <RadzenDataGridColumn TItem="PriorityQueueItem" Property="Source" Title="Source" Width="140px" />
                            <RadzenDataGridColumn TItem="PriorityQueueItem" Property="ImpactScore" Title="Impact" Width="80px" />
                            <RadzenDataGridColumn TItem="PriorityQueueItem" Property="Confidence" Title="Confidence" Width="95px" />
                            <RadzenDataGridColumn TItem="PriorityQueueItem" Property="Reason" Title="Reason" />
                            <RadzenDataGridColumn TItem="PriorityQueueItem" Property="Owner" Title="Owner" Width="110px" />
                            <RadzenDataGridColumn TItem="PriorityQueueItem" Property="Environment" Title="Env" Width="90px" />
                            <RadzenDataGridColumn TItem="PriorityQueueItem" Title="Command" Width="110px" Sortable="false" Filterable="false">
                                <Template Context="p">
                                    @if (!string.IsNullOrWhiteSpace(p.Command))
                                    {
                                        <RadzenButton Text="Copy" Icon="content_copy" Size="ButtonSize.ExtraSmall" Variant="Variant.Outlined"
                                                      Click="@(() => CopyToClipboard(p.Command!))" />
                                    }
                                </Template>
                            </RadzenDataGridColumn>
                        </Columns>
                    </RadzenDataGrid>
                    </div>
                </div>
            </RadzenTabsItem>

            <!-- ── Tab 3: Web Services ── -->
            <RadzenTabsItem Text="@($"🌐 Web Services ({currentReport.WebServices?.Total ?? 0})")">
                <div class="app-tab-pane">
                <div class="app-table-frame">
                <RadzenDataGrid Data="@SortedServices" TItem="WebService" AllowFiltering="true" AllowSorting="true"
                                AllowPaging="true" PageSize="15" ShowPagingSummary="true" AllowColumnResize="true" FilterMode="FilterMode.Simple">
                    <Columns>
                        <RadzenDataGridColumn TItem="WebService" Property="FriendlyName" Title="Name" Width="160px">
                            <Template Context="s">
                                <strong>@(string.IsNullOrEmpty(s.FriendlyName) ? s.Name : s.FriendlyName)</strong>
                                <br /><small class="app-meta-line">@s.ResourceGroup</small>
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="WebService" Property="ResourceType" Title="Type" Width="130px">
                            <Template Context="s">
                                <RadzenBadge Text="@TypeLabel(s.ResourceType)" BadgeStyle="BadgeStyle.Info" IsPill="true" class="app-badge-xs" />
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="WebService" Property="Url" Title="URL" Width="220px">
                            <Template Context="s">
                                @if (!string.IsNullOrEmpty(s.Url))
                                {
                                    <a href="@s.Url" target="_blank" rel="noopener noreferrer" class="app-inline-link app-link-break">@s.Url</a>
                                }
                                else { <span class="app-dash">—</span> }
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="WebService" Property="HttpStatus" Title="HTTP" Width="110px">
                            <Template Context="s">
                                <RadzenBadge Text="@s.HttpStatus" IsPill="true"
                                             BadgeStyle="@HttpBadgeStyle(s.HttpStatus)" />
                                @if (s.Connectivity?.IsAzureErrorPage == true)
                                { <RadzenBadge Text="AZ-page" BadgeStyle="BadgeStyle.Danger" IsPill="true" class="app-badge-xs" /> }
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="WebService" Property="PlatformState" Title="Platform" Width="100px">
                            <Template Context="s">
                                <RadzenBadge Text="@(s.PlatformState ?? "—")" IsPill="true"
                                             BadgeStyle="@(s.PlatformState=="Running" ? BadgeStyle.Success : BadgeStyle.Warning)" />
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="WebService" Title="7d Req" Width="80px">
                            <Template Context="s">
                                @if (s.Metrics7Days?.Requests == 0)
                                { <span class="app-tone-warning">0 ⚠</span> }
                                else { @(s.Metrics7Days?.Requests.ToString() ?? "—") }
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="WebService" Title="7d 5xx" Width="75px">
                            <Template Context="s">
                                @if (s.Metrics7Days?.Http5xx > 0)
                                { <span class="app-tone-danger">@s.Metrics7Days.Http5xx</span> }
                                else { @(s.Metrics7Days != null ? "0" : "—") }
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="WebService" Title="RT ms" Width="80px">
                            <Template Context="s">
                                @if (s.Connectivity?.Success == true)
                                {
                                    <span class="@ResponseTimeClass(s.Connectivity.ResponseTime)" title="@s.Connectivity.ResponseTime ms">@s.Connectivity.ResponseTime ms</span>
                                }
                                else if (s.Connectivity?.Error != null && (s.Connectivity.Error.Contains("canceled") || s.Connectivity.Error.Contains("Timeout") || s.Connectivity.Error.Contains("timed out")))
                                { <RadzenBadge Text="Timeout" BadgeStyle="BadgeStyle.Danger" IsPill="true" class="app-badge-xs" /> }
                                else if (s.Connectivity?.Error != null)
                                { <span class="app-tone-danger" title="@s.Connectivity.Error">Err ⚠</span> }
                                else { <span class="app-dash">—</span> }
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="WebService" Title="Free Tier" Width="120px">
                            <Template Context="s">
                                @if (s.FreeTierCheck?.IsOnFreeTier == true)
                                { <RadzenBadge Text="Free ✓" BadgeStyle="BadgeStyle.Success" IsPill="true" class="app-badge-xs" /> }
                                else if (s.FreeTierCheck?.CanGoFree == true)
                                { <RadzenBadge Text="Can go free" BadgeStyle="BadgeStyle.Warning" IsPill="true" class="app-badge-xs" /> }
                                else
                                { <RadzenBadge Text="Paid" BadgeStyle="BadgeStyle.Light" IsPill="true" class="app-badge-xs" /> }
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="WebService" Title="Fix Plan" Width="110px" Sortable="false" Filterable="false">
                            <Template Context="s">
                                @{
                                    var isUnhealthy = s.HttpStatus is "broken" or "unreachable"
                                        || s.Connectivity?.IsAzureErrorPage == true
                                        || s.Metrics7Days?.Http5xx > 0;
                                }
                                @if (isUnhealthy)
                                {
                                    <RadzenButton Text="Fix Plan" Icon="healing" Size="ButtonSize.ExtraSmall"
                                                  ButtonStyle="ButtonStyle.Warning" Variant="Variant.Outlined"
                                                  Click="@(() => OpenFixPlan(s))" />
                                }
                                else
                                { <span class="app-dash">—</span> }
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
                </div>

                <!-- ── Fix Plan Panel ── -->
                @if (_fixPlanService is not null)
                {
                    <div class="app-detail-panel warning">
                        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center" class="rz-mb-2">
                            <RadzenText TextStyle="TextStyle.H6" class="rz-m-0">
                                🔧 Fix Plan — <strong>@(_fixPlanService.FriendlyName ?? _fixPlanService.Name)</strong>
                            </RadzenText>
                            <RadzenButton Icon="close" Size="ButtonSize.ExtraSmall" Variant="Variant.Text"
                                          Click="@(() => { _fixPlanService = null; _fixPlanText = null; _fixPlanLoading = false; _fixPlanError = null; })" />
                        </RadzenStack>
                        @if (_fixPlanLoading)
                        {
                            <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" Style="height:6px" />
                            <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary rz-mt-1">Analysing with AI…</RadzenText>
                        }
                        else if (_fixPlanError is not null)
                        {
                            <RadzenAlert AlertStyle="AlertStyle.Warning" Variant="Variant.Outlined" ShowIcon="true">@_fixPlanError</RadzenAlert>
                        }
                        else if (_fixPlanDisabledMessage is not null)
                        {
                            <RadzenAlert AlertStyle="AlertStyle.Info" Variant="Variant.Outlined" ShowIcon="true">@_fixPlanDisabledMessage</RadzenAlert>
                        }
                        else if (_fixPlanText is not null)
                        {
                            <div style="white-space:pre-wrap;font-size:.85rem;line-height:1.7;color:var(--rz-text-color)">@_fixPlanText</div>
                        }
                    </div>
                }
                </div>
            </RadzenTabsItem>

            <!-- ── Tab 2: Safe to Remove ── -->
            <RadzenTabsItem Text="@($"🗑 Safe to Remove ({safeToRemove.Count})")">
                <div class="app-tab-pane rz-mt-2">
                @if (!safeToRemove.Any())
                {
                    <div class="app-callout success">
                        ✅ No resources flagged as safe to remove. Your subscription looks clean.
                    </div>
                }
                else
                {
                    <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary rz-mb-3">
                        Resources identified as unused or cost-waste. Verify before running any commands.
                    </RadzenText>
                    <div class="app-table-frame">
                    <RadzenDataGrid Data="@safeToRemove" TItem="SafeToRemoveItem" AllowSorting="true" AllowPaging="true" PageSize="15">
                        <Columns>
                            <RadzenDataGridColumn TItem="SafeToRemoveItem" Property="Name" Title="Resource" Width="200px" />
                            <RadzenDataGridColumn TItem="SafeToRemoveItem" Property="Confidence" Title="Confidence" Width="110px">
                                <Template Context="i">
                                    <RadzenBadge Text="@i.Confidence.ToUpper()" IsPill="true"
                                                 BadgeStyle="@(i.Confidence=="high" ? BadgeStyle.Danger : i.Confidence=="medium" ? BadgeStyle.Warning : BadgeStyle.Light)" />
                                </Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="SafeToRemoveItem" Property="Source" Title="Source" Width="160px">
                                <Template Context="i"><small class="app-meta-line">@i.Source</small></Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="SafeToRemoveItem" Property="Reason" Title="Reason" />
                            <RadzenDataGridColumn TItem="SafeToRemoveItem" Property="Saving" Title="Saving" Width="110px">
                                <Template Context="i">
                                    @if (!string.IsNullOrEmpty(i.Saving))
                                    { <span class="app-tone-success">💰 @i.Saving</span> }
                                </Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="SafeToRemoveItem" Property="Command" Title="CLI Command" Sortable="false">
                                <Template Context="i">
                                    @if (!string.IsNullOrEmpty(i.Command))
                                    {
                                        <RadzenButton Text="Copy" Icon="content_copy" Size="ButtonSize.ExtraSmall" Variant="Variant.Outlined"
                                                      Click="@(() => CopyToClipboard(i.Command))" />
                                        <br /><small class="app-command-preview">@i.Command[..Math.Min(60,i.Command.Length)]@(i.Command.Length>60?"…":"")</small>
                                    }
                                    else { <span class="app-dash">Check Azure Portal</span> }
                                </Template>
                            </RadzenDataGridColumn>
                        </Columns>
                    </RadzenDataGrid>
                    </div>
                }
                </div>
            </RadzenTabsItem>

            <!-- ── Tab 3: Cost ── -->
            <RadzenTabsItem Text="@($"💳 Cost ({currentReport.Cost?.TotalFormatted ?? "$0"})")">
                <div class="app-tab-pane rz-mt-2">
                @if (currentReport.Cost?.Note != null)
                {
                    <div class="app-callout warning">
                        📝 @currentReport.Cost.Note
                    </div>
                }
                @if (currentReport.BurnRate?.DailyCosts.Count > 0)
                {
                    <RadzenRow class="rz-mb-4">
                        <RadzenColumn SizeXS="12" SizeMD="7">
                            <RadzenText TextStyle="TextStyle.H6" class="rz-mb-1">
                                Monthly Burn Rate
                                <RadzenBadge Text="@($"Projected: {currentReport.BurnRate?.ProjectedFormatted ?? "—"}")" BadgeStyle="BadgeStyle.Warning" IsPill="true" class="app-badge-xs" />
                            </RadzenText>
                            <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary rz-mb-1">Based on daily spend this calendar month only — not rolling 30d</RadzenText>
                            <RadzenChart Style="height:280px">
                                <RadzenLineSeries TItem="DailyCostChartPoint" Data="@BurnRateChartData" CategoryProperty="Date" ValueProperty="Cost" Title="Daily ($)" Smooth="true">
                                    <RadzenMarkers MarkerType="MarkerType.Circle" Size="4" />
                                </RadzenLineSeries>
                                <RadzenCategoryAxis Step="@BurnRateLabelStep" />
                                <RadzenValueAxis FormatString="${0:F2}">
                                    <RadzenGridLines Visible="true" />
                                </RadzenValueAxis>
                                <RadzenLegend Visible="false" />
                            </RadzenChart>
                        </RadzenColumn>
                        <RadzenColumn SizeXS="12" SizeMD="5">
                            <RadzenText TextStyle="TextStyle.H6" class="rz-mb-1">Cost by Resource Group (30d)</RadzenText>
                            <RadzenChart Style="height:260px">
                                <RadzenBarSeries TItem="ChartPoint" Data="@CostByRgData" CategoryProperty="Label" ValueProperty="Value" Title="Cost ($)">
                                    <RadzenSeriesDataLabels Visible="false" />
                                </RadzenBarSeries>
                                <RadzenValueAxis FormatString="${0:F2}">
                                    <RadzenGridLines Visible="true" />
                                </RadzenValueAxis>
                                <RadzenLegend Visible="false" />
                            </RadzenChart>
                        </RadzenColumn>
                    </RadzenRow>
                }
                <div class="app-table-frame">
                <RadzenDataGrid Data="@currentReport.Cost?.TopCostDrivers" TItem="CostDriver" AllowSorting="true" PageSize="30" AllowPaging="false">
                    <Columns>
                        <RadzenDataGridColumn TItem="CostDriver" Property="Name" Title="Service / Resource Group" />
                        <RadzenDataGridColumn TItem="CostDriver" Property="Cost" Title="Cost (USD)" Width="130px" TextAlign="TextAlign.Right">
                            <Template Context="d">
                                <span class="@(d.Cost > 0 ? "app-tone-warning" : "app-tone-muted")">
                                    $@d.Cost.ToString("F2")
                                </span>
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
                </div>
                <RadzenCard class="app-detail-panel rz-mt-3 app-text-right">
                    <RadzenText TextStyle="TextStyle.H6">Total: <span class="app-tone-warning">@(currentReport.Cost?.TotalFormatted ?? "—")</span></RadzenText>
                </RadzenCard>
                </div>
            </RadzenTabsItem>

            <!-- ── SSL Expiry Tab ── -->
            <RadzenTabsItem Text="@($"🔒 SSL ({currentReport.SslExpiry?.Count ?? 0})")">
                <div class="app-tab-pane rz-mt-2">
                @{
                    var sslCritical  = currentReport.SslExpiry?.Count(x => x.DaysLeft is { } d && d < 14) ?? 0;
                    var sslWarning   = currentReport.SslExpiry?.Count(x => x.DaysLeft is { } d && d is >= 14 and < 60) ?? 0;
                    var sslErrored   = currentReport.SslExpiry?.Count(x => x.Error != null && x.DaysLeft == null) ?? 0;
                    var sslOk        = currentReport.SslExpiry?.Count(x => x.DaysLeft != null) ?? 0;
                }
                @if (sslErrored > 0 && sslOk == 0)
                {
                    <div class="app-callout warning">
                        ⚠️ SSL checks ran but all <strong>@sslErrored</strong> entries returned errors. Hit <strong>Refresh from Azure</strong> to re-check.
                    </div>
                }
                else if (sslCritical > 0)
                {
                    <div class="app-callout danger">
                        ⚠️ <strong>@sslCritical certificate(s)</strong> expire in fewer than 14 days — renew immediately!
                    </div>
                }
                else if (sslWarning > 0)
                {
                    <div class="app-callout warning">
                        🟡 @sslWarning certificate(s) expire within 60 days — schedule renewal soon.
                    </div>
                }
                <div class="app-table-frame">
                <RadzenDataGrid Data="@currentReport.SslExpiry" TItem="SslEntry" AllowSorting="true" AllowFiltering="true"
                                FilterMode="FilterMode.Simple" AllowPaging="true" PageSize="20">
                    <Columns>
                        <RadzenDataGridColumn TItem="SslEntry" Property="Name" Title="Service" Width="180px" />
                        <RadzenDataGridColumn TItem="SslEntry" Property="Url" Title="URL" Width="230px">
                            <Template Context="s">
                                @if (!string.IsNullOrEmpty(s.Url))
                                { <a href="@s.Url" target="_blank" rel="noopener noreferrer" class="app-inline-link app-link-break">@s.Url</a> }
                                else { <span class="app-dash">—</span> }
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="SslEntry" Property="DaysLeft" Title="Days Left" Width="110px">
                            <Template Context="s">
                                @if (s.DaysLeft is { } d)
                                {
                                    <RadzenBadge Text="@($"{d}d")" IsPill="true"
                                                 BadgeStyle="@(d < 14 ? BadgeStyle.Danger : d < 60 ? BadgeStyle.Warning : BadgeStyle.Success)" />
                                }
                                else if (!string.IsNullOrEmpty(s.Error))
                                { <RadzenBadge Text="Error" BadgeStyle="BadgeStyle.Warning" IsPill="true" class="app-badge-xs" /> }
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="SslEntry" Property="Error" Title="Error" Width="160px">
                            <Template Context="s">
                                @if (!string.IsNullOrEmpty(s.Error))
                                { <span class="app-tone-warning" title="@s.Error">@(s.Error.Length > 40 ? s.Error.Substring(0, 40) + "…" : s.Error)</span> }
                                else { <span class="app-dash">—</span> }
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="SslEntry" Property="Expiry" Title="Expires" Width="115px" />
                        <RadzenDataGridColumn TItem="SslEntry" Property="Subject" Title="Subject">
                            <Template Context="s">
                                @if (s.Subject?.Contains("*.azurewebsites.net") == true || s.Subject?.Contains("*.azurefd.net") == true || s.Subject?.Contains("*.trafficmanager.net") == true)
                                { <RadzenBadge Text="Azure Managed" BadgeStyle="BadgeStyle.Light" IsPill="true" class="app-badge-xs" /> }
                                else { <span class="app-meta-line">@(s.Subject ?? "—")</span> }
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
                </div>
                </div>
            </RadzenTabsItem>

            <!-- ── App Insights Tab ── -->
            <RadzenTabsItem Text="@($"📊 App Insights ({currentReport.AppInsightsMetrics?.Count ?? 0})")">
                <div class="app-tab-pane rz-mt-2">
                @if (currentReport.AppInsightsMetrics?.Any() != true)
                {
                    <div class="app-callout info">
                        ℹ️ No Application Insights components found, or metrics could not be retrieved.
                    </div>
                }
                else
                {
                    <div class="app-table-frame">
                    <RadzenDataGrid Data="@currentReport.AppInsightsMetrics" TItem="AppInsightsMetric"
                                    AllowSorting="true" AllowFiltering="true" FilterMode="FilterMode.Simple"
                                    AllowPaging="true" PageSize="20">
                        <Columns>
                            <RadzenDataGridColumn TItem="AppInsightsMetric" Property="Name" Title="Component" Width="210px" />
                            <RadzenDataGridColumn TItem="AppInsightsMetric" Property="ResourceGroup" Title="Resource Group" Width="160px" />
                            <RadzenDataGridColumn TItem="AppInsightsMetric" Property="Requests7Days" Title="7d Requests" Width="120px" TextAlign="TextAlign.Right">
                                <Template Context="m">
                                    @if (m.Requests7Days == 0) { <span class="app-tone-warning">0 ⚠</span> }
                                    else { <span>@(m.Requests7Days?.ToString() ?? "—")</span> }
                                </Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="AppInsightsMetric" Property="FailedRequests7Days" Title="7d Failed" Width="105px" TextAlign="TextAlign.Right">
                                <Template Context="m">
                                    @if (m.FailedRequests7Days > 0) { <span class="app-tone-danger">@m.FailedRequests7Days</span> }
                                    else { <span class="app-tone-success">@(m.FailedRequests7Days?.ToString() ?? "—")</span> }
                                </Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="AppInsightsMetric" Property="Exceptions7Days" Title="7d Exceptions" Width="125px" TextAlign="TextAlign.Right">
                                <Template Context="m">
                                    @if (m.Exceptions7Days > 0) { <span class="app-tone-warning">⚠ @m.Exceptions7Days</span> }
                                    else { <span>@(m.Exceptions7Days?.ToString() ?? "—")</span> }
                                </Template>
                            </RadzenDataGridColumn>
                        </Columns>
                    </RadzenDataGrid>
                    </div>
                }
                </div>
            </RadzenTabsItem>

            <!-- ── Resource Breakdown Tab ── -->
            <RadzenTabsItem Text="@($"📦 Resources ({currentReport.AllResourceSummary?.Total ?? 0})")">
                <div class="app-tab-pane rz-mt-2">
                <RadzenRow>
                    <RadzenColumn SizeXS="12" SizeMD="6">
                        <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">Top 10 Resource Types <small class="app-meta-line">(click a row to drill in)</small></RadzenText>
                        <RadzenChart Style="height:340px">
                            <RadzenDonutSeries TItem="ChartPoint" Data="@ResourceTypeChartData" CategoryProperty="Label" ValueProperty="Value" InnerRadius="70" />
                            <RadzenLegend Position="LegendPosition.Bottom" />
                        </RadzenChart>
                    </RadzenColumn>
                    <RadzenColumn SizeXS="12" SizeMD="6">
                        <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">All Resource Types</RadzenText>
                        <div class="app-scroll-panel">
                        <RadzenDataGrid Data="@ResourceTypeTableData" TItem="ChartPoint" AllowSorting="true" PageSize="50" AllowPaging="false" RowClick="@(args => SelectResourceType(args.Data?.Label ?? ""))">
                            <Columns>
                                <RadzenDataGridColumn TItem="ChartPoint" Property="Label" Title="Type">
                                    <Template Context="p">
                                        <span class="@(_selectedResourceType == p.Label ? "app-row-link" : string.Empty)">@p.Label</span>
                                    </Template>
                                </RadzenDataGridColumn>
                                <RadzenDataGridColumn TItem="ChartPoint" Property="Value" Title="Count" Width="90px" TextAlign="TextAlign.Right">
                                    <Template Context="p"><strong>@((int)p.Value)</strong></Template>
                                </RadzenDataGridColumn>
                            </Columns>
                        </RadzenDataGrid>
                        </div>
                    </RadzenColumn>
                </RadzenRow>
                @if (_selectedResourceType is not null && _selectedResourceDetails is not null)
                {
                    <div class="app-detail-panel soft">
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="12px" class="rz-mb-2">
                            <RadzenText TextStyle="TextStyle.H6" class="rz-m-0">
                                🔍 <strong>@_selectedResourceType</strong>
                                <RadzenBadge Text="@_selectedResourceDetails.Count.ToString()" BadgeStyle="BadgeStyle.Info" IsPill="true" class="app-badge-xs" />
                            </RadzenText>
                            <RadzenButton Text="Clear" Icon="close" Size="ButtonSize.ExtraSmall" Variant="Variant.Outlined"
                                          Click="@(() => { _selectedResourceType = null; _selectedResourceDetails = null; })" />
                        </RadzenStack>
                        <RadzenDataGrid Data="@_selectedResourceDetails" TItem="ResourceDetail"
                                        AllowSorting="true" AllowFiltering="true" FilterMode="FilterMode.Simple" AllowPaging="true" PageSize="15">
                            <Columns>
                                <RadzenDataGridColumn TItem="ResourceDetail" Property="Name" Title="Name" Width="230px" />
                                <RadzenDataGridColumn TItem="ResourceDetail" Property="ResourceGroup" Title="Resource Group" Width="180px" />
                                <RadzenDataGridColumn TItem="ResourceDetail" Property="Location" Title="Location" Width="130px" />
                                <RadzenDataGridColumn TItem="ResourceDetail" Property="Sku" Title="SKU" Width="110px">
                                    <Template Context="r">
                                        @if (!string.IsNullOrEmpty(r.Sku))
                                        { <RadzenBadge Text="@r.Sku" BadgeStyle="BadgeStyle.Light" IsPill="true" class="app-badge-xs" /> }
                                        else { <span class="app-dash">—</span> }
                                    </Template>
                                </RadzenDataGridColumn>
                            </Columns>
                        </RadzenDataGrid>
                    </div>
                }
                </div>
            </RadzenTabsItem>

            <!-- ── Orphaned Resources Tab ── -->
            <RadzenTabsItem Text="@($"🧟 Orphaned ({currentReport.OrphanedResources?.Count ?? 0})")">
                <div class="app-tab-pane rz-mt-2">
                @if (currentReport.OrphanedResources?.Any() != true)
                {
                    <div class="app-callout success">
                        ✅ No orphaned resources — no unattached disks, idle public IPs, or empty App Service Plans.
                    </div>
                }
                else
                {
                    <div class="app-table-frame">
                    <RadzenDataGrid Data="@currentReport.OrphanedResources" TItem="OrphanedResource" AllowSorting="true" AllowPaging="true" PageSize="15">
                        <Columns>
                            <RadzenDataGridColumn TItem="OrphanedResource" Property="Name" Title="Resource" Width="200px" />
                            <RadzenDataGridColumn TItem="OrphanedResource" Property="ResourceGroup" Title="Resource Group" Width="160px" />
                            <RadzenDataGridColumn TItem="OrphanedResource" Property="Type" Title="Type" Width="150px">
                                <Template Context="o"><RadzenBadge Text="@o.Type" BadgeStyle="BadgeStyle.Info" IsPill="true" class="app-badge-xs" /></Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="OrphanedResource" Property="Reason" Title="Reason" />
                            <RadzenDataGridColumn TItem="OrphanedResource" Property="EstimatedMonthlyCost" Title="Est. Cost/mo" Width="130px">
                                <Template Context="o">
                                    @if (!string.IsNullOrEmpty(o.EstimatedMonthlyCost))
                                    { <span class="app-tone-warning">💰 @o.EstimatedMonthlyCost</span> }
                                </Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="OrphanedResource" Property="Command" Title="CLI Command" Sortable="false">
                                <Template Context="o">
                                    @if (!string.IsNullOrEmpty(o.Command))
                                    {
                                        <RadzenButton Text="Copy" Icon="content_copy" Size="ButtonSize.ExtraSmall" Variant="Variant.Outlined"
                                                      Click="@(() => CopyToClipboard(o.Command!))" />
                                        <br /><small class="app-command-preview">@o.Command[..Math.Min(60, o.Command.Length)]@(o.Command.Length > 60 ? "…" : "")</small>
                                    }
                                </Template>
                            </RadzenDataGridColumn>
                        </Columns>
                    </RadzenDataGrid>
                    </div>
                }
                </div>
            </RadzenTabsItem>

            <!-- ── Storage Tab ── -->
            <RadzenTabsItem Text="@($"💾 Storage ({currentReport.StorageInventory?.Count ?? 0})")">
                <div class="app-tab-pane rz-mt-2">
                <div class="app-table-frame">
                <RadzenDataGrid Data="@currentReport.StorageInventory" TItem="StorageItem" AllowFiltering="true" AllowSorting="true" PageSize="15" AllowPaging="true" FilterMode="FilterMode.Simple">
                    <Columns>
                        <RadzenDataGridColumn TItem="StorageItem" Property="Name" Title="Account" Width="180px" />
                        <RadzenDataGridColumn TItem="StorageItem" Property="ResourceGroup" Title="Resource Group" Width="160px" />
                        <RadzenDataGridColumn TItem="StorageItem" Property="Sku" Title="SKU" Width="120px" />
                        <RadzenDataGridColumn TItem="StorageItem" Property="PublicBlobAccess" Title="Public Blobs" Width="120px">
                            <Template Context="s">
                                <RadzenBadge Text="@(s.PublicBlobAccess ? "Public ⚠" : "Private ✓")" IsPill="true"
                                             BadgeStyle="@(s.PublicBlobAccess ? BadgeStyle.Danger : BadgeStyle.Success)" />
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="StorageItem" Property="HttpsOnly" Title="HTTPS Only" Width="110px">
                            <Template Context="s">
                                <RadzenBadge Text="@(s.HttpsOnly ? "Yes" : "No ⚠")" IsPill="true"
                                             BadgeStyle="@(s.HttpsOnly ? BadgeStyle.Success : BadgeStyle.Danger)" />
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="StorageItem" Property="MinTls" Title="Min TLS" Width="90px" />
                        <RadzenDataGridColumn TItem="StorageItem" Property="IssueCount" Title="Issues" Width="80px">
                            <Template Context="s">
                                <RadzenBadge Text="@s.IssueCount.ToString()" IsPill="true"
                                             BadgeStyle="@(s.IssueCount > 0 ? BadgeStyle.Warning : BadgeStyle.Success)" />
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="StorageItem" Title="Issue Detail">
                            <Template Context="s">
                                @if (s.Issues?.Any() == true)
                                { @foreach (var issue in s.Issues) { <div class="app-issue-line">@issue.Issue</div> } }
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
                </div>
                </div>
            </RadzenTabsItem>

            <!-- ── Tab: CI/CD Review ── -->
            <RadzenTabsItem Text="@($"🔧 CI/CD Review ({_infraReviews.Count})")">
                <div class="app-tab-pane rz-mt-2">

                @if (_infraDisabledMessage is not null)
                {
                    <RadzenAlert AlertStyle="AlertStyle.Info" Variant="Variant.Outlined" ShowIcon="true" class="rz-mb-3">
                        <strong>GitHub PAT not configured.</strong>
                        <div class="rz-mt-1">@_infraDisabledMessage</div>
                        <div class="app-meta-line rz-mt-2">
                            Key Vault secret name: <code>PoPunkouterSoftware--GitHub--PersonalAccessToken</code>
                        </div>
                    </RadzenAlert>
                }

                @if (_infraReviews.Count == 0 && _infraDisabledMessage is null)
                {
                    <div class="app-callout info app-text-right" style="text-align:center">
                        <div class="rz-mb-2" style="font-size:1.75rem">🔍</div>
                        <RadzenText TextStyle="TextStyle.Body1" class="rz-mb-2">
                            Scan all GitHub repositories under <strong>punkouter26</strong> for CI/CD workflows and
                            infrastructure files (Bicep, ARM, Docker, Azure Developer CLI).
                        </RadzenText>
                        <RadzenButton Text="@(_infraLoading ? "Scanning repos…" : "Scan All Repos")"
                                      Icon="@(_infraLoading ? "sync" : "search")"
                                      ButtonStyle="ButtonStyle.Primary"
                                      Disabled="@_infraLoading"
                                      Click="@LoadInfraReviewAsync" />
                        @if (_infraLoading)
                        {
                            <div class="rz-mt-2">
                                <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" Style="height:6px" />
                                <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary rz-mt-1">
                                    Fetching repo trees and file contents from GitHub API…
                                </RadzenText>
                            </div>
                        }
                        @if (_infraError is not null)
                        {
                            <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Outlined" ShowIcon="true" class="rz-mt-3">
                                @_infraError
                            </RadzenAlert>
                        }
                    </div>
                }
                else if (_infraReviews.Count > 0)
                {
                    // ── Summary strip ────────────────────────────────────────
                    var reposWithCicd   = _infraReviews.Count(r => r.CiCdFiles.Count > 0);
                    var reposWithBicep  = _infraReviews.Count(r => r.InfraFiles.Any(f => f.FileType == "bicep"));
                    var reposWithDocker = _infraReviews.Count(r => r.InfraFiles.Any(f => f.FileType is "docker" or "compose"));
                    var reposWithErrors = _infraReviews.Count(r => r.Error is not null);
                    <div class="app-grid" style="grid-template-columns:repeat(auto-fit,minmax(130px,1fr));margin-bottom:1.25rem">
                        @InfraSummaryCard(_infraReviews.Count.ToString(), "Repos Scanned", "var(--rz-info)")
                        @InfraSummaryCard(reposWithCicd.ToString(), "With CI/CD", "var(--rz-primary)")
                        @InfraSummaryCard(reposWithBicep.ToString(), "Using Bicep", "var(--rz-success)")
                        @InfraSummaryCard(reposWithDocker.ToString(), "Docker", "var(--rz-warning)")
                        @InfraSummaryCard(reposWithErrors.ToString(), "Scan Errors", reposWithErrors > 0 ? "var(--rz-danger)" : "var(--rz-secondary)")
                    </div>

                    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center" class="rz-mb-2" Wrap="FlexWrap.Wrap" Gap="8px">
                        <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary">
                            Scanned at @(_infraReviews.FirstOrDefault()?.ScannedAt.ToString("yyyy-MM-dd HH:mm") ?? "—") UTC
                            &nbsp;·&nbsp; Click a row to expand CI/CD + infra file details
                        </RadzenText>
                        <RadzenButton Text="Re-scan" Icon="refresh" Size="ButtonSize.Small"
                                      ButtonStyle="ButtonStyle.Light" Variant="Variant.Outlined"
                                      Disabled="@_infraLoading" Click="@RescanInfraAsync" />
                    </RadzenStack>

                    <!-- ── Comparison table ── -->
                    <RadzenDataGrid Data="@_infraReviews" TItem="InfraReview"
                                    AllowSorting="true" AllowFiltering="true" FilterMode="FilterMode.Simple"
                                    AllowPaging="true" PageSize="20"
                                    RowClick="@(args => { if (args.Data is not null) ToggleInfraDetail(args.Data); })"
                                    class="app-clickable-grid">
                        <Columns>
                            <RadzenDataGridColumn TItem="InfraReview" Property="RepoName" Title="Repository" Width="200px">
                                <Template Context="r">
                                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="6px">
                                        @if (!string.IsNullOrEmpty(r.RepoUrl))
                                        {
                                            <a href="@r.RepoUrl" target="_blank" rel="noopener noreferrer" class="app-row-link" @onclick:stopPropagation="true">@r.RepoName</a>
                                        }
                                        else { <strong class="app-row-link">@r.RepoName</strong> }
                                        @if (r.IsPrivate)
                                        { <RadzenBadge Text="private" BadgeStyle="BadgeStyle.Light" IsPill="true" class="app-badge-2xs" /> }
                                    </RadzenStack>
                                    @if (r.AppName is not null)
                                    { <div class="app-meta-line">@r.AppName</div> }
                                </Template>
                            </RadzenDataGridColumn>

                            <RadzenDataGridColumn TItem="InfraReview" Property="DeploymentTarget" Title="Hosting Target" Width="150px">
                                <Template Context="r">
                                    @if (r.Error is null)
                                    {
                                        <RadzenBadge Text="@r.DeploymentTarget" IsPill="true"
                                                     BadgeStyle="@TargetBadge(r.DeploymentTarget)" />
                                    }
                                    else { <RadzenBadge Text="Scan Error" BadgeStyle="BadgeStyle.Danger" IsPill="true" Style="font-size:.7rem" /> }
                                </Template>
                            </RadzenDataGridColumn>

                            <RadzenDataGridColumn TItem="InfraReview" Property="DeploymentMethod" Title="Deploy Method" Width="140px">
                                <Template Context="r">
                                    @if (r.Error is null)
                                    {
                                        <span>@r.DeploymentMethod</span>
                                    }
                                </Template>
                            </RadzenDataGridColumn>

                            <RadzenDataGridColumn TItem="InfraReview" Title="CI/CD Files" Width="100px" Sortable="false" Filterable="false">
                                <Template Context="r">
                                    @if (r.CiCdFiles.Count > 0)
                                    {
