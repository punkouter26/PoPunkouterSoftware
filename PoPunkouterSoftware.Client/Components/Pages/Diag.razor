@page "/diag"
@rendermode WasmRenderModes.Interactive
@using System.Text.Json
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>PoPunkouterSoftware — Diagnostics</PageTitle>

<div class="app-page">

    @if (_loading)
    {
        <div class="app-card">
            <RadzenProgressBar Value="100" Mode="ProgressBarMode.Indeterminate" class="rz-my-3" />
            <p class="app-note rz-mb-0">Checking external connections…</p>
            @if (_slowLoad)
            {
                <RadzenAlert AlertStyle="AlertStyle.Warning" Variant="Variant.Outlined" ShowIcon="true" class="rz-mt-3" AllowClose="false">
                    Taking longer than expected — an external service may be slow or unreachable.
                </RadzenAlert>
            }
        </div>
    }
    else if (_result is not null)
    {
        var healthyChecks = _checks.Count(row => row.Status is "reachable" or "healthy");
        var degradedChecks = _checks.Count - healthyChecks;

        <section class="app-section">
            <div class="app-banner @(_result.Status == "healthy" ? "healthy" : "critical")">
                <div class="app-toolbar">
                    <div>
                        <div class="app-kicker">Current state</div>
                        <h2 class="app-card-title">@_result.Status.ToUpperInvariant()</h2>
                        <p class="app-note rz-mb-0">
                            Environment: @_result.Environment &nbsp;|&nbsp; Checked at: @_result.Timestamp.ToString("yyyy-MM-dd HH:mm:ss") UTC
                        </p>
                    </div>

                    <div class="app-actions">
                        <RadzenBadge BadgeStyle="@(_result.Status == "healthy" ? BadgeStyle.Success : BadgeStyle.Danger)"
                                     Text="@_result.Status.ToUpperInvariant()" />
                        <RadzenButton Text="Refresh" Icon="refresh" ButtonStyle="ButtonStyle.Light"
                                      Size="ButtonSize.Small" Click="@LoadAsync" />
                    </div>
                </div>

                <div class="app-dashboard-summary rz-mt-3">
                    <div class="app-metric-card">
                        <strong>@healthyChecks</strong>
                        <span class="app-note">Healthy checks</span>
                    </div>
                    <div class="app-metric-card">
                        <strong>@degradedChecks</strong>
                        <span class="app-note">Degraded checks</span>
                    </div>
                    <div class="app-metric-card">
                        <strong>@(_result.Config?.Count ?? 0)</strong>
                        <span class="app-note">Masked config values</span>
                    </div>
                </div>
            </div>
        </section>

        <section class="app-section app-spotlight-grid">
            <div class="app-card">
                <div class="app-kicker">Dependency checks</div>
                <h2 class="app-card-title rz-mb-2">External connections</h2>
                <div class="app-table-frame">
                    <RadzenDataGrid Data="@_checks" TItem="CheckRow" AllowSorting="true" AllowPaging="false">
                        <Columns>
                            <RadzenDataGridColumn TItem="CheckRow" Property="Name" Title="Service" Width="200px" />
                            <RadzenDataGridColumn TItem="CheckRow" Title="Status" Width="130px">
                                <Template Context="row">
                                    <RadzenBadge BadgeStyle="@(row.Status == "reachable" || row.Status == "healthy" ? BadgeStyle.Success : BadgeStyle.Danger)"
                                                 Text="@row.Status.ToUpperInvariant()" />
                                </Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="CheckRow" Property="Detail" Title="Detail" />
                        </Columns>
                    </RadzenDataGrid>
                </div>
            </div>

            <div class="app-card">
                <div class="app-kicker">Config snapshot</div>
                <h2 class="app-card-title rz-mb-2">Masked configuration</h2>
                <p class="app-note">Sensitive values remain masked. Use this view to confirm environment and wiring, not to inspect secrets.</p>
                @if (_result.Config is { } cfg)
                {
                    <div class="app-table-frame">
                        <RadzenDataGrid Data="@(cfg.Select(kv => new ConfigRow(kv.Key, kv.Value)).ToList())" TItem="ConfigRow" AllowSorting="true" AllowPaging="false">
                            <Columns>
                                <RadzenDataGridColumn TItem="ConfigRow" Property="Key" Title="Key" Width="300px" />
                                <RadzenDataGridColumn TItem="ConfigRow" Property="Value" Title="Value (masked)" />
                            </Columns>
                        </RadzenDataGrid>
                    </div>
                }
            </div>
        </section>
    }
    else if (_error is not null)
    {
        <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true">@_error</RadzenAlert>
    }
</div>

@code {
    private bool _loading = true;
    private bool _slowLoad = false;
    private HealthResult? _result;
    private string? _error;
    private List<CheckRow> _checks = [];

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _slowLoad = false;
        _error = null;
        _result = null;
        _checks = [];
        StateHasChanged();

        // Show a "taking longer than expected" hint after 5 seconds
        using var slowTimer = new CancellationTokenSource();
        var slowHint = Task.Delay(5_000, slowTimer.Token).ContinueWith(_ =>
        {
            if (_loading) { _slowLoad = true; InvokeAsync(StateHasChanged); }
        }, TaskContinuationOptions.OnlyOnRanToCompletion);

        try
        {
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(15));
            var response = await Http.GetAsync("/api/health", cts.Token);
            response.EnsureSuccessStatusCode();
            _result = await response.Content.ReadFromJsonAsync<HealthResult>();

            if (_result?.Checks is not null)
            {
                _checks = _result.Checks
                    .Select(kv =>
                    {
                        var detail = kv.Value.TryGetProperty("error", out var err)
                            ? err.GetString() ?? string.Empty
                            : kv.Value.TryGetProperty("httpStatus", out var code)
                                ? kv.Value.TryGetProperty("note", out var noteEl) && noteEl.ValueKind != System.Text.Json.JsonValueKind.Null
                                    ? $"HTTP {code} ({noteEl.GetString()})"
                                    : $"HTTP {code}"
                                : string.Empty;
                        var status = kv.Value.TryGetProperty("status", out var s)
                            ? s.GetString() ?? "unknown"
                            : "unknown";
                        return new CheckRow(kv.Key, status, detail);
                    })
                    .ToList();
            }
        }
        catch (OperationCanceledException)
        {
            _error = "Request timed out after 15 seconds — an external service may be unavailable.";
        }
        catch (Exception ex)
        {
            _error = $"Failed to reach /api/health: {ex.Message}";
        }
        finally
        {
            slowTimer.Cancel();
            _loading = false;
        }
    }

    private record CheckRow(string Name, string Status, string Detail);
    private record ConfigRow(string Key, string Value);

    private record HealthResult(
        string Status,
        string Application,
        string Environment,
        DateTime Timestamp,
        Dictionary<string, JsonElement>? Checks,
        Dictionary<string, string>? Config);
}
