@rendermode WasmRenderModes.Interactive
@using System.Text.Json
@using System.Text.Json.Serialization
@using PoPunkouterSoftware.Shared.Azure
@inject HttpClient Http

<PageTitle>PoPunkouterSoftware — Service Status</PageTitle>

<div class="app-page">

    @if (_loading)
    {
        <div class="app-card">
            <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" class="rz-my-2" />
            <p class="app-note rz-mb-0">Refreshing current service health…</p>
        </div>
    }
    else if (_error is not null)
    {
        <RadzenAlert AlertStyle="AlertStyle.Warning" Variant="Variant.Outlined" ShowIcon="true" class="rz-my-4">
            Could not load status data: @_error
        </RadzenAlert>
    }
    else if (_report is not null)
    {
        var allActive = _report.Services.All(s => s.CurrentStatus == "active");
        var anyBroken = _report.Services.Any(s => s.CurrentStatus is "broken" or "unreachable");
        var operationalCount = _report.Services.Count(s => s.CurrentStatus == "active");
        var degradedCount = _report.Services.Count - operationalCount;
        var avgUptime = _report.Services.Count == 0 ? 100 : _report.Services.Average(s => CalcUptime(s.Samples));
        var bannerClass = allActive ? "healthy" : anyBroken ? "critical" : "degraded";

        <section class="app-section">
            <div class="app-banner @bannerClass">
                <div class="app-toolbar">
                    <div>
                        <div class="app-kicker">Current state</div>
                        <h2 class="app-card-title">@(allActive ? "All systems operational" : anyBroken ? "Some services are degraded" : "Partial degradation")</h2>
                        <p class="app-note rz-mb-0">
                            Last updated: @_report.GeneratedAt.ToString("yyyy-MM-dd HH:mm UTC")
                            &nbsp;·&nbsp; @operationalCount / @_report.Services.Count services operational
                        </p>
                    </div>

                    <div class="app-grid metrics" style="min-width:min(100%, 520px);">
                        <div class="app-metric-card">
                            <strong>@operationalCount</strong>
                            <span class="app-note">Operational</span>
                        </div>
                        <div class="app-metric-card">
                            <strong>@degradedCount</strong>
                            <span class="app-note">Need attention</span>
                        </div>
                        <div class="app-metric-card">
                            <strong>@avgUptime.ToString("F1")%</strong>
                            <span class="app-note">Average uptime</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="app-section">
            @if (_pingerLoaded)
            {
                <div class="app-card" style="padding:.75rem 1rem;display:flex;align-items:center;gap:.75rem;">
                    <RadzenIcon Icon="wifi_tethering" Style="color:var(--app-accent-strong)" />
                    <span class="app-note" style="margin:0">Wake-up pinger active — last sweep: @(_pingerSweptAt?.ToString("HH:mm UTC") ?? "pending")</span>
                    <RadzenBadge Text="@($"{_pingerResults.Count} services")"
                                 BadgeStyle="BadgeStyle.Info" IsPill="true" Variant="Variant.Flat" />
                </div>
            }

            <div class="app-list">
                @foreach (var svc in _report.Services.OrderBy(s => s.CurrentStatus == "active" ? 1 : 0).ThenBy(s => s.FriendlyName ?? s.Name))
                {
                    var isActive = svc.CurrentStatus == "active";
                    var isBroken = svc.CurrentStatus is "broken" or "unreachable";
                    var statusClass = isActive ? "healthy" : isBroken ? "critical" : "degraded";
                    var statusColor = isActive ? "var(--app-accent-strong)" : isBroken ? "var(--app-danger-soft)" : "var(--app-accent-warm)";
                    var statusLabel = isActive ? "Operational" : isBroken ? "Degraded" : svc.CurrentStatus;
                    var uptimePct = CalcUptime(svc.Samples);
                    _pingerResults.TryGetValue(svc.Name, out var ping);

                    <div class="app-service-card @statusClass">
                        <div class="app-toolbar">
                            <div>
                                <div class="app-status-row">
                                    <span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:@statusColor"></span>
                                    <h3 class="app-card-title">@(svc.FriendlyName ?? svc.Name)</h3>
                                </div>
                                @if (!string.IsNullOrEmpty(svc.Url))
                                {
                                    <a href="@svc.Url" target="_blank" rel="noopener noreferrer" class="app-inline-link">@svc.Url</a>
                                }
                            </div>

                            <div class="app-chip-row">
                                <RadzenBadge Text="@statusLabel" IsPill="true"
                                             BadgeStyle="@(isActive ? BadgeStyle.Success : isBroken ? BadgeStyle.Danger : BadgeStyle.Warning)" />
                                @if (svc.ResponseTimeMs.HasValue)
                                {
                                    var rt = svc.ResponseTimeMs.Value;
                                    <RadzenBadge Text="@($"{rt} ms")" IsPill="true"
                                                 BadgeStyle="@(rt < 1000 ? BadgeStyle.Success : rt < 3000 ? BadgeStyle.Warning : BadgeStyle.Danger)"
                                                 Variant="Variant.Flat" />
                                }
                                <RadzenBadge Text="@($"Uptime {uptimePct:F1}%")" IsPill="true"
                                             BadgeStyle="@(uptimePct >= 99 ? BadgeStyle.Success : uptimePct >= 90 ? BadgeStyle.Warning : BadgeStyle.Danger)"
                                             Variant="Variant.Flat" />
                                @if (ping is not null)
                                {
                                    var pStyle = ping.Status == "reachable" ? BadgeStyle.Success : ping.Status == "timeout" ? BadgeStyle.Warning : BadgeStyle.Danger;
                                    var pingerTitle = $"Last pinger probe: {ping.PingedAt:HH:mm} UTC";
                                    <RadzenBadge Text="@($"Ping {ping.ResponseTimeMs}ms")" IsPill="true" BadgeStyle="@pStyle" Variant="Variant.Flat"
                                                 title="@pingerTitle" />
                                }
                            </div>
                        </div>

                        @{
                            var samples = svc.Samples.AsEnumerable().Reverse().TakeLast(30).ToList();
                            const int cellW = 14; const int cellH = 16; const int gap = 2;
                            var svgW = samples.Count * (cellW + gap);
                        }
                        @if (samples.Count > 1)
                        {
                            <div class="rz-mt-2" title="Uptime heatmap — green=active, red=broken, grey=unknown (oldest left, newest right)">
                                <svg width="@svgW" height="@cellH" style="display:block;">
                                    @for (int si = 0; si < samples.Count; si++)
                                    {
                                        var s = samples[si];
                                        var fill = s.Status == "active" ? "#22c55e"
                                                 : s.Status is "broken" or "unreachable" ? "#ef4444"
                                                 : "rgba(255,255,255,0.14)";
                                        var x = si * (cellW + gap);
                                        <rect x="@x" y="0" width="@cellW" height="@cellH" rx="3" fill="@fill"
                                              opacity="0.85">
                                            <title>@s.At.ToString("yyyy-MM-dd HH:mm") — @s.Status@(s.ResponseTimeMs.HasValue ? $" ({s.ResponseTimeMs}ms)" : "")</title>
                                        </rect>
                                    }
                                </svg>
                                <div class="app-note" style="display:flex;justify-content:space-between;margin-top:.3rem;font-size:.72rem;">
                                    <span>Older</span>
                                    <span>@samples.Count checks · @uptimePct.ToString("F0")% up</span>
                                    <span>Latest</span>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </section>

        <p class="app-note">Data derived from periodic Azure health scans. Status may lag real-time by up to several hours.</p>
    }
</div>

@code {
    private StatusPageReport? _report;
    private bool   _loading = true;
    private string? _error;

    // Pinger snapshot
    private bool   _pingerLoaded;
    private DateTime? _pingerSweptAt;
    private Dictionary<string, PingResultDto> _pingerResults = new(StringComparer.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        var opts = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
        try
        {
            _report = await Http.GetFromJsonAsync<StatusPageReport>("/api/status", opts);
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }

        // Load pinger results (non-fatal)
        try
        {
            var snap = await Http.GetFromJsonAsync<PingerSnapshotDto>("/api/pinger/status", opts);
            if (snap?.Swept == true && snap.Results is not null)
            {
                _pingerSweptAt = snap.SweptAt;
                _pingerResults = snap.Results.ToDictionary(r => r.Name, StringComparer.OrdinalIgnoreCase);
                _pingerLoaded  = true;
            }
        }
        catch { /* non-fatal */ }
    }

    private static double CalcUptime(List<StatusSample> samples)
    {
        if (samples.Count == 0) return 100.0;
        var up = samples.Count(s => s.Status == "active");
        return (double)up / samples.Count * 100.0;
    }

    // ── DTOs for pinger endpoint ──────────────────────────────────────
    private record PingerSnapshotDto(
        [property: JsonPropertyName("swept")] bool Swept,
        [property: JsonPropertyName("sweptAt")] DateTime? SweptAt,
        [property: JsonPropertyName("results")] List<PingResultDto>? Results);

    private record PingResultDto(
        [property: JsonPropertyName("name")] string Name,
        [property: JsonPropertyName("status")] string Status,
        [property: JsonPropertyName("responseTimeMs")] long ResponseTimeMs,
        [property: JsonPropertyName("pingedAt")] DateTime PingedAt);
}
