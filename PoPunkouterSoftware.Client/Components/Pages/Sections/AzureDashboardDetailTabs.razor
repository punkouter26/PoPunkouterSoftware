@using PoPunkouterSoftware.Shared.Azure
@using Radzen
@using Radzen.Blazor

@if (Report is { } report)
{
    <section class="app-section app-detail-tabs">
        <div class="app-kicker">Analysis</div>
        <h2 class="app-section-heading">Full Report Details</h2>
        <RadzenTabs @bind-SelectedIndex="SelectedTabIndex">
            <Tabs>
                @* ── Tab 1: Health (Downtime + Services + Zombies + Delta) ── *@
                <RadzenTabsItem Text="🩺 Health">
                    @* Downtime diagnosis — compact table, expandable details *@
                    @if (report.DowntimeDiagnoses?.Count > 0)
                    {
                        <div class="app-card rz-mb-3">
                            <div class="app-card-header">Downtime Diagnoses</div>
                            <div class="app-table-frame">
                                <RadzenDataGrid Data="@report.DowntimeDiagnoses.OrderBy(d => d.FriendlyName ?? d.Name)"
                                                TItem="ServiceDowntimeDiagnosis" AllowSorting="true"
                                                ExpandMode="DataGridExpandMode.Single"
                                                @bind-ExpandedItems="_expandedDiagnoses">
                                    <Template Context="diag">
                                        <div class="app-detail-panel soft rz-px-4 rz-py-3">
                                            <div class="app-detail-cause" style="background:color-mix(in srgb,@(CauseColor(diag.LikelyCause)) 8%,transparent)">
                                                <div class="app-detail-label" style="color:@(CauseColor(diag.LikelyCause))">Likely Cause</div>
                                                <div class="app-detail-body">@diag.LikelyCause</div>
                                            </div>
                                            @if (!string.IsNullOrEmpty(diag.SuggestedFix))
                                            {
                                                <div class="app-detail-block rz-mt-2">
                                                    <div class="app-detail-label">Suggested Fix</div>
                                                    @if (diag.SuggestedFix.TrimStart().StartsWith("az "))
                                                    {
                                                        <code class="app-detail-code">@diag.SuggestedFix</code>
                                                    }
                                                    else
                                                    {
                                                        <span class="app-detail-body">@diag.SuggestedFix</span>
                                                    }
                                                </div>
                                            }
                                            @if (diag.RecentDeployments.Count > 0)
                                            {
                                                <div class="app-detail-block rz-mt-2">
                                                    <div class="app-detail-label">Recent Deployments</div>
                                                    <div class="app-detail-table-wrap">
                                                        <table class="app-detail-table">
                                                            <thead><tr><th>Status</th><th>Time</th><th>Author</th><th>Message</th></tr></thead>
                                                            <tbody>
                                                                @foreach (var dep in diag.RecentDeployments)
                                                                {
                                                                    <tr>
                                                                        <td>
                                                                            <span style="font-weight:700;color:@(dep.StatusCode == 4 ? "var(--rz-success)" : dep.StatusCode == 3 ? "var(--rz-danger)" : "var(--rz-warning)")">@(dep.StatusText ?? "-")</span>
                                                                            @if (dep.Active == true) { <span class="app-note rz-ml-1">(active)</span> }
                                                                        </td>
                                                                        <td class="app-nowrap">@(dep.DeployedAt?.ToLocalTime().ToString("MM/dd HH:mm") ?? "-")</td>
                                                                        <td>@(dep.Author ?? "-")</td>
                                                                        <td class="app-break">@if (dep.Message is { Length: > 0 } msg) { <span>@(msg.Length > 120 ? msg[..120] + "..." : msg)</span> }</td>
                                                                    </tr>
                                                                }
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                </div>
                                            }
                                            @if (diag.RecentActivity.Count > 0)
                                            {
                                                <div class="app-detail-block rz-mt-2">
                                                    <div class="app-detail-label">Activity Log (48h)</div>
                                                    <div class="app-detail-table-wrap">
                                                        <table class="app-detail-table">
                                                            <thead><tr><th>Time</th><th>Operation</th><th>Status</th><th>Caller</th></tr></thead>
                                                            <tbody>
                                                                @foreach (var ev in diag.RecentActivity)
                                                                {
                                                                    <tr>
                                                                        <td class="app-nowrap">@(ev.EventTimestamp?.ToLocalTime().ToString("MM/dd HH:mm") ?? "-")</td>
                                                                        <td>@(ev.OperationName ?? "-")</td>
                                                                        <td><span style="color:@(ev.Status == "Succeeded" ? "var(--rz-success)" : ev.Status == "Failed" ? "var(--rz-danger)" : "inherit")">@(ev.Status ?? "-")</span></td>
                                                                        <td class="app-break">@(ev.Caller ?? "-")</td>
                                                                    </tr>
                                                                }
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </Template>
                                    <Columns>
                                        <RadzenDataGridColumn TItem="ServiceDowntimeDiagnosis" Property="FriendlyName" Title="Service" Width="200px">
                                            <Template Context="d"><strong>@(d.FriendlyName ?? d.Name)</strong></Template>
                                        </RadzenDataGridColumn>
                                        <RadzenDataGridColumn TItem="ServiceDowntimeDiagnosis" Title="Status" Width="110px">
                                            <Template Context="d">
                                                <span class="app-badge app-http-badge" style="@HttpStatusBadgeStyle(d.HttpStatus)">@d.HttpStatus</span>
                                                @if (d.IsSuspended) { <span class="app-badge app-badge-warning rz-ml-1">SUSP</span> }
                                            </Template>
                                        </RadzenDataGridColumn>
                                        <RadzenDataGridColumn TItem="ServiceDowntimeDiagnosis" Title="Cause" Sortable="false">
                                            <Template Context="d">
                                                <span class="app-note app-break">@(d.LikelyCause.Length > 80 ? d.LikelyCause[..80] + "..." : d.LikelyCause)</span>
                                            </Template>
                                        </RadzenDataGridColumn>
                                        <RadzenDataGridColumn TItem="ServiceDowntimeDiagnosis" Title="Fix" Width="50px" Sortable="false">
                                            <Template Context="d">
                                                @if (!string.IsNullOrEmpty(d.SuggestedFix))
                                                {
                                                    <span class="material-symbols-outlined" style="font-size:1rem;color:var(--rz-info)">construction</span>
                                                }
                                            </Template>
                                        </RadzenDataGridColumn>
                                    </Columns>
                                </RadzenDataGrid>
                            </div>
                        </div>
                    }

                    @* Services master grid *@
                    <div class="app-card rz-mb-3">
                        <div class="app-card-header">Services</div>
                        <div class="app-overflow-top">
                            <RadzenDataGrid Data="@AllServices" TItem="WebService" AllowSorting="true" AllowFiltering="true" FilterMode="FilterMode.SimpleWithMenu" PageSize="50" AllowPaging="@(TotalCount > 50)" GridLines="DataGridGridLines.Horizontal" Style="width:100%;min-width:900px">
                                <Columns>
                                    <RadzenDataGridColumn TItem="WebService" Property="FriendlyName" Title="Name" Width="180px">
                                        <Template Context="svc"><span style="font-weight:600">@(svc.FriendlyName ?? svc.Name)</span></Template>
                                    </RadzenDataGridColumn>
                                    <RadzenDataGridColumn TItem="WebService" Property="HttpStatus" Title="Status" Width="110px">
                                        <Template Context="svc"><span class="app-badge app-http-badge" style="@HttpStatusBadgeStyle(svc.HttpStatus)">@svc.HttpStatus</span></Template>
                                    </RadzenDataGridColumn>
                                    <RadzenDataGridColumn TItem="WebService" Property="PlatformState" Title="Platform" Width="100px" />
                                    <RadzenDataGridColumn TItem="WebService" Title="Response" Width="100px" TextAlign="TextAlign.Right">
                                        <Template Context="svc">@if (svc.Connectivity?.ResponseTime > 0) { <span>@svc.Connectivity.ResponseTime ms</span> } else { <span class="app-note">-</span> }</Template>
                                    </RadzenDataGridColumn>
                                    <RadzenDataGridColumn TItem="WebService" Title="Req 7d" Width="90px" TextAlign="TextAlign.Right">
                                        <Template Context="svc">@(svc.Metrics7Days?.Requests is int r ? r.ToString("N0") : "-")</Template>
                                    </RadzenDataGridColumn>
                                    <RadzenDataGridColumn TItem="WebService" Title="5xx 7d" Width="80px" TextAlign="TextAlign.Right">
                                        <Template Context="svc"><span style="@(svc.Metrics7Days?.Http5xx > 0 ? "color:var(--rz-danger)" : "")">@(svc.Metrics7Days?.Http5xx is int e && e > 0 ? e.ToString("N0") : "-")</span></Template>
                                    </RadzenDataGridColumn>
                                    <RadzenDataGridColumn TItem="WebService" Property="ResourceGroup" Title="Resource Group" Width="160px" />
                                    <RadzenDataGridColumn TItem="WebService" Title="URL" Width="240px"><Template Context="svc">@if (!string.IsNullOrEmpty(svc.Url)) { <a href="@svc.Url" target="_blank" rel="noopener noreferrer" class="app-link app-link-break">@svc.Url</a> }</Template></RadzenDataGridColumn>
                                </Columns>
                            </RadzenDataGrid>
                        </div>
                    </div>

                    @* Zombies (compact, only if > 0) *@
                    @if (report.ZombieApps?.Count > 0)
                    {
                        <div class="app-card rz-mb-3">
                            <div class="app-card-header">Zombie Apps</div>
                            <div class="app-table-frame app-overflow-y-230">
                                <RadzenDataGrid Data="@report.ZombieApps" TItem="ZombieApp" AllowPaging="false" AllowSorting="true">
                                    <Columns>
                                        <RadzenDataGridColumn TItem="ZombieApp" Property="Name" Title="App" />
                                        <RadzenDataGridColumn TItem="ZombieApp" Property="HttpStatus" Title="Status" Width="90px">
                                            <Template Context="z"><RadzenBadge Text="@(z.HttpStatus ?? "-")" IsPill="true" BadgeStyle="@HttpBadgeStyle(z.HttpStatus ?? "")" /></Template>
                                        </RadzenDataGridColumn>
                                        <RadzenDataGridColumn TItem="ZombieApp" Property="Recommendation" Title="Action" />
                                    </Columns>
                                </RadzenDataGrid>
                            </div>
                        </div>
                    }

                    @* Delta (if available) *@
                    @if (report.Delta is { } rptDelta && rptDelta.PreviousGeneratedAt is not null)
                    {
                        <div class="app-card rz-mb-3">
                            <div class="app-card-header">Scan Delta</div>
                            <div class="app-grid metrics app-grid-metrics-160 app-mb-1">
                                <div class="app-stat"><span class="app-stat-label">Previous scan</span><span class="app-stat-value app-detail-stat">@rptDelta.PreviousGeneratedAt.Value.ToLocalTime().ToString("MM/dd HH:mm")</span></div>
                                <div class="app-stat"><span class="app-stat-label">Broken services delta</span><span class="app-stat-value" style="color:@(rptDelta.BrokenServicesDelta > 0 ? "var(--rz-danger)" : rptDelta.BrokenServicesDelta < 0 ? "var(--rz-success)" : "inherit")">@(rptDelta.BrokenServicesDelta > 0 ? "+" : "")@rptDelta.BrokenServicesDelta</span></div>
                                <div class="app-stat"><span class="app-stat-label">Cost delta</span><span class="app-stat-value" style="color:@(rptDelta.CostDelta > 0 ? "var(--rz-warning)" : "var(--rz-success)")">@(rptDelta.CostDelta > 0 ? "+" : "")$@(rptDelta.CostDelta?.ToString("F2") ?? "-")</span></div>
                            </div>
                            @if (rptDelta.NewBrokenServices.Count > 0) { <div class="app-card rz-mb-3 app-border-left-danger"><div class="app-card-header app-tone-danger">Newly broken</div>@foreach (var s in rptDelta.NewBrokenServices) { <div class="app-note">@s</div> }</div> }
                            @if (rptDelta.RecoveredServices.Count > 0) { <div class="app-card rz-mb-3 app-border-left-success"><div class="app-card-header app-tone-success">Recovered</div>@foreach (var s in rptDelta.RecoveredServices) { <div class="app-note">@s</div> }</div> }
                            @if (rptDelta.NewOrphanedResources.Count > 0) { <div class="app-card rz-mb-3 app-border-left-warning"><div class="app-card-header app-tone-warning">New orphaned resources</div>@foreach (var s in rptDelta.NewOrphanedResources) { <div class="app-note">@s</div> }</div> }
                        </div>
                    }
                </RadzenTabsItem>

                @* ── Tab 2: Security (SSL + Storage) ── *@
                <RadzenTabsItem Text="🔒 Security">
                    @if (report.SslExpiry?.Count > 0)
                    {
                        <div class="app-card rz-mb-3">
                            <div class="app-card-header">SSL Certificates</div>
                            <div class="app-overflow-top">
                                <RadzenDataGrid Data="@report.SslExpiry" TItem="SslEntry" AllowSorting="true" AllowFiltering="true" FilterMode="FilterMode.SimpleWithMenu" GridLines="DataGridGridLines.Horizontal" Style="width:100%">
                                    <Columns>
                                        <RadzenDataGridColumn TItem="SslEntry" Property="Name" Title="Service" Width="180px" />
                                        <RadzenDataGridColumn TItem="SslEntry" Title="Status" Width="140px"><Template Context="e"><span class="app-badge app-http-badge" style="@SslBadgeStyle(e)">@SslLabel(e)</span></Template></RadzenDataGridColumn>
                                        <RadzenDataGridColumn TItem="SslEntry" Property="Expiry" Title="Expiry" Width="160px" />
                                        <RadzenDataGridColumn TItem="SslEntry" Property="Subject" Title="Subject" />
                                        <RadzenDataGridColumn TItem="SslEntry" Property="Url" Title="URL"><Template Context="e">@if (!string.IsNullOrEmpty(e.Url)) { <a href="@e.Url" target="_blank" rel="noopener noreferrer" class="app-link app-link-break">@e.Url</a> }</Template></RadzenDataGridColumn>
                                    </Columns>
                                </RadzenDataGrid>
                            </div>
                        </div>
                    }
                    @if (report.StorageInventory?.Count > 0)
                    {
                        var storageItems = report.StorageInventory;
                        var insecureItems = storageItems.Where(s => s.PublicBlobAccess || !s.HttpsOnly || s.MinTls is "TLS1_0" or "TLS1_1").ToList();
                        <div class="app-card rz-mb-3">
                            <div class="app-card-header">Storage Security</div>
                            @if (insecureItems.Count > 0)
                            {
                                <div class="app-callout warning rz-mb-2"><strong>@insecureItems.Count of @storageItems.Count account(s)</strong> have security misconfigurations.</div>
                                <div class="app-table-frame app-overflow-y-310">
                                    <RadzenDataGrid Data="@insecureItems" TItem="StorageItem" AllowSorting="true" GridLines="DataGridGridLines.Horizontal" Style="width:100%">
                                        <Columns>
                                            <RadzenDataGridColumn TItem="StorageItem" Property="Name" Title="Account" Width="150px" />
                                            <RadzenDataGridColumn TItem="StorageItem" Title="Public Blobs" Width="105px" TextAlign="TextAlign.Center"><Template Context="s">@(s.PublicBlobAccess ? "🔴" : "🟢")</Template></RadzenDataGridColumn>
                                            <RadzenDataGridColumn TItem="StorageItem" Title="HTTPS" Width="70px" TextAlign="TextAlign.Center"><Template Context="s">@(s.HttpsOnly ? "🟢" : "🔴")</Template></RadzenDataGridColumn>
                                            <RadzenDataGridColumn TItem="StorageItem" Property="MinTls" Title="Min TLS" Width="90px" TextAlign="TextAlign.Center"><Template Context="s"><RadzenBadge Text="@(s.MinTls ?? "?")" IsPill="true" BadgeStyle="@(s.MinTls is "TLS1_0" or "TLS1_1" ? BadgeStyle.Danger : BadgeStyle.Success)" /></Template></RadzenDataGridColumn>
                                            <RadzenDataGridColumn TItem="StorageItem" Property="Sku" Title="SKU" Width="100px" />
                                        </Columns>
                                    </RadzenDataGrid>
                                </div>
                            }
                            else
                            {
                                <div class="app-callout success">All @storageItems.Count storage accounts pass security checks.</div>
                            }
                        </div>
                    }
                </RadzenTabsItem>

                @* ── Tab 3: Config (Drift + App Insights) ── *@
                <RadzenTabsItem Text="⚙️ Config">
                    @if (report.ConfigDrift?.Count > 0)
                    {
                        var driftItems = report.ConfigDrift;
                        var driftWithIssues = driftItems.Where(d => d.IssueCount > 0).OrderByDescending(d => d.IssueCount).ToList();
                        var criticalDrift = driftItems.Count(d => d.Issues?.Any(i => i.Severity is "critical" or "high") == true);

                        @* Group by issue type *@
                        var issueGroups = driftWithIssues
                            .SelectMany(d => d.Issues ?? new(), (d, i) => new { Service = d.FriendlyName ?? d.Name, Issue = i.Issue, Severity = i.Severity })
                            .GroupBy(x => x.Issue)
                            .OrderByDescending(g => g.Count())
                            .ToList();

                        <div class="app-card rz-mb-3">
                            <div class="app-card-header">Config Drift</div>
                            @if (criticalDrift > 0)
                            {
                                <div class="app-callout danger rz-mb-2"><strong>@criticalDrift service(s)</strong> have high/critical severity issues.</div>
                            }
                            @if (issueGroups.Count > 0)
                            {
                                <div class="rz-mb-3">
                                    <div class="app-detail-label rz-mb-1">Issue Summary</div>
                                    <div class="app-badge-cluster">
                                        @foreach (var grp in issueGroups.Take(8))
                                        {
                                            var sev = grp.Max(x => x.Severity?.ToLowerInvariant() switch { "critical" or "high" => 3, "medium" or "warning" => 2, _ => 1 });
                                            var badgeStyle = sev == 3 ? BadgeStyle.Danger : sev == 2 ? BadgeStyle.Warning : BadgeStyle.Info;
                                            var badgeText = $"{grp.Key} ({grp.Count()})";
                                            <RadzenBadge Text="@badgeText" BadgeStyle="@badgeStyle" IsPill="true" class="app-badge-xs" />
                                        }
                                    </div>
                                </div>
                            }
                            @if (driftWithIssues.Count > 0)
                            {
                                <div class="app-table-frame app-overflow-y-340">
                                    <RadzenDataGrid Data="@driftWithIssues" TItem="ConfigDriftItem" AllowSorting="true" AllowPaging="false">
                                        <Columns>
                                            <RadzenDataGridColumn TItem="ConfigDriftItem" Property="FriendlyName" Title="Service" Width="160px"><Template Context="d"><strong>@(d.FriendlyName ?? d.Name)</strong></Template></RadzenDataGridColumn>
                                            <RadzenDataGridColumn TItem="ConfigDriftItem" Property="IssueCount" Title="#" Width="60px" TextAlign="TextAlign.Center"><Template Context="d"><RadzenBadge Text="@d.IssueCount.ToString()" IsPill="true" BadgeStyle="@(d.IssueCount > 3 ? BadgeStyle.Danger : d.IssueCount > 1 ? BadgeStyle.Warning : BadgeStyle.Info)" /></Template></RadzenDataGridColumn>
                                            <RadzenDataGridColumn TItem="ConfigDriftItem" Title="Top Issue" Sortable="false"><Template Context="d"><span class="app-meta-line">@(d.Issues?.FirstOrDefault()?.Issue ?? "—")</span></Template></RadzenDataGridColumn>
                                        </Columns>
                                    </RadzenDataGrid>
                                </div>
                            }
                        </div>
                    }

                    @if (report.AppInsightsMetrics?.Count > 0)
                    {
                        <div class="app-card rz-mb-3">
                            <div class="app-card-header">Application Insights</div>
                            <div class="app-table-frame app-overflow-y-230">
                                <RadzenDataGrid Data="@report.AppInsightsMetrics" TItem="AppInsightsMetric" AllowSorting="true" GridLines="DataGridGridLines.Horizontal" Style="width:100%">
                                    <Columns>
                                        <RadzenDataGridColumn TItem="AppInsightsMetric" Property="Name" Title="Resource" Width="200px" />
                                        <RadzenDataGridColumn TItem="AppInsightsMetric" Property="Requests7Days" Title="Requests 7d" Width="120px" TextAlign="TextAlign.Right"><Template Context="m">@(m.Requests7Days?.ToString("N0") ?? "-")</Template></RadzenDataGridColumn>
                                        <RadzenDataGridColumn TItem="AppInsightsMetric" Property="FailedRequests7Days" Title="Failed 7d" Width="100px" TextAlign="TextAlign.Right"><Template Context="m"><span style="color:@(m.FailedRequests7Days > 0 ? "var(--rz-danger)" : "inherit")">@(m.FailedRequests7Days?.ToString("N0") ?? "-")</span></Template></RadzenDataGridColumn>
                                        <RadzenDataGridColumn TItem="AppInsightsMetric" Property="Exceptions7Days" Title="Exceptions 7d" Width="120px" TextAlign="TextAlign.Right"><Template Context="m"><span style="color:@(m.Exceptions7Days > 0 ? "var(--rz-warning)" : "inherit")">@(m.Exceptions7Days?.ToString("N0") ?? "-")</span></Template></RadzenDataGridColumn>
                                    </Columns>
                                </RadzenDataGrid>
                            </div>
                        </div>
                    }
                </RadzenTabsItem>

                @* ── Tab 4: Inventory (All Resources + Orphaned) ── *@
                <RadzenTabsItem Text="📦 Inventory">
                    @if (report.AllResourceSummary is { } allRes && allRes.Total > 0)
                    {
                        <div class="app-card rz-mb-3">
                            <div class="app-card-header">Resources by Type</div>
                            <RadzenRow>
                                <RadzenColumn SizeXS="12" SizeMD="6">
                                    <RadzenChart Style="height:260px">
                                        <RadzenDonutSeries TItem="KeyValuePair<string, int>" Data="@(allRes.ByType.OrderByDescending(kv => kv.Value).Take(12).ToList())" CategoryProperty="Key" ValueProperty="Value" InnerRadius="70" />
                                    </RadzenChart>
                                </RadzenColumn>
                                <RadzenColumn SizeXS="12" SizeMD="6">
                                    <div class="app-table-frame app-overflow-y-230">
                                        <RadzenDataGrid Data="@(allRes.ByType.OrderByDescending(kv => kv.Value).ToList())" TItem="KeyValuePair<string, int>" AllowSorting="true" GridLines="DataGridGridLines.Horizontal">
                                            <Columns>
                                                <RadzenDataGridColumn TItem="KeyValuePair<string, int>" Property="Key" Title="Type" />
                                                <RadzenDataGridColumn TItem="KeyValuePair<string, int>" Property="Value" Title="Count" Width="80px" TextAlign="TextAlign.Right" />
                                            </Columns>
                                        </RadzenDataGrid>
                                    </div>
                                </RadzenColumn>
                            </RadzenRow>
                        </div>
                        @foreach (var grp in allRes.ResourcesByType.OrderBy(kv => kv.Key))
                        {
                            <div class="app-card rz-mb-3">
                                <div class="app-card-header">@grp.Key <span class="app-note rz-ml-1">(@grp.Value.Count)</span></div>
                                <div class="app-table-frame">
                                    <RadzenDataGrid Data="@grp.Value" TItem="ResourceDetail" AllowSorting="true" PageSize="10" AllowPaging="@(grp.Value.Count > 10)" GridLines="DataGridGridLines.Horizontal" Style="width:100%">
                                        <Columns>
                                            <RadzenDataGridColumn TItem="ResourceDetail" Property="Name" Title="Name" />
                                            <RadzenDataGridColumn TItem="ResourceDetail" Property="ResourceGroup" Title="Resource Group" Width="160px" />
                                            <RadzenDataGridColumn TItem="ResourceDetail" Property="Location" Title="Location" Width="120px" />
                                            <RadzenDataGridColumn TItem="ResourceDetail" Property="Sku" Title="SKU" Width="100px"><Template Context="r">@(r.Sku ?? "-")</Template></RadzenDataGridColumn>
                                        </Columns>
                                    </RadzenDataGrid>
                                </div>
                            </div>
                        }
                    }
                    @if (report.OrphanedResources?.Count > 0)
                    {
                        <div class="app-card rz-mb-3">
                            <div class="app-card-header">Orphaned Resources</div>
                            <div class="app-table-frame app-overflow-y-230">
                                <RadzenDataGrid Data="@report.OrphanedResources" TItem="OrphanedResource" AllowSorting="true" GridLines="DataGridGridLines.Horizontal" Style="width:100%">
                                    <Columns>
                                        <RadzenDataGridColumn TItem="OrphanedResource" Property="Name" Title="Resource" Width="180px" />
                                        <RadzenDataGridColumn TItem="OrphanedResource" Property="Type" Title="Type" Width="180px" />
                                        <RadzenDataGridColumn TItem="OrphanedResource" Property="ResourceGroup" Title="Resource Group" Width="160px" />
                                        <RadzenDataGridColumn TItem="OrphanedResource" Property="Reason" Title="Reason" />
                                        <RadzenDataGridColumn TItem="OrphanedResource" Property="EstimatedMonthlyCost" Title="Est. Cost/mo" Width="120px"><Template Context="r">@(r.EstimatedMonthlyCost ?? "-")</Template></RadzenDataGridColumn>
                                    </Columns>
                                </RadzenDataGrid>
                            </div>
                        </div>
                    }
                </RadzenTabsItem>
            </Tabs>
        </RadzenTabs>
    </section>
}

@code {
    [Parameter] public AzureReport? Report { get; set; }
    [Parameter] public int TotalCount { get; set; }
    [Parameter] public bool ShowAdvancedDiagnostics { get; set; }
    [Parameter] public int SelectedTabIndex { get; set; }
    [Parameter] public EventCallback<int> SelectedTabIndexChanged { get; set; }

    private IList<ServiceDowntimeDiagnosis> _expandedDiagnoses = new List<ServiceDowntimeDiagnosis>();

    private IEnumerable<WebService> AllServices =>
        (Report?.WebServices?.Services ?? new List<WebService>())
            .OrderBy(s => s.HttpStatus == "active" ? 0 : s.HttpStatus == "broken" ? 1 : 2)
            .ThenBy(s => s.FriendlyName ?? s.Name);

    private static string HttpStatusBadgeStyle(string status) => status switch
    {
        "active" => "background:var(--rz-success);color:#fff",
        "broken" => "background:var(--rz-danger);color:#fff",
        "unreachable" => "background:var(--rz-warning);color:#fff",
        _ => "background:var(--rz-base-300);color:var(--rz-text-color)",
    };

    private static BadgeStyle HttpBadgeStyle(string? status) => status switch
    {
        "active" => BadgeStyle.Success,
        "broken" => BadgeStyle.Danger,
        "unreachable" => BadgeStyle.Warning,
        _ => BadgeStyle.Info,
    };

    private static string SslBadgeStyle(SslEntry e) => (e.DaysLeft ?? 999) switch
    {
        <= 0 => "background:var(--rz-danger);color:#fff",
        <= 14 => "background:var(--rz-danger);color:#fff",
        <= 30 => "background:var(--rz-warning);color:#fff",
        _ => "background:var(--rz-success);color:#fff",
    };

    private static string SslLabel(SslEntry e) => e.DaysLeft switch
    {
        null => "unknown",
        <= 0 => "EXPIRED",
        <= 14 => $"{e.DaysLeft}d CRITICAL",
        <= 30 => $"{e.DaysLeft}d WARNING",
        _ => $"{e.DaysLeft}d OK",
    };

    private static string CauseColor(string cause) => cause switch
    {
        var c when c.Contains("quota", StringComparison.OrdinalIgnoreCase) => "var(--rz-warning)",
        var c when c.Contains("stopped", StringComparison.OrdinalIgnoreCase) => "var(--rz-danger)",
        var c when c.Contains("failed", StringComparison.OrdinalIgnoreCase) => "var(--rz-danger)",
        _ => "var(--rz-info)",
    };
}
